/// Shared memory allocator for Hexa projects

//
// Hexa
//

let defaultReserveMegabytes = #if bit64 4096u16 #else 128u16 #end
let reserveAtVirtualMegabyte = #if bit64 4096 * 4096 * 4 #else(4096 / 4) * 3 - (defaultReserveMegabytes * 2) #end

fun reserveIgnore(megabytes UInt16) {
	// Nothing, already did reserve
}

// TODO take custom reserveAtVirtualMegabyte
fun reserve(megabytes UInt16) {
	// TODO
	wrapReserve = reserveIgnore
	wrapAllocate = allocate
	// TODO wrapFree = free
}

fun allocate(size UInt32) #if bit64 UInt64 #else UInt32 #end {
	// TODO
	return 0
}

// TODO Use `SizeOfPointer`
fun allocateFirst(size UInt32) #if bit64 UInt64 #else UInt32 #end {
	reserve(defaultReserveMegabytes)
	return allocate(size)
}

// fun free(pointer UInt64, size UInt32) {
// // TODO
// }

fun freeStub(pointer UInt64, size UInt32) {
	// Nothing, not yet ready
}

var wrapReserve = reserve

var wrapAllocate = allocateFirst

var wrapFree = freeStub

// TODO somehow set as default calling convention for all functions + depending on bits
@stdcall

// TODO Use higher allocation density on 32-bit to prolong buffer usage
@draft
@dllExport('tofitaHexaReserve')
fun tofitaHexaReserve(megabytes UInt16) {
	wrapReserve(megabytes)
}

@draft
@dllExport('tofitaHexaAllocate')
fun tofitaHexaAllocate(size UInt32) {
	return wrapAllocate(size)
}

@draft
@dllExport('tofitaHexaFree')
fun tofitaHexaFree(pointer #if bit64 UInt64 #else UInt32 #end, size UInt32) {
	wrapFree(pointer, size)
}

//
// Tofita
//

// High performance function, that does completely nothing
// TODO link names
@fastcall
@dllExport('tofitaFastStub')
fun tofitaFastStub(rcx ConstArrayPointer<UInt8>, rdx ConstArrayPointer<UInt8>) UInt32 {
	kkernelDebugLog("--> tofitaFastStub --> caller=%8".utf16(), callerAddress)
	kkernelDebugLog("--> tofitaFastStub --> rcx=%8 rdx=%8".utf16(), rcx as! UInt64, rdx as! UInt64)
	return 0
}

@stdcall
@convention('stdcall')
@dllExport('tofitaStdStub')
fun tofitaStdStub(arg ConstArrayPointer<UInt8>) UInt32 {
	kkernelDebugLog("--> tofitaStdStub --> arg=%8 caller=%8".utf16(), arg as! UInt64, callerAddress)
	return 0
}

// External
@emitHeader
#if bit64
	@linkName('kosmos32FastSystemCallWrapper')
#else
	// Expected convention by assembly
	@convention('fastcall')
	@linkName('@kosmos32FastSystemCallWrapper@8')
#end
declare fun kosmos32FastSystemCallWrapper(rcx TofitaSyscalls, rdx SyscallPayload) SyscallResult

// Return value is placed into RAX
// Only ecx/edx available in x86-32 fastcall, so use rcx/rdx pair only
@convention('fastcall')
#if bit64
	@dllExport('kosmos32FastSystemCall')
	@fastcall // TODO same for 32bit?
#else
	@dllExport('@kosmos32FastSystemCall@8')
#end
fun kosmos32FastSystemCall(
	rcx TofitaSyscalls,
	rdx SyscallPayload
) SyscallResult
// TODO bit64 or bits64?
{
	return kosmos32FastSystemCallWrapper(rcx, rdx)
}

//
// General
//

@dllExport('kosmos32ExitProcess')
fun kosmos32ExitProcess(exitCode Int32) Void {
	let payload = new ByValue<ExitProcessPayload>()
	payload.ref.exitCode = exitCode
	kosmos32FastSystemCall(TofitaSyscalls.ExitProcess, payload as! SyscallPayload)
}

// TODO Hexa: basic "C-like" compiler could compile headers like that:
@rename('(uint64_t)__builtin_extract_return_addr(__builtin_return_address (0))')
declare let callerAddress: UInt64

@rename('(uint64_t)__builtin_extract_return_addr(__builtin_return_address (1))')
declare let callerCallerAddress: UInt64

// TODO this avoids some weird crashes
var payload ByValue<DebugLogPayload> = ByValue<DebugLogPayload>()
#if bit64
	@convention('fastcall')
#else
	@convention('cdecl')
#end
@dllExport('kkernelDebugLog')
// TODO @rename('kkernelDebugLog')
// TODO drop arguments and formatting support, use formatted string pre-printing on the user side
fun kkernelDebugLog(message ConstArrayPointer<ClangWideChar>, extra SizeOfPointer = 0, more SizeOfPointer = 0) Void {
	// let payload = new ByValue<DebugLogPayload>()
	// TODO @stack
	// TODO ^ optimize to allocate on stack, some lifetime flag on creation and usage?
	payload.ref.message = message as! UInt64 // TODO ConstArrayPointer.address UInt64/32
	// TODO ConstArrayPointer.unsafeFromAddress(PointerAddress.unsafeFrom(123u64))
	// TODO on the engine side ValidateUserPointer<DebugLogPayload>.clone() <= does SEH copy of sizeOf
	// TODO hint `as! PointerAddress` use instead `fromAddress`
	payload.ref.extra = extra as! UInt64
	payload.ref.more = more as! UInt64
	// payload.ref.caller = callerAddress
	kosmos32FastSystemCall(TofitaSyscalls.DebugLog, payload.ref as! SyscallPayload)
}

// #if bit64
// declare Payload = UInt64
// // TODO instead of `.ref as! Payload` use `.asAddress PointerAddress` built-in type (aka size_t)
// #else
// declare Payload = UInt32
// #end
//
//
// NjRAA
//

@dllExport('njraaSwapWindowFramebuffer')
fun njraaSwapWindowFramebuffer(fb WindowFramebuffer) Void {
	// TODO make it possible to (lazy swap?) copy only part of the fb aka dirty region
	let payload = new ByValue<SwapWindowFramebufferPayload>()
	let payload = payload.ref
	payload.fb = fb as! UInt64
	kosmos32FastSystemCall(TofitaSyscalls.SwapWindowFramebuffer, payload as! SyscallPayload)
}

@dllExport('njraaGetOrCreateWindowFramebuffer')
fun njraaGetOrCreateWindowFramebuffer(fb WindowFramebuffer) Void {
	let payload = new ByValue<SwapWindowFramebufferPayload>()
	let payload = payload.ref
	payload.fb = fb as! UInt64
	kosmos32FastSystemCall(TofitaSyscalls.GetOrCreateWindowFramebuffer, payload as! SyscallPayload)
}

//
// User Interface
//

@dllExport('tofitaCreateWindowEx')
fun tofitaCreateWindowEx(payload CreateWindowExPayload) UInt64 {
	return kosmos32FastSystemCall(TofitaSyscalls.CreateWindowEx, payload as! SyscallPayload) as! UInt64
}

@dllExport('tofitaShowWindow')
fun tofitaShowWindow(payload ShowWindowPayload) Void {
	// let payload = new ByValue<ShowWindowPayload>()
	// let payload = payload.ref
	// let payload = ShowWindowPayload()
	// payload.windowId = windowId
	// payload.nCmdShow = nCmdShow
	// payload.x = x
	// payload.y = y
	// payload.width = width
	// payload.height = height
	kkernelDebugLog("--> tofitaShowWindow --> rcx=%8 rdx=%8".utf16(), payload.windowId as! UInt64, payload.nCmdShow as! UInt64)
	kosmos32FastSystemCall(TofitaSyscalls.ShowWindow, payload as! SyscallPayload)
	kkernelDebugLog("--> tofitaShowWindow --> done".utf16())
}

@dllExport('tofitaGetMessage')
fun tofitaGetMessage(payload GetMessagePayload) Bool32 {
	// TODO filters
	// TODO UInt64 -> Bool32 is a lossy conversion, type check it somehow
	return kosmos32FastSystemCall(TofitaSyscalls.GetMessage as! TofitaSyscalls, payload as! SyscallPayload) as! Bool32
}

@dllExport('tofitaPeekMessage')
fun tofitaPeekMessage(payload PeekMessagePayload) Bool32 {
	// TODO filters
	// TODO UInt64 -> Bool32 is a lossy conversion, type check it somehow
	return kosmos32FastSystemCall(TofitaSyscalls.PeekMessage as! TofitaSyscalls, payload as! SyscallPayload) as! Bool32
}

@dllExport('tofitaPostMessage')
fun tofitaPostMessage(payload PostMessagePayload) Bool32 {
	return kosmos32FastSystemCall(TofitaSyscalls.PostMessage as! TofitaSyscalls, payload as! SyscallPayload) as! Bool32
}

@dllExport('tofitaSetTimer')
fun tofitaSetTimer(payload SetTimerPayload) UInt64 {
	kkernelDebugLog("--> tofitaSetTimer --> hWnd=%8 nIDEvent=%u".utf16(),
		payload.hwnd as! UInt64, payload.nIDEvent as! UInt64)
	let result = kosmos32FastSystemCall(TofitaSyscalls.SetTimer as! TofitaSyscalls, payload as! SyscallPayload) as! UInt64
	kkernelDebugLog("--> tofitaSetTimer --> done, result=%u".utf16(), result as! UInt64)
	return result
}

@dllExport('tofitaKillTimer')
fun tofitaKillTimer(payload KillTimerPayload) Bool32 {
	kkernelDebugLog("--> tofitaKillTimer --> hWnd=%8 nIDEvent=%u".utf16(),
		payload.hwnd as! UInt64, payload.nIDEvent as! UInt64)
	let result = kosmos32FastSystemCall(TofitaSyscalls.KillTimer as! TofitaSyscalls, payload as! SyscallPayload) as! Bool32
	kkernelDebugLog("--> tofitaKillTimer --> done, result=%u".utf16(), result as! UInt64)
	return result
}

// kosmos32/64.asm -> incbin
@emitHeader // TODO Hexa: fix it for vars
@customHeader('extern const uint8_t binFont[];')

@extern @rename('binFont') declare let binFont ConstArrayPointer<UInt8>
@extern @rename('binFontBitmap') declare let binFontBitmap ConstArrayPointer<UInt8>
let fontWidth UInt32 = 512
let fontHeight UInt32 = 32

@customHeader('
	extern const uint8_t binFont[] asm("binFont");
	extern const uint8_t binFontBitmap[] asm("binFontBitmap");
')
declare fun embed() Void

@dllExport('tofitaFont')
fun tofitaFont() ConstArrayPointer<UInt8> {
	return binFont
}

@dllExport('tofitaFontBitmap')
fun tofitaFontBitmap() ConstArrayPointer<UInt8> {
	return binFontBitmap
}

@rename('__readgsqword')
declare fun readgsqword(offset UInt32) UInt64

@rename('__readfsqword')
declare fun readfsqword(offset UInt32) UInt64

@rename('__readgsdword')
declare fun readgsdword(offset UInt32) UInt32

@rename('__readfsdword')
declare fun readfsdword(offset UInt32) UInt32
