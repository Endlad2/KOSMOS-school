// Tofita
let _fltused Int64 = 0

// Only ecx/edx available in x86-32 fastcall, so use rcx/rdx pair only
@convention('fastcall')
#if bit64
	@dllImport('kosmos32FastSystemCall')
	@fastcall // TODO same for 32bit?
#else
	@dllImport('@kosmos32FastSystemCall@8')
#end
// TODO ^ template substitution for var names in decorators by default
declare fun kosmos32FastSystemCall(rcx TofitaSyscalls,
	#if bit64
		rdx UInt64 = 0
	#else
		rdx UInt32 = 0
	#end
) #if bit64 UInt64 #else UInt32 #end
// TODO link name + dll import
@fastcall declare fun tofitaFastStub(rcx UInt64, rdx UInt64) UInt32
@stdcall declare fun tofitaStdStub(arg ConstArrayPointer<UInt8>) UInt32

// TODO yeah some ...variadic version needed + update logging everywhere (also zero-cost when not used)
#if bit64
	@convention('fastcall')
#else
	@convention('cdecl')
#end
// @dllImport @linkAsIs
@dllImport('kkernelDebugLog')
declare fun kkernelDebugLogREAL(message ConstArrayPointer<ClangWideChar>, extra SizeOfPointer = 0, more SizeOfPointer = 0) Void

@customHeader('
	#define kkernelDebugLog_(m, e, mo) kkernelDebugLogREAL_((wchar_t *)m, (size_t)(e), (size_t)(mo))
')
declare fun kkernelDebugLog(message ConstArrayPointer<ClangWideChar>, extra UInt64 = 0, more UInt64 = 0) Void

@rename('(uint64_t)__builtin_extract_return_addr(__builtin_return_address (0))')
declare let callerAddress: UInt64

@rename('(uint64_t)__builtin_extract_return_addr(__builtin_return_address (1))')
declare let callerCallerAddress: UInt64

@rename('(uint64_t)__builtin_frame_address(0)')
declare let callerFrame: UInt64

fun kkernelDebugLogxx(message ConstArrayPointer<ClangWideChar>, extra UInt64 = 0, more UInt64 = 0) Void {
	// { return }
	let payload = new ByValue<DebugLogPayload>()
	// TODO @stack
	// TODO ^ optimize to allocate on stack, some lifetime flag on creation and usage?
	payload.ref.message = message as! UInt64 // TODO ConstArrayPointer.address UInt64/32
	// TODO ConstArrayPointer.unsafeFromAddress(PointerAddress.unsafeFrom(123u64))
	// TODO on the engine side ValidateUserPointer<DebugLogPayload>.clone() <= does SEH copy of sizeOf
	// TODO hint `as! PointerAddress` use instead `fromAddress`
	payload.ref.extra = extra
	payload.ref.more = more
	// payload.ref.caller = callerAddress
	kosmos32FastSystemCall(TofitaSyscalls.DebugLog, payload.ref as! #if bit64 UInt64 #else UInt32 #end)
}

// General
@dllImport @linkAsIs
declare fun kosmos32ExitProcess(exitCode Int32) Void

// User Interface
@dllImport @linkAsIs
declare fun tofitaCreateWindowEx(payload CreateWindowExPayload) UInt64
@dllImport @linkAsIs
declare fun tofitaShowWindow(payload ShowWindowPayload) Void
@dllImport @linkAsIs
declare fun tofitaGetMessage(payload GetMessagePayload) Bool32
@dllImport @linkAsIs
declare fun tofitaPostMessage(payload PostMessagePayload) Bool32
@dllImport @linkAsIs
declare fun tofitaPeekMessage(payload PeekMessagePayload) Bool32

// Timers
@dllImport @linkAsIs
declare fun tofitaSetTimer(payload SetTimerPayload) UInt64
@dllImport @linkAsIs
declare fun tofitaKillTimer(payload KillTimerPayload) Bool32

// NjRAA
@dllImport @linkAsIs
declare fun njraaGetOrCreateWindowFramebuffer(fb WindowFramebuffer) Void
@dllImport @linkAsIs
declare fun njraaSwapWindowFramebuffer(fb WindowFramebuffer) Void

// Fonts
// TODO this is just a temporary solution
let fontWidth UInt32 = 512
let fontHeight UInt32 = 32

@dllImport @linkAsIs
declare fun tofitaFont() ConstArrayPointer<UInt8>

@dllImport @linkAsIs
declare fun tofitaFontBitmap() ConstArrayPointer<UInt8>
