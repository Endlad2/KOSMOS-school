@struct class LogPalette {
	var palVersion UInt16
	var palNumEntries UInt16
	var palPalEntry ArrayPointer<PalEntry>
	new () { }
}

// TODO rename to `PaletteEntry`
@struct class PalEntry {
	var peRed UInt8
	var peGreen UInt8
	var peBlue UInt8
	var peFlags UInt8
	new () { }
}

enum HandleType : UInt16 {
	HInstance = 0xCFA8
	HIcon = 0xCFA9
	HBrush = 0xCFAA
	HCursor = 0xCFAB
	HLocal = 0xCFAC
	HGlobal = 0xCFAD
	HWnd = 0xCFAE
	HMenu = 0xCFAF
	HDc = 0xCFB0
	HFont = 0xCFB1
	HRsrc = 0xCFB2
	HMonitor = 0xCFB3
	HModule = 0xCFB4
	HBitmap = 0xCFB5
	HPen = 0xCFB6
	HRgn = 0xCFB7
	HPalette = 0xCFB8
}

@struct class HandleTypeHolder {
	let handleType HandleType
}

// TODO inherit from HandleTypeHolder
@struct class Pen {
	let handleType HandleType = HandleType.HPen
	var style Int32
	var width Int32
	var color COLORREF
	new () { }
}

@struct class LogPen {
	var lopnStyle UInt32
	var lopnWidth ByValue<Point> // Only x is used for width
	var lopnColor COLORREF
	new () { }
}

@struct class Brush {
	let handleType HandleType = HandleType.HBrush
	var pattern HBitmap? = null
	var color COLORREF = 0u32
	new () { }
}

// TODO rename BITMAP to Bitmap and add to namespace `Gdi`
@struct class BITMAP {
	var bmType Int32
	var bmWidth Int32
	var bmHeight Int32
	var bmWidthBytes Int32
	var bmPlanes Int16
	var bmBitsPixel Int16
	var bmBits SizeOfPointer
	new () { }
}

@packed
@struct class BITMAPINFOHEADER {
	var biSize UInt32
	var biWidth Int32
	var biHeight Int32
	var biPlanes UInt16
	var biBitCount UInt16
	var biCompression UInt32
	var biSizeImage UInt32
	var biXPelsPerMeter Int32
	var biYPelsPerMeter Int32
	var biClrUsed UInt32
	var biClrImportant UInt32
	new () { }
}

@packed
@struct class RGBQUAD {
	var rgbBlue UInt8
	var rgbGreen UInt8
	var rgbRed UInt8
	var rgbReserved UInt8
	new () { }
}

@struct class BITMAPINFO {
	var bmiHeader ByValue<BITMAPINFOHEADER>
	var bmiColors ArrayByValue<RGBQUAD, 1>
	new () { }
}

// TODO move to `typesUser.hexa`, `typesGdi.hexa` etc
@struct class MINMAXINFO {
	var ptReserved ByValue<Point>
	var ptMaxSize ByValue<Point>
	var ptMaxPosition ByValue<Point>
	var ptMinTrackSize ByValue<Point>
	var ptMaxTrackSize ByValue<Point>
	new () { }
}

enum ROP2 : Int32 {
	R2_BLACK = 1
	R2_COPY_PEN = 13
	R2_MASK_NOT_PEN = 3
	R2_MASK_PEN = 9
	R2_MASK_PEN_NOT = 5
	R2_MERGE_NOT_PEN = 12
	R2_MERGE_PEN = 15
	R2_MERGE_PEN_NOT = 14
	R2_NOP = 11
	R2_NOT = 6
	R2_NOT_COPY_PEN = 4
	R2_NOT_MASK_PEN = 8
	R2_NOT_MERGE_PEN = 2
	R2_NOT_XOR_PEN = 10
	R2_WHITE = 16
	R2_XOR_PEN = 7
}

// TODO rename to `DrawingContext` and add to namespace `Gdi`
@struct class DC {
	let handleType HandleType = HandleType.HDc

	// Selectable objects
	var hPalette HPalette = null
	var hBitmap HBitmap = null
	var hBrush HBrush = null
	var hFont HFont = null
	var hPen HPen = null
	var hRgn HRgn = null

	var penPosX Int32 = 0
	var penPosY Int32 = 0

	// Framebuffer
	// var fb WindowFramebuffer?
	var fb ByValue<WindowFramebuffer>

	// Client area
	let width UInt16
	let height UInt16

	var textColor COLORREF = 0x000000 as! COLORREF // Black
	var bkColor COLORREF = 0xFFFFFF as! COLORREF // White
	/// This brush is created on-demand to be used by the functions that cannot work directly with COLORREF
	var bkBrush HBrush = null
	var brushOrgX Int32 = 0
	var brushOrgY Int32 = 0
	var rop2 ROP2 = ROP2.R2_COPY_PEN

	new () { }
}

// Define the Bitmap structure to hold DIB data
@struct
class Bitmap {
	let handleType HandleType = HandleType.HBitmap
	var width Int32
	var height Int32
	var bitsPerPixel Int16
	var bytesPerRow Int32
	var bits ArrayPointer<UInt8>
	var colorTable ArrayPointer<ByValue<RGBQUAD>>
	var colorTableSize UInt32
	var isTopDown Bool
	new () { }
}

@struct
class FILETIME {
	var dwLowDateTime UInt32
	var dwHighDateTime UInt32
	new () { }
}

@struct
class LARGE_INTEGER {
	var quadPart Int64
	new () { }
}
