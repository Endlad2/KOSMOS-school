fun userCallHandled(@volatile process TofitaProcess, syscall TofitaSyscalls) Bool {
	@volatile var frame = process.frame

	if syscall == TofitaSyscalls.CreateWindowEx {
		serialPrintf("<> syscall == TofitaSyscalls.CreateWindowEx at %8\n", frame.rdxArg1)
		if not probeForReadOkay(frame.rdxArg1, sizeOf<CreateWindowExPayload>()) {
			serialPrintf("<> CreateWindowExPayload bad sizeof at %8\n", frame.rdxArg1)
			return false
		}

		var payload = frame.rdxArg1 as! CreateWindowExPayload

		// TODO why 16?
		// if probeForReadOkay((payload.lpClassName as! UInt64), 16) {
		// serialPrintf("<> lpClassName == %S\n", payload.lpClassName)
		// }

		if probeForReadOkay((payload.lpWindowName as! UInt64), 4) {
			serialPrintf("<> good lpWindowName == %S\n", payload.lpWindowName)
		} else {
			serialPrintf("<> bad lpWindowName == %8\n", payload.lpWindowName)
		}

		var window = overlappedWindow_create(process.pid)
		window.width = payload.nWidth as! UInt16
		window.height = payload.nHeight as! UInt16
		// TODO window.x = payload.x
		// TODO window.y = payload.y

		// Set icon when available (TODO use window class icon in the future)
		if let icon16 = process.icon16 {
			window.icon = icon16
		}

		// TODO ensure this opaque value, and not an accessible pointer
		window.hWnd = payload.hWnd as! Handle

		// TODO proper probe method, probably separate probeForWideCharOkay
		// ^ probably should produce `String?` and separate `probeForCopyOkay`
		if probeForReadOkay((payload.lpWindowName as! UInt64), 4) {
			// TODO must error `candidate function not viable: no known conversion from 'const wchar_t *' to 'const uint16_t      *'` window.title = String.fromUTF16z(payload.lpWindowName)
			// TODO should limit the max string length and be SEH-safe
			// ^ maybe sehCountNonNull16bits(), oh no no no
			// this way may go out of think if virtual memory changes
			// instead String.consumeUTF16z that doesn't create a copy
			// no no no no no! just copy into global (TLS) char16[MAX_PATH]
			// and copy string from there! yeah! sehStringFromUTF16z(addr, limit: MAX_PATH - 1?)
			window.title = String.fromUTF16z(payload.lpWindowName as! ConstArrayPointer<UInt16>)
			// TODO ^ limit to lower address space, to not capable of reading engine mem
			// TODO another idea of temporal mapping to zero page?
			// ^ this way values would be zero anyway so can be easily tested with guard
			// TODO trim()
		} else {
			// TODO use app name here
			window.title = process.name
			// TODO disallow title to be "Kosmos" for third-party apps for security
		}

		frame.raxReturn = window.windowId
		serialPrintf("<> window.windowId == %8\n", window.windowId)
		process.schedulable = true
		return true
	}

	if syscall == TofitaSyscalls.ShowWindow {
		// TODO merge to probeForReadAndConvert os it takes <T> and returns nullable for `if let`
		if not probeForReadOkay(frame.rdxArg1, sizeOf<ShowWindowPayload>()) {
			serialPrintf("<> TofitaSyscalls.ShowWindow == not probeForReadOkay\n")
			return false
		}

		let payload = frame.rdxArg1 as! ShowWindowPayload

		let windowId = payload.windowId
		serialPrintf("<> ShowWindow.windowId == %8\n", windowId)
		let nCmdShow = payload.nCmdShow
		// TODO may fail - use Hexa' nullability feature here
		let window = overlappedWindow_find(process.pid, windowId)
		serialPrintf("<> ShowWindow.window == %8\n", window as! UInt64)

		// TODO add nullability feature
		// Bring to front if requested
		if window != null, nCmdShow != CmdShow.SW_UNCHANGED {
			window.visible = true
			overlappedWindow_attach(windowId)
		}

		// Resize if requested
		if let window = window, payload.width != -1, payload.height != -1 {
			window.width = payload.width as! UInt16
			window.height = payload.height as! UInt16
		}

		process.schedulable = true
		return true
	}

	// TODO to exhaustive switch over selected syscall enum subset
	// ^ just multi-inherit multiple enums
	if syscall == TofitaSyscalls.GetMessage {
		// TODO pointers should be validated to be not within engine space!
		if not probeForWriteOkay(frame.rdxArg1, sizeOf<GetMessagePayload>()) {
			// TODO wrote here %S instead of %8 and it crashed, must think about such safety
			// serialPrintf("<> GetMessage frame.rdxArg1 probe fail %8\n", frame.rdxArg1)
			return false
		}

		let payload = frame.rdxArg1 as! GetMessagePayload

		// TODO Finally, the WM_PAINT is sent. However, note that the system treats this message specially and
		// it comes only after all other messages from the message queue are handled and it is empty.
		// If you think about it, it makes sense. As long as there are other messages in the queue,
		// they may change the state of the control, resulting in a need for yet another repainting.
		// ^ make separate queue for WM_PAINT messages and deduplicate them per window
		frame.raxReturn = getMessage(process, payload).toZeroOrOne

		// Should sorts of loop forever
		if frame.raxReturn != 0 {
			process.schedulable = true

			// Mark timer event as processed to prevent repeated firing of the same timer message
			// This acknowledges that the timer event has been handled and clears it from the active timer queue
			if payload.message == Message.WM_TIMER {
				let timerId = payload.wParam
				let timer = timerList[timerId]
				if timer != null {
					timer.processed = true
				}
			}
		} else {
			// process.syscallToHandle = TofitaSyscalls.GetMessage
			process.awaitsGetMessage = true
		}

		return true
	}

	if syscall == TofitaSyscalls.PeekMessage {
		/* Validate payload to ensure it’s writable, as peekMessage may write to the MSG struct */
		if not probeForWriteOkay(frame.rdxArg1, sizeOf<PeekMessagePayload>()) {
			serialPrintf("<> TofitaSyscalls.PeekMessage == not probeForWriteOkay\n")
			return false
		}

		let payload = frame.rdxArg1 as! PeekMessagePayload

		/* Log window ID for debugging, consistent with other handlers */
		// serialPrintf("<> PeekMessage.windowId == %8\n", payload.hwnd)

		/* Call peekMessage to check the message queue; convert result to 0 or 1 */
		frame.raxReturn = peekMessage(process, payload).toZeroOrOne

		if frame.raxReturn != 0 {
			// Mark timer event as processed to prevent repeated firing of the same timer message
			// This acknowledges that the timer event has been handled and clears it from the active timer queue
			if payload.message == Message.WM_TIMER {
				let timerId = payload.wParam
				let timer = timerList[timerId]
				if timer != null {
					timer.processed = true
				}
			}
		}

		/* PeekMessage is non-blocking, so always keep process schedulable */
		process.schedulable = true
		return true
	}

	if syscall == TofitaSyscalls.PostMessage {
		if not probeForReadOkay(frame.rdxArg1, sizeOf<PostMessagePayload>()) {
			return false
		}

		var payload = frame.rdxArg1 as! PostMessagePayload

		frame.raxReturn = postMessage(process, payload).toZeroOrOne

		process.schedulable = true
		return true
	}

	if syscall == TofitaSyscalls.SetTimer {
		if not probeForReadOkay(frame.rdxArg1, sizeOf<SetTimerPayload>()) {
			serialPrintf("<> TofitaSyscalls.SetTimer == not probeForReadOkay\n")
			return false
		}

		let payload = frame.rdxArg1 as! SetTimerPayload

		// Find and reset timer
		for i in timerListUsed {
			let timer = timerList[i]
			if
				timer != null,
				timer.processId == process.pid,
				timer.hwnd == payload.hwnd,
				timer.nIDEvent == payload.nIDEvent
			{
				// Reset timer
				timer.nextFireTime = uptimeMilliseconds + payload.uElapse
				frame.raxReturn = payload.nIDEvent // Return timer ID
				process.schedulable = true
				return true
			}
		}

		// Create new timer
		var timer = new Timer()
		timer.hwnd = payload.hwnd
		timer.nIDEvent = payload.nIDEvent
		timer.interval = payload.uElapse
		// TODO Hexa: ensure `UInt64 + UInt32` does `a + (uint64_t)b`
		timer.nextFireTime = uptimeMilliseconds + payload.uElapse
		timer.timerProc = payload.timerProc
		timer.processId = process.pid

		// Add to timerList
		// TODO update existing ones
		timerList[timerListUsed] = timer
		timerListUsed++

		frame.raxReturn = payload.nIDEvent // Return timer ID
		process.schedulable = true
		return true
	}

	if syscall == TofitaSyscalls.KillTimer {
		if not probeForReadOkay(frame.rdxArg1, sizeOf<KillTimerPayload>()) {
			serialPrintf("<> TofitaSyscalls.KillTimer == not probeForReadOkay\n")
			return false
		}

		let payload = frame.rdxArg1 as! KillTimerPayload

		// Find and remove timer
		for i in timerListUsed {
			let timer = timerList[i]
			if
				timer != null,
				timer.processId == process.pid,
				timer.hwnd == payload.hwnd,
				timer.nIDEvent == payload.nIDEvent
			{
				// Shift remaining timers
				for j in i ... (timerListUsed - 1) {
					timerList[j] = timerList[j + 1]
				}
				timerList[timerListUsed - 1] = null
				timerListUsed--
				frame.raxReturn = 1
				process.schedulable = true
				break
			}
		}

		frame.raxReturn = 0
		process.schedulable = true
		return true
	}

	return false
}
