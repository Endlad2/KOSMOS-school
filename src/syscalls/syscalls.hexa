// TODO protocol generator should make wrappers around user pointers,
// to validate them be within < lower user space otherwise nullify them or cancel syscall
// TODO randomize on every build (use version number)
// @randomize(min: 2, max: 123456)
let userSyscalls = 123000

// TODO store all syscalls as huge complex enum and generate all wrappers with macro
// and serializer to-from enum tags / wow64
// @castTo('TofitaSyscalls')
// TODO LMAO rename to just TofitaSyscall
enum TofitaSyscalls : UInt32 {
	// System
	// TODO Disallow user to call them by index
	Noop = 0
	Cpu = 1
	Message = 2

	// User
	// TODO DebugLog = userSyscalls
	// TODO Hexa: randomize via `#int define` and add `#string define` too
	DebugLog = 123000
	CreateWindowEx = 123001 // TODO auto compute while ensure unique
	ShowWindow = 123002 // TODO auto compute
	GetMessage = 123003 // TODO auto compute
	PostMessage = 123004 // TODO auto compute
	PeekMessage = 123005 // TODO auto compute
	GetOrCreateWindowFramebuffer = 123006 // TODO auto compute
	SwapWindowFramebuffer = 123007 // TODO auto compute
	ExitProcess = 123008 // TODO auto compute
	SetTimer = 123009
	KillTimer = 123010
	LazySwap = 123011
}

// Note: all pointers should be 64-bit even for 32-bit processes

// Note: all pointers must be stored as `UInt64` to avoid in-engine occasional dereferencing

@sizeOfLessOrEqual(4096)
@struct class ProcessStartupInformation {
	var pid UInt64 = 0
	var entry UInt64 = 0
	var dllEntries UInt64 = 0
	var dllCount UInt64 = 0
	var base UInt64 = 0
	new () { }
}

@struct
// @byValue // TODO Hexa: inherited by others and cancelable by `@byValue(false)`
// bad idea cause would make also "pointers" being ByValue passing
class SyscallPayload { }

@struct
class SyscallResult { }

@struct @sizeOf(8 * 3)
// TODO Hexa: `class DebugLogPayload SyscallPayload {}` and eliminate all `as! SyscallPayload`
class DebugLogPayload {
	// ConstArrayPointer<UInt16>
	var message UInt64
	// TODO count chars at user space, and transfer as length for SEH probing
	var extra UInt64 = 0
	var more UInt64 = 0
	/// Address of the caller (i.e. instruction pointer)
	var caller UInt64 = 0
	new () { }
}

@struct @sizeOf(8 * 2)
class SwapWindowFramebufferPayload {
	var fb UInt64 // WindowFramebuffer
	new () { }
}

/// Updates window visual state like position and visibility
// TODO rename to `SetWindowState`
@struct @sizeOf(8 * 2)
class ShowWindowPayload {
	// TODO `let`
	var windowId UInt64

	// TODO do not use W32 types in syscalls
	var nCmdShow CmdShow
	// TODO `Int?` for unchanged, current is `-1`
	var x Int32
	var y Int32
	var width Int32
	var height Int32
	new () { }
}

@struct @sizeOf(4)
class ExitProcessPayload {
	var exitCode Int32
	new () { }
}

@struct
class LParam {
	// NOTE making function that returns `LParam` to avoid cast makes sense `makeULongParam`
	static fun makeULong(low UInt16, high UInt16) UInt32 {
		return ((low & 0xFFFFu32) | ((high & 0xFFFFu32) << 16u32))
	}

	static fun makeLong(low Int16, high Int16) Int32 {
		return ((low & 0xFFFFi32) | ((high & 0xFFFFi32) << 16i32))
	}

	static fun loWord(lParam UInt32) UInt16 {
		return lParam & 0xFFFFu16
	}

	static fun hiWord(lParam UInt32) UInt16 {
		return lParam >> 16u16
	}

	// NOTE `static fun fromMINMAXINFO` or other way-around

	new () { }
}

@struct
class WParam {
	new () { }
}

// TODO use pointer wrappers instead of raw pointers
@struct @sizeOf(8 * 8 + 5 * 4 + 4)
// TODO Hexa: `class CreateWindowExPayload SyscallPayload {}`
// TODO rename to CreateWindowPayload
class CreateWindowExPayload {
	var wc UInt64 // WindowClass
	var hWnd UInt64 // HWnd

	// CreateWindowEx
	// var lpClassName UInt64 // ConstArrayPointer<ClangWideChar>
	// TODO count chars at user space, and transfer as length for SEH probing
	var lpWindowName UInt64 // ConstArrayPointer<ClangWideChar>
	var dwStyle UInt32
	var x Int32
	var y Int32
	var nWidth Int32
	var nHeight Int32
	// var hWndParent UInt64 // HWnd
	// var hMenu UInt64 // HMenu
	// var hInstance UInt64 // HInstance
	// var lpParam UInt64 // LParam
	new () { }
}

@struct @sizeOf(8 + 4 + 8 * 2 + 4)
class PostMessagePayload {
	var hWnd UInt64 // HWnd
	var msg Message
	// TODO ^ rename to msgId or something, to make clear it's not a struct
	var wParam UInt64 // WParam
	var lParam UInt64 // LParam
	new () { }
}

@struct @sizeOf(8 * 2 + 4 * 2)
class GetMessagePayload {
	var hwnd UInt64 // HWnd
	var message Message
	var wParam UInt64 // WParam
	var lParam UInt64 // LParam
	var time UInt32
	var pt ByValue<Point>
	var lPrivate UInt32

	// TODO why twice?
	var hWnd UInt64 // HWnd
	var wMsgFilterMin UInt32
	var wMsgFilterMax UInt32
	new () { }
}

@struct @sizeOf(8 * 2 + 4 * 2) // TODO `@packed`
class PeekMessagePayload {
	var hwnd UInt64 // HWnd
	var message Message
	var wParam UInt64 // WParam
	var lParam UInt64 // LParam
	var time UInt32
	var pt ByValue<Point>
	var lPrivate UInt32

	var wMsgFilterMin UInt32
	var wMsgFilterMax UInt32
	var remove UInt32
	new () { }
}

@struct @sizeOf(8 * 3 + 4)
class SetTimerPayload {
	var hwnd UInt64 // HWnd
	var nIDEvent UInt64 // Timer ID
	var uElapse UInt32 // Interval in milliseconds
	var timerProc UInt64 // TIMERPROC function pointer (0 if NULL)
	new () { }
}

@struct @sizeOf(8 * 2)
class KillTimerPayload {
	var hwnd UInt64 // HWnd
	var nIDEvent UInt64 // Timer ID
	new () { }
}
