@struct
class CPUID {
	// TODO implement value arrays init in constructor
	// CPU specs
	var vendorID ArrayByValue<UInt8, 13> = [0]
	var brandName ArrayByValue<UInt8, 48> = [0]
	var cpuFamily UInt32 = 0
	var cpuModel UInt32 = 0
	var cpuStepping UInt32 = 0
	new () { }

	// CPUID raw values
	var maxStandardFunction ArrayByValue<UInt32, 1> = [0]
	var maxExtendedFunction ArrayByValue<UInt32, 1> = [0]
	var extendedECX ArrayByValue<UInt32, 1> = [0]
	var extendedEDX ArrayByValue<UInt32, 1> = [0]
	var standardECX ArrayByValue<UInt32, 1> = [0]
	var standardEDX ArrayByValue<UInt32, 1> = [0]
	var standardEAX ArrayByValue<UInt32, 1> = [0]
	var standardEBX ArrayByValue<UInt32, 1> = [0]
	var leaf7EBX ArrayByValue<UInt32, 1> = [0]
	var leafAEBX ArrayByValue<UInt32, 1> = [0]
	var leafAECX ArrayByValue<UInt32, 1> = [0]
	var leafAEDX ArrayByValue<UInt32, 1> = [0]
	var leaf2EAX ArrayByValue<UInt32, 1> = [0]
	var leaf2EBX ArrayByValue<UInt32, 1> = [0]
	var leaf2ECX ArrayByValue<UInt32, 1> = [0]
	var leaf2EDX ArrayByValue<UInt32, 1> = [0]
	var leaf4EAX ArrayByValue<UInt32, 1> = [0]
	var leaf4EBX ArrayByValue<UInt32, 1> = [0]
	var leaf4ECX ArrayByValue<UInt32, 1> = [0]
	var leaf4EDX ArrayByValue<UInt32, 1> = [0]
	var leafBTopologyLevel ArrayByValue<UInt32, 1> = [0] // EAX for leaf 0x0B
	var leaf15TSC ArrayByValue<UInt32, 1> = [0] // EAX for leaf 0x15
	var leaf15Crystal ArrayByValue<UInt32, 1> = [0] // EBX for leaf 0x15
	var leaf15Nominal ArrayByValue<UInt32, 1> = [0] // ECX for leaf 0x15
	var leaf16BaseMHz ArrayByValue<UInt32, 1> = [0] // EAX for leaf 0x16
	var leaf16MaxMHz ArrayByValue<UInt32, 1> = [0] // EBX for leaf 0x16
	var leaf16BusMHz ArrayByValue<UInt32, 1> = [0] // ECX for leaf 0x16
	var cacheLineSize UInt32 = 0
	var logicalProcessorCount UInt32 = 0
	var cpuTemperatureCelsius Float = 0.0
	var performanceCounterCount UInt32 = 0
	var performanceCounterWidth UInt32 = 0
	var performanceCounterSupported = false
	var invariantTscSupported = false

	// Feature flags for easy access
	var nxBitSupported = false
	var patSupported = false
	var clflushSupported = false
	var fpuSupported = false
	var pseSupported = false
	var tscSupported = false
	var msrSupported = false
	var paeSupported = false
	var mceSupported = false
	var cx8Supported = false
	var apicSupported = false
	var sepSupported = false
	var mtrrSupported = false
	var pgeSupported = false
	var mcaSupported = false
	var cmovSupported = false
	var pse36Supported = false
	var psnSupported = false
	var dsSupported = false
	var acpiSupported = false
	var mmxSupported = false
	var fxsrSupported = false
	var ssSupported = false
	var tmSupported = false
	var pbeSupported = false
	var ia64Supported = false
	var sseSupported = false
	var sse2Supported = false
	var sse3Supported = false
	var pclmulqdqSupported = false
	var aesSupported = false
	var dtes64Supported = false
	var monitorSupported = false
	var dscplSupported = false
	var vmxSupported = false
	var smxSupported = false
	var eistSupported = false
	var tm2Supported = false
	var cnxtidSupported = false
	var cmpxchg16bSupported = false
	var xtprSupported = false
	var pdcmSupported = false
	var pcidSupported = false
	var dcaSupported = false
	var movbeSupported = false
	var popcntSupported = false
	var tscdeadlineSupported = false
	var f16cSupported = false
	var rdrandSupported = false
	var xsaveSupported = false
	var osxsaveSupported = false
	var ssse3Supported = false
	var sse41Supported = false
	var sse42Supported = false
	var avxSupported = false
	var fsgsbaseSupported = false
	var bmi1Supported = false
	var hleSupported = false
	var avx2Supported = false
	var smepSupported = false
	var bmi2Supported = false
	var ermsSupported = false
	var invpcidSupported = false
	var rtmSupported = false
	var rdseedSupported = false
	var shaSupported = false
	var hyperthreadingSupported = false
	var longModeSupported = false
	var oneGbPagesSupported = false
	var rdtscpSupported = false
	var threedNowSupported = false
	var threedNowExtSupported = false
	var amdMmxExtSupported = false
	var fullThreedNowSupported = false
	var fma3Supported = false
	var fma4Supported = false
	var sse4aSupported = false
	var xopSupported = false
	var x2apicSupported = false
}

let cpuidExtendedLevels UInt32 = 0x80000000u32 // TODO valid values u/i8/16/32/64

fun getCPUID() CPUID {
	var result = new CPUID()
	var stub ArrayByValue<UInt32, 1> = [0]

	// Read the Vendor name
	cpuid(
		0,
		0,
		result.maxStandardFunction.ref,
		(result.vendorID.ref as! UInt64 + 0) as! ArrayPointer<UInt32>,
		(result.vendorID.ref as! UInt64 + 8) as! ArrayPointer<UInt32>,
		(result.vendorID.ref as! UInt64 + 4) as! ArrayPointer<UInt32>
	)

	cpuid(
		cpuidExtendedLevels,
		0,
		result.maxExtendedFunction.ref,
		stub.ref,
		stub.ref,
		stub.ref
	)

	cpuid(
		cpuidExtendedLevels + 1,
		0,
		stub.ref,
		stub.ref,
		result.extendedECX.ref,
		result.extendedEDX.ref
	)

	// TODO Hexa: disallow mixing bit ops and logical (!=) ops!
	// Like Infix(bit, Infix(logical, ...))
	// result.nxBitSupported = 0 != result.extendedEDX[0] & 0b00000000000100000000000000000000u32
	// TODO ^ also precedence bug or Infix bug: the result of this is Bool, not integer, must not be assignable

	result.nxBitSupported = 0 != (result.extendedEDX[0] & (1u32 << 20)) // NX (bit 20)

	// Get standard CPUID features (function 0x00000001)
	// Check if function 0x00000001 is supported
	if result.maxStandardFunction[0] >= 0x00000001 {
		cpuid(
			0x00000001,
			0,
			result.standardEAX.ref,
			result.standardEBX.ref,
			result.standardECX.ref,
			result.standardEDX.ref
		)
	}

	if result.maxExtendedFunction[0] >= cpuidExtendedLevels + 4 {
		cpuid(
			cpuidExtendedLevels + 2,
			0,
			// TODO trim?
			(result.brandName.ref as! UInt64 + 0) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 4) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 8) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 12) as! ArrayPointer<UInt32>
		)
		cpuid(
			cpuidExtendedLevels + 3,
			0,
			(result.brandName.ref as! UInt64 + 16) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 20) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 24) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 28) as! ArrayPointer<UInt32>
		)
		cpuid(
			cpuidExtendedLevels + 4,
			0,
			(result.brandName.ref as! UInt64 + 32) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 36) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 40) as! ArrayPointer<UInt32>,
			(result.brandName.ref as! UInt64 + 44) as! ArrayPointer<UInt32>
		)
	}

	// Fill the flags
	// Due to arrays being 0-filled by default, we just do bit masking without checking feature levels

	// Standard CPUID feature detection (function 0x00000001)
	// EDX features
	result.fpuSupported = 0 != (result.standardEDX[0] & (1u32 << 0)) // FPU (bit 0)
	result.pseSupported = 0 != (result.standardEDX[0] & (1u32 << 3)) // PSE (bit 3)
	result.tscSupported = 0 != (result.standardEDX[0] & (1u32 << 4)) // TSC (bit 4)
	result.msrSupported = 0 != (result.standardEDX[0] & (1u32 << 5)) // MSR (bit 5)
	result.paeSupported = 0 != (result.standardEDX[0] & (1u32 << 6)) // PAE (bit 6)
	result.mceSupported = 0 != (result.standardEDX[0] & (1u32 << 7)) // MCE (bit 7)
	result.cx8Supported = 0 != (result.standardEDX[0] & (1u32 << 8)) // CX8 (bit 8)
	result.apicSupported = 0 != (result.standardEDX[0] & (1u32 << 9)) // APIC (bit 9)
	result.sepSupported = 0 != (result.standardEDX[0] & (1u32 << 11)) // SEP (bit 11)
	result.mtrrSupported = 0 != (result.standardEDX[0] & (1u32 << 12)) // MTRR (bit 12)
	result.pgeSupported = 0 != (result.standardEDX[0] & (1u32 << 13)) // PGE (bit 13)
	result.mcaSupported = 0 != (result.standardEDX[0] & (1u32 << 14)) // MCA (bit 14)
	result.cmovSupported = 0 != (result.standardEDX[0] & (1u32 << 15)) // CMOV (bit 15)
	result.patSupported = 0 != (result.standardEDX[0] & (1u32 << 16)) // PAT (bit 16)
	result.pse36Supported = 0 != (result.standardEDX[0] & (1u32 << 17)) // PSE36 (bit 17)
	result.psnSupported = 0 != (result.standardEDX[0] & (1u32 << 18)) // PSN (bit 18)
	result.clflushSupported = 0 != (result.standardEDX[0] & (1u32 << 19)) // CLFLUSH (bit 19)
	result.dsSupported = 0 != (result.standardEDX[0] & (1u32 << 21)) // DS (bit 21)
	result.acpiSupported = 0 != (result.standardEDX[0] & (1u32 << 22)) // ACPI (bit 22)
	result.mmxSupported = 0 != (result.standardEDX[0] & (1u32 << 23)) // MMX (bit 23)
	result.fxsrSupported = 0 != (result.standardEDX[0] & (1u32 << 24)) // FXSR (bit 24)
	result.sseSupported = 0 != (result.standardEDX[0] & (1u32 << 25)) // SSE (bit 25)
	result.sse2Supported = 0 != (result.standardEDX[0] & (1u32 << 26)) // SSE2 (bit 26)
	result.ssSupported = 0 != (result.standardEDX[0] & (1u32 << 27)) // SS (bit 27)
	result.hyperthreadingSupported = (0 != (result.standardEDX[0] & (1u32 << 28))) and (result.logicalProcessorCount > 1) // HT Technology (bit 28) + count >1
	result.tmSupported = 0 != (result.standardEDX[0] & (1u32 << 29)) // TM (bit 29)
	result.ia64Supported = 0 != (result.standardEDX[0] & (1u32 << 30)) // IA64 (bit 30)
	result.pbeSupported = 0 != (result.standardEDX[0] & (1u32 << 31)) // PBE (bit 31)

	// ECX features
	result.sse3Supported = 0 != (result.standardECX[0] & (1u32 << 0)) // SSE3 (bit 0)
	result.pclmulqdqSupported = 0 != (result.standardECX[0] & (1u32 << 1)) // PCLMULQDQ (bit 1)
	result.dtes64Supported = 0 != (result.standardECX[0] & (1u32 << 2)) // DTES64 (bit 2)
	result.monitorSupported = 0 != (result.standardECX[0] & (1u32 << 3)) // MONITOR (bit 3)
	result.dscplSupported = 0 != (result.standardECX[0] & (1u32 << 4)) // DSCPL (bit 4)
	result.vmxSupported = 0 != (result.standardECX[0] & (1u32 << 5)) // VMX (bit 5)
	result.smxSupported = 0 != (result.standardECX[0] & (1u32 << 6)) // SMX (bit 6)
	result.eistSupported = 0 != (result.standardECX[0] & (1u32 << 7)) // EIST (bit 7)
	result.tm2Supported = 0 != (result.standardECX[0] & (1u32 << 8)) // TM2 (bit 8)
	result.ssse3Supported = 0 != (result.standardECX[0] & (1u32 << 9)) // SSSE3 (bit 9)
	result.cnxtidSupported = 0 != (result.standardECX[0] & (1u32 << 10)) // CNXTID (bit 10)
	result.cmpxchg16bSupported = 0 != (result.standardECX[0] & (1u32 << 13)) // CMPXCHG16B (bit 13)
	result.xtprSupported = 0 != (result.standardECX[0] & (1u32 << 14)) // xTPR (bit 14)
	result.pdcmSupported = 0 != (result.standardECX[0] & (1u32 << 15)) // PDCM (bit 15)
	result.pcidSupported = 0 != (result.standardECX[0] & (1u32 << 17)) // PCID (bit 17)
	result.dcaSupported = 0 != (result.standardECX[0] & (1u32 << 18)) // DCA (bit 18)
	result.sse41Supported = 0 != (result.standardECX[0] & (1u32 << 19)) // SSE4.1 (bit 19)
	result.sse42Supported = 0 != (result.standardECX[0] & (1u32 << 20)) // SSE4.2 (bit 20)
	result.movbeSupported = 0 != (result.standardECX[0] & (1u32 << 22)) // MOVBE (bit 22)
	result.popcntSupported = 0 != (result.standardECX[0] & (1u32 << 23)) // POPCNT (bit 23)
	result.tscdeadlineSupported = 0 != (result.standardECX[0] & (1u32 << 24)) // TSCDeadline (bit 24)
	result.aesSupported = 0 != (result.standardECX[0] & (1u32 << 25)) // AES (bit 25)
	result.xsaveSupported = 0 != (result.standardECX[0] & (1u32 << 26)) // XSAVE (bit 26)
	result.osxsaveSupported = 0 != (result.standardECX[0] & (1u32 << 27)) // OSXSAVE (bit 27)
	result.avxSupported = 0 != (result.standardECX[0] & (1u32 << 28)) // AVX (bit 28)
	result.f16cSupported = 0 != (result.standardECX[0] & (1u32 << 29)) // F16C (bit 29)
	result.rdrandSupported = 0 != (result.standardECX[0] & (1u32 << 30)) // RDRND (bit 30)
	result.fma3Supported = 0 != (result.standardECX[0] & (1u32 << 12)) // FMA3 (bit 12)
	result.x2apicSupported = 0 != (result.standardECX[0] & (1u32 << 21)) // x2APIC (bit 21)

	// Extended ECX features (AMD-specific)
	result.fma4Supported = 0 != (result.extendedECX[0] & (1u32 << 16)) // FMA4 (bit 16)
	result.sse4aSupported = 0 != (result.extendedECX[0] & (1u32 << 6)) // SSE4a (bit 6)
	result.xopSupported = 0 != (result.extendedECX[0] & (1u32 << 11)) // XOP (bit 11)

	// Extract numeric CPU specifications
	if result.maxStandardFunction[0] >= 0x00000001 {
		// Extract CPU signature from EAX
		var eaxValue = result.standardEAX[0]
		result.cpuStepping = eaxValue & 0xFu32
		var baseModel = (eaxValue >> 4) & 0xFu32
		var baseFamily = (eaxValue >> 8) & 0xFu32

		// Handle extended family/model for newer CPUs
		var extendedFamily = (eaxValue >> 20) & 0xFFu32
		var extendedModel = (eaxValue >> 16) & 0xFu32

		// Get deterministic cache parameters (leaf 4)
		// Check if leaf 4 is supported
		if result.maxStandardFunction[0] >= 0x00000004 {
			var cacheLevel = 0u32
			while cacheLevel < 32 { // Reasonable upper limit TODO
				cpuid(
					0x00000004,
					cacheLevel,
					result.leaf4EAX.ref,
					result.leaf4EBX.ref,
					result.leaf4ECX.ref,
					result.leaf4EDX.ref
				)

				// Check if this is a valid cache level (EAX bit 4:0 > 0)
				var eaxValue = result.leaf4EAX[0]
				if (eaxValue & 0x1Fu32) == 0 {
					break // No more cache levels
				}

				cacheLevel++
			}
		}

		// Get extended topology (leaf 0x0B)
		// Check if leaf 0x0B is supported
		if result.maxStandardFunction[0] >= 0x0000000B {
			cpuid(
				0x0000000B,
				0,
				// TODO expand to separate values
				result.leafBTopologyLevel.ref,
				result.leafBTopologyLevel.ref,
				result.leafBTopologyLevel.ref,
				result.leafBTopologyLevel.ref
			)
		}

		// Calculate display family
		if baseFamily == 0xF {
			result.cpuFamily = baseFamily + extendedFamily
		} else {
			result.cpuFamily = baseFamily
		}

		// Calculate display model
		if baseFamily == 0x6 or baseFamily == 0xF or baseModel == 0xF {
			result.cpuModel = (extendedModel << 4) + baseModel
		} else {
			result.cpuModel = baseModel
		}

		// Extract cache line size and logical processor count from EBX
		var ebxValue = result.standardEBX[0]
		result.cacheLineSize = (ebxValue >> 8) & 0xFFu32
		result.logicalProcessorCount = (ebxValue >> 16) & 0xFFu32
		// Get cache and TLB descriptors (leaf 2)
		// Check if leaf 2 is supported (most CPUs support it)
		if result.maxStandardFunction[0] >= 0x00000002 {
			cpuid(
				0x00000002,
				0,
				result.leaf2EAX.ref,
				result.leaf2EBX.ref,
				result.leaf2ECX.ref,
				result.leaf2EDX.ref
			)
		}

		// Get CPUID leaf 7 features (extended features)
		// Check if leaf 7 is supported
		if result.maxStandardFunction[0] >= 0x00000007 {
			cpuid(
				0x00000007,
				0,
				stub.ref,
				result.leaf7EBX.ref,
				stub.ref,
				stub.ref
			)
		}

		// CPUID leaf 7 feature detection (extended features)
		result.fsgsbaseSupported = 0 != (result.leaf7EBX[0] & (1u32 << 0)) // FSGSBASE (bit 0)
		result.bmi1Supported = 0 != (result.leaf7EBX[0] & (1u32 << 3)) // BMI1 (bit 3)
		result.hleSupported = 0 != (result.leaf7EBX[0] & (1u32 << 4)) // HLE (bit 4)
		result.avx2Supported = 0 != (result.leaf7EBX[0] & (1u32 << 5)) // AVX2 (bit 5)
		result.smepSupported = 0 != (result.leaf7EBX[0] & (1u32 << 7)) // SMEP (bit 7)
		result.bmi2Supported = 0 != (result.leaf7EBX[0] & (1u32 << 8)) // BMI2 (bit 8)
		result.ermsSupported = 0 != (result.leaf7EBX[0] & (1u32 << 9)) // ERMS (bit 9)
		result.invpcidSupported = 0 != (result.leaf7EBX[0] & (1u32 << 10)) // INVPCID (bit 10)
		result.rtmSupported = 0 != (result.leaf7EBX[0] & (1u32 << 11)) // RTM (bit 11)
		result.rdseedSupported = 0 != (result.leaf7EBX[0] & (1u32 << 18)) // RDSEED (bit 18)
		result.shaSupported = 0 != (result.leaf7EBX[0] & (1u32 << 29)) // SHA (bit 29)

		// Get frequency and timing information (leaf 0x15/0x16)
		// Check if leaf 0x15 is supported
		if result.maxStandardFunction[0] >= 0x00000015 {
			cpuid(
				0x00000015,
				0,
				result.leaf15TSC.ref,
				result.leaf15Crystal.ref,
				result.leaf15Nominal.ref,
				stub.ref
			)
		}

		// Check if leaf 0x16 is supported
		if result.maxStandardFunction[0] >= 0x00000016 {
			cpuid(
				0x00000016,
				0,
				result.leaf16BaseMHz.ref,
				result.leaf16MaxMHz.ref,
				result.leaf16BusMHz.ref,
				stub.ref
			)
		}

		// Extended AMD64-specific features (function 0x80000001)
		result.longModeSupported = 0 != (result.extendedEDX[0] & (1u32 << 29)) // Long Mode (bit 29)
		result.oneGbPagesSupported = 0 != (result.extendedEDX[0] & (1u32 << 26)) // 1GB Pages (bit 26)
		result.rdtscpSupported = 0 != (result.extendedEDX[0] & (1u32 << 27)) // RDTSCP (bit 27)

		// AMD-specific features (extendedEDX)
		result.threedNowSupported = 0 != (result.extendedEDX[0] & (1u32 << 31)) // Base 3DNow! (bit 31)
		result.threedNowExtSupported = 0 != (result.extendedEDX[0] & (1u32 << 30)) // 3DNow! Extensions (bit 30)
		result.amdMmxExtSupported = 0 != (result.extendedEDX[0] & (1u32 << 22)) // AMD MMX Extensions (bit 22)
		result.fullThreedNowSupported = result.threedNowSupported and result.threedNowExtSupported and result.amdMmxExtSupported

		// Read CPU temperature via MSR if supported
		if result.msrSupported {
			// MSR 0x19C = IA32_THERM_STATUS for Intel CPUs
			// Bits 22:16 contain temperature reading
			// TODO: Implement MSR reading for temperature
			// For now, set a placeholder value
			result.cpuTemperatureCelsius = 42.0 // Placeholder - implement MSR read
		}

		// Detect performance counter support (CPUID leaf 0x0A)
		if result.maxStandardFunction[0] >= 0x0000000A {
			cpuid(
				0x0000000A,
				0,
				stub.ref,
				result.leafAEBX.ref,
				result.leafAECX.ref,
				result.leafAEDX.ref
			)

			// EBX contains performance counter information
			var ebxValue = result.leafAEBX[0]
			result.performanceCounterCount = ebxValue & 0xFFu32
			result.performanceCounterWidth = (ebxValue >> 8) & 0xFFu32

			// If we got valid counter info, mark as supported
			if result.performanceCounterCount > 0 {
				result.performanceCounterSupported = true
			}
		}

		// Detect invariant TSC support
		// Invariant TSC is supported if TSC is supported and CPU indicates invariance
		result.invariantTscSupported = result.tscSupported
		// TODO: Enhance with MSR 0x10 reads for more precise invariant TSC detection

		// Trim the names
		var i = 0
		let r = '\r'.charCodeAt(0) as! UInt8
		let n = '\n'.charCodeAt(0) as! UInt8

		// TODO Hexa: disallow code like this, allow only `v = i++`
		while i++ < 48 {
			if result.brandName[i] == r {
				result.brandName[i] = 0
			} else if result.brandName[i] == n {
				result.brandName[i] = 0
			}
		}

		i = 0
		while i++ < 13 {
			if result.vendorID[i] == r {
				result.vendorID[i] = 0
			} else if result.vendorID[i] == n {
				result.vendorID[i] = 0
			}
		}

		// return result // TODO Hexa: keep this, remove return below, and make it checked by typer to always return
	}

	return result
}
