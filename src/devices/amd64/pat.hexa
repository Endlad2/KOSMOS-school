@customHeader('
	void pat() {
		uint64_t pat = rdmsr(0x277) & ~(0x7ull << 32);
        pat |= 0x1ull << 32; // set WC mode for PA4
        wrmsr(0x277, pat);
	}
')
@rename('pat')
declare fun pat(
) Void

/// Set PA4 to Write Combine
fun initializePAT(cpuid CPUID) Void {
	if cpuid.patSupported {
		serialPrintf("[AMD64] PAT supported\n")
		pat()
		serialPrintf("[AMD64] PAT initialized\n")
	} else {
		serialPrintf("[AMD64] PAT is not supported\n")
	}
}
