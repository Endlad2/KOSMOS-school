// ACPI 2.0 is required by Tofita
// So we don't need to support ACPI 1.0
// TODO check if more generic table ST.ConfigurationTable viable

// Types

@struct @packed
class AcpiTableHeader {
	var type AcpiTypeId
	var length UInt32
	var revision UInt8
	var checksum UInt8
	var oemId ArrayByValue<UInt8, 6>
	var oemTable ArrayByValue<UInt8, 8>
	var oemRevision UInt32
	var creatorId UInt32
	var creatorRevision UInt32

	fun validate(expectedType AcpiTypeId) Bool {
		return expectedType == type
	}
}

// TODO this is probably useless
fun validate(expectedType AcpiTypeId, type AcpiTypeId) Bool {
	return expectedType == type
}

@struct @packed
class AcpiMcfgEntry {
	var base UInt64
	var group UInt16
	var busStart UInt8
	var busEnd UInt8
	var reserved UInt32
}

// TODO Buffer.from('MCFG') macro
/// little-endian 32-bit values (what the ACPI tables in memory actually contain)
enum AcpiTypeId : UInt32 {
	APIC = 0x43495041u32 // 'APIC' -> 1128878145
	HPET = 0x54455048u32 // 'HPET' -> 1413828680
	TPM2 = 0x324d5054u32 // 'TPM2' ->  843927636
	SSDT = 0x54445353u32 // 'SSDT' -> 1413763923
	MCFG = 0x4746434du32 // 'MCFG' -> 1195787085
	BGRT = 0x54524742u32 // 'BGRT' -> 1414678338

	// Common
	FACP = 0x50434146u32 // 'FACP' (often called FADT) -> 1346584902
	FADT = 0x54444146u32 // 'FADT' -> 1413759302
	XSDT = 0x54445358u32 // 'XSDT' -> 1413763928
	RSDT = 0x54445352u32 // 'RSDT' -> 1413763922
	DSDT = 0x54445344u32 // 'DSDT' -> 1413763908
	FACS = 0x53434146u32 // 'FACS' -> 1398038976
}

@struct @packed
class AcpiMcfg {
	// TODO static let sign = @acpiHeaderSignature 'MCFG'
	var header ByValue<AcpiTableHeader>
	var reserved UInt64
	var entries ArrayByValue<ByValue<AcpiMcfgEntry>, 0>
}

// TODO move to apic.hexa
@struct @packed
class AcpiApic {
	// TODO static let sign = @acpiHeaderSignature 'APIC'
	var header ByValue<AcpiTableHeader>
	var localAddress UInt32
	var flags UInt32
	var controllerData ArrayByValue<UInt8, 0>
}

@struct @packed
class XSDT {
	// TODO static let sign = @acpiHeaderSignature 'XSDT'
	var header ByValue<AcpiTableHeader>
	// TODO ArrayByValueArbitarySized <- otherwise check bounds at ctime where possible
	var headers ArrayByValue<AcpiTableHeader, 0>
}

@struct @packed
class Acpi20 {
	var length UInt32
	var xsdtAddress XSDT
	var checksum UInt8
	var reserved ArrayByValue<UInt8, 3>
}

@struct @packed
class Acpi10 {
	var signature ArrayByValue<UInt8, 8>
	var checksum UInt8
	var oemID ArrayByValue<UInt8, 6>
	var revision UInt8
	var rsdtAddress UInt32
}

@struct @packed
class ACPI {
	var acpi10 ByValue<Acpi10>
	var acpi20 ByValue<Acpi20>
}

// TODO Hexa template
fun acpiTableEntries<T>(t T, size UInt64) UInt64 {
	return 0 // (t.header.length - sizeOf<T>()) / size
}

// Compute APIC controller data bytes count (header.length - sizeof(AcpiApic))
fun acpiTableEntriesApic(t AcpiApic, size UInt64) UInt64 {
	// TODO Hexa: `if (t_2889_->header_ == nullptr) {}` is wrong for `ByValue`

	/*if t.header == null {
		serialPrintf("[ERROR] acpiTableEntriesApic: t.header is null!\n")
		return 0
	}*/
	let sizeofAcpiApic = sizeOf<AcpiApic>()
	let result = (t.header.ref.length - sizeofAcpiApic) / size
	return result
}

fun acpiTableEntriesXSDT(t XSDT, size UInt64) UInt64 {
	return (t.header.ref.length - sizeOf<XSDT>()) / size
}

fun acpiTableEntriesAcpiMcfg(t AcpiMcfg, size UInt64) UInt64 {
	return (t.header.ref.length - sizeOf<AcpiMcfg>()) / size
}

// TODO
fun acpiValidate<T>(t T) Bool {
	// TODO `return t.header.validate(T.typeId)`
	return true
}

fun acpiValidateXSDT(t XSDT) Bool {
	// TODO `return t.header.validate(T.typeId)`
	return true
}

fun putSig(into ArrayPointer<UInt8>, type AcpiTypeId) Void {
	let typeId ArrayByValue<UInt32, 1> = [type as! UInt32]
	let typeRef = typeId.ref as! ArrayPointer<UInt8>
	for j in 4 {
		into[j] = typeRef[j]
	}
}

@inline
fun busAddr(bus UInt8, device UInt8, func UInt8) UInt16 {
	return bus << 8 | device << 3 | func
}

@struct
class PciGroup {
	var group UInt16
	var busStart UInt16
	var busEnd UInt16
	var base ArrayPointer<UInt32>

	fun baseFor(bus UInt8, device UInt8, func UInt8) ArrayPointer<UInt32> {
		return (base as! UInt64 + busAddr(bus, device, func) << 12) as! ArrayPointer<UInt32>
	}

	fun hasDevice(bus UInt8, device UInt8, func UInt8) Bool {
		return (baseFor(bus, device, func)[0] & 0xffff) != 0xffff
	}
}

// TODO move acpiParser.hexa
class ACPIParser {
	static fun parse(acpiVendorTable UInt64, cpuid CPUID, framebuffer FrameBuffer) Bool {
		serialPrint("[ACPI] parsing started at physical ")
		serialPrintHex(acpiVendorTable as! UInt64)
		serialPrint("\n")

		if acpiVendorTable == 0 {
			serialPrintln("[ACPI] not present at all")
			return false
		}

		var acpiTable = physicalToVirtual(acpiVendorTable) as! ACPI

		var acpi10 = acpiTable.acpi10

		serialPrint("[ACPI] signature is '")

		for i in sizeOf<ArrayByValue<UInt8, 8> >() {
			putChar(acpi10.ref.signature[i])
		}

		serialPrint("'\n")

		serialPrintf("[ACPI] revision is %d\n", acpi10.ref.revision)

		if acpi10.ref.revision < 2 {
			serialPrintln("[ACPI] revision is not 2.0, aborting")
			return false
		}

		// TODO Hexa: communicate presence \0 at end of array
		// ^ may assume \0 for `ArrayByValue<Clang[Wide]Char, 9>` also `9 + 0` idea
		// or always assume \0 as in C thus <N+1>, but may do `= @nullTerminated(false) "RSD PTR "`
		// ^ in the code gen it will produce `char s2[3] = {'a','a','a'};`
		var signature ArrayByValue<UInt8, 9> = "RSD PTR "

		// TODO sizeOf accepts 0 args! `for i in sizeOf(acpi10.ref.signature) {`
		for i in sizeOf<ArrayByValue<UInt8, 8> >() {
			if acpi10.ref.signature[i] != signature[i] {
				serialPrintln("[ACPI] RSDP table signature is incorrect")
				return false
			}
		}

		var checksum UInt8 = 0

		for i in sizeOf<Acpi10>() {
			checksum += (acpi10 as! ArrayPointer<UInt8>)[i]
		}

		if checksum != 0 {
			serialPrintln("[ACPI] checksum ACPI 1.0 failed")
			return false
		}

		let acpi20data = acpiTable.acpi20 as! Acpi20
		let acpi20raw = acpi20data as! ArrayPointer<UInt8>
		checksum = 0

		for i in sizeOf<Acpi20>() {
			checksum += (acpi20raw)[i]
		}

		if checksum != 0 {
			serialPrintln("[ACPI] checksum ACPI 2.0 failed")
			return false
		}

		// TODO `Physical.toVirtual()` helper
		var xsdt = (acpiTable.acpi20.ref.xsdtAddress as! UInt64 + wholePhysicalStart) as! XSDT

		loadXsdt(xsdt, cpuid, framebuffer)

		serialPrintln("[ACPI] loaded")
		return true
	}

	static /*TODO private*/ fun physicalToVirtual(physical UInt64) UInt64 {
		var result UInt64 = wholePhysicalStart + (physical as! UInt64)
		return result
	}

	static fun dump32(msg ConstArrayPointer<UInt8>, virtualAddress ConstArrayPointer<UInt8>) {
		serialPrintf("\n[DUMP] %s: ", msg)
		let x = virtualAddress as! ArrayPointer<UInt8>
		let y = virtualAddress as! ArrayPointer<UInt8>

		for j in 8 {
			var buffer ArrayByValue<UInt16, 2> = [0, 0]
			buffer[0] = (y[j] == 0 or y[j] < 32) ? '?'.charCodeAt(0) as! UInt8 : x[j]
			buffer[1] = 0 as! UInt8
			serialPrint(String.fromUTF16z(buffer.ref as! ConstArrayPointer<UInt16>))
		}

		serialPrint("\n")
	}

	static fun loadXsdt(xsdt XSDT, cpuid CPUID, framebuffer FrameBuffer) {
		drawLoadingVerbose("Loading XSDT...", framebuffer)

		if xsdt == null {
			serialPrintln("[ACPI] XSDT is null")
			return
		}

		let valid = acpiValidateXSDT(xsdt)
		serialPrintf("[ACPI] acpiValidate(xsdt) %d\n", valid)

		if not valid {
			serialPrintln("[ACPI] XSDT validation failed")
			return
		}

		var sig ArrayByValue<UInt8, 5> = [0, 0, 0, 0, 0]
		serialPrintf("[ACPI] ACPI 2.0+ tables loading\n")
		putSig(sig.ref, xsdt.header.ref.type)
		serialPrintf("[ACPI] Found table %s\n", sig.ref)
		quakePrintf("[ACPI] Found table %s, ".utf16(), sig.ref)

		let numTables UInt64 = acpiTableEntriesXSDT(xsdt, 8)
		serialPrintf("[ACPI] Entries XSDT %d\n", numTables)

		for i in numTables {
			let header = physicalToVirtual((xsdt.headers[i] as! UInt64)) as! AcpiTableHeader

			putSig(sig.ref, header.type)
			serialPrintf("[ACPI] Found sub-table %s\n", sig.ref)
			quakePrintf("found table %s, ".utf16(), sig.ref)

			// TODO this validation is nonsense
			let valid Bool = header.validate(header.type)
			if not valid {
				serialPrintln("[ACPI] header validation failed")
				continue
			}

			switch header.type {
				case APIC:
					serialPrintf("[ACPI] header.type == APIC\n")
					loadApic(header as! AcpiApic, cpuid, framebuffer)
					// break // TODO breaks `for` not `switch`

				case MCFG:
					serialPrintf("[ACPI] header.type == MCFG\n")
					// TODO crashes loadMcfg(header as! AcpiMcfg, framebuffer)
					// break

				case FADT:
					serialPrintf("[ACPI] header.type == FADT\n")
					// TODO loadFadt(header as! AcpiFadt)
					// break

				case HPET: serialPrintf("[ACPI] header is HPET -> skipping for now\n") // TODO
				case TPM2: serialPrintf("[ACPI] header is TPM2 -> skipping for now\n") // TODO
				case SSDT: serialPrintf("[ACPI] header is SSDT -> skipping for now\n") // TODO
				case BGRT: serialPrintf("[ACPI] header is BGRT -> skipping for now\n") // TODO
				case FACP: serialPrintf("[ACPI] header is FACP -> skipping for now\n") // TODO
				case XSDT: serialPrintf("[ACPI] header is XSDT -> skipping for now\n") // TODO
				case RSDT: serialPrintf("[ACPI] header is RSDT -> skipping for now\n") // TODO
				case DSDT: serialPrintf("[ACPI] header is DSDT -> skipping for now\n") // TODO
				case FACS: serialPrintf("[ACPI] header is FACS -> skipping for now\n") // TODO

				case _:
					serialPrintf("[ACPI] (warning) header.type == UNKNOWN (%d)\n", header.type)
					// break
			}
		}

		quakePrintf("done.\n".utf16())
	}

	// TODO test volatile
	@volatile static var coresAp UInt64 = 1

	/// APs start here after trampoline sets stack, paging, GDT/TSS; init per-core state.
	// Pitfall: Assuming uniform CPU features (e.g., x2APIC support);
	// TODO on heterogeneous HW (rare), check CPUID per-AP.
	// TODO Edge-case: In NUMA, local APIC base may differ per-socket—read from MSR, map per-core if needed;
	// for simple SMP assume shared.
	static fun apStart() {
		// Safety measure
		disableAllInterrupts()

		// Get own CPU index in the OS CPUs array TODO create one
		let core = coresAp + 1
		serialPrintf("[ACPI] apStart(%d)\n", core)

		// TODO seems useless, cause main CPU waits for SIPIs anyway
		// apLock.lock()

		// CPU features
		let cpuid CPUID = getCPUID()
		// TODO IDT
		// TODO GDT
		// NX bit
		enableNX(cpuid)

		// TODO APIC

		// ALL DONE //

		// In case of success we can now report that CPU is usable
		quakePrintf("CPU #%u initialized, ".utf16(), core)
		// Counter is watched in the SMP startup code -> incrementing is a trigger
		coresAp++

		// TODO apLock.unlock()

		// TODO start another AP in chain (if applicable) to speed-up the SMP initialization

		// NOW CAN EXECUTE THREADS AND SYSCALLS //

		// Enable interrupts for timer/IPIs
		// TODO Edge-case: If NMI/SError, handle via IST.
		// TODO enableAllInterrupts()

		while true {
			// TODO execute "thread-safe" syscalls from the event-loop
			halt()
			pause()
		}
	}

	static let smpEnabled Bool = false
	// TODO this should be removed in the future as SMP always required

	// TODO Hexa: `<T>` note: not @volatile by default
	static fun writeToUInt64(address UInt64, value UInt64) Void {
		// TODO Hexa: this does not produce volatile types yet, so using __sync_synchronize here
		__sync_synchronize()
		let at = address as! ArrayPointer<@volatile UInt64>
		at[0] = value
	}

	static fun writeToUInt32(address UInt64, value UInt32) Void {
		__sync_synchronize()
		let at = address as! ArrayPointer<@volatile UInt32>
		at[0] = value
	}

	static fun readFromUInt32(address UInt64) UInt32 {
		__sync_synchronize()
		let at = address as! ArrayPointer<@volatile UInt32>
		return at[0] // TODO as! UInt32
	}

	/// Note: non volatile
	static fun readFromUInt8(address UInt64) UInt8 {
		let at = address as! ArrayPointer<UInt8>
		return at[0] // TODO as! UInt32
	}

	// TODO Hexa: field-vars are taken as static in static functions
	// let ioregsel = 0x00
	static let ioregsel = 0x00
	static let iowin = 0x10
	static let ioredtbl = 0x10u8

	static fun ioApicOut(base UInt64, reg UInt8, val UInt32) Void {
		writeToUInt32(base + ioregsel, reg)
		writeToUInt32(base + iowin, val)
	}

	static fun ioApicIn(base UInt64, reg UInt8) UInt32 {
		writeToUInt32(base + ioregsel, reg)
		return readFromUInt32(base + iowin)
	}

	static fun ioApicSetEntry(base UInt64, index UInt8, data UInt64) Void {
		ioApicOut(base, ioredtbl + index * 2u8, data as! UInt32)
		ioApicOut(base, ioredtbl + index * 2 + 1u8, (data >> 32) as! UInt32)
	}

	static fun delayMicroseconds(mcs Int) Void {
		// One `pause` is 10+ cycles, assuming 4 Ghz CPU
		// TODO better idea (rdtscTicks)
		let dosensOfCycles = mcs * 400
		for i in dosensOfCycles {
			pause()
		}
	}

	static fun delayMilliseconds(ms Int) Void {
		delayMicroseconds(ms * 1000)
	}

	static fun loadApic(apic AcpiApic, cpuid CPUID, framebuffer FrameBuffer) {
		drawLoadingVerbose("Loading APIC...", framebuffer)

		serialPrintf("[ACPI] loadApic begin SMP\n")
		// TODO Delay between IPI-SIPI + disable PIC
		// TODO Hexa: ensure `if not boolean` generates `!= true_` instead of `c-style != 0` cause null-bool is `2`
		// ^ Normalizer.ToPlainBoolean (non-nullable Bool)
		if not smpEnabled {
			// TODO extract SMP init to smp.hexa
			serialPrintf("[ACPI] skipping: SMP is not enabled for this release\n")
			return
		}

		disableAllInterrupts()

		// x2APIC is supported
		let x2 Bool = cpuid.x2apicSupported

		let apic_base_flag = 0xFFFFF000u32
		let apic_enable_flag = 0x800u32
		let apic_x2apic_enable_flag = 0x400u32

		let ia32_apic_base = 27u64 // aka 0x1B
		// Turns the Local APIC on
		if x2 {
			// Enable x2APIC mode (bit 10 and 11)
			drawLoadingVerbose("Enable x2APIC...", framebuffer)
			wrmsr(ia32_apic_base, (apic.localAddress & apic_base_flag) | apic_enable_flag | apic_x2apic_enable_flag)
		} else {
			// Enable xAPIC mode
			drawLoadingVerbose("Enable xAPIC...", framebuffer)
			wrmsr(ia32_apic_base, (apic.localAddress & apic_base_flag) | apic_enable_flag)
		}

		// TODO define this in globals + rethink
		let offsetGigabytes = 32u64
		let virtualLocalApic = wholePhysicalStart + (offsetGigabytes * 1024u64 * 1024u64 * 1024u64)
		let physicalLocalApic = apic.localAddress

		fun localApicOut(reg UInt64, data UInt32, virtualLocalApic UInt64) Void {
			// TODO Hexa: volatile types cannot be assigned
			// TODO Hexa: code gen
			// let at = (virtualLocalApic + reg) as! ArrayPointer<@volatile UInt32>
			// at[0] = data
			writeToUInt32(virtualLocalApic + reg, data)
		}

		// TODO Hexa: optimize to `fun`: `let localApicIn = (reg UInt64) => {`
		// TODO Hexa: disable (arg TYPE_THIS_THING) for arrow fun-s, let use `fun` when non-inferrable
		fun localApicIn(reg UInt64, virtualLocalApic UInt64) UInt32 {
			// TODO return readFrom<ArrayPointer<@volatile UInt32>>(virtualLocalApic + reg)
			// let at = (virtualLocalApic + reg) as! ArrayPointer<@volatile UInt32>
			// return at[0]
			return readFromUInt32(virtualLocalApic + reg)
		}

		let lapic_tpr = 0x0080u64 // Task Priority
		let lapic_dfr = 0x00e0u64 // Destination Format
		let lapic_ldr = 0x00d0u64 // Logical Destination
		let lapic_svr = 0x00f0u64 // Spurious Interrupt Vector

		drawLoadingVerbose("Enable LAPIC...", framebuffer)

		// TODO is 1 page enough?
		mapMemory(pml4entries, virtualLocalApic, physicalLocalApic, 1)

		localApicOut(lapic_tpr, 0, virtualLocalApic) // Clear task priority to enable all interrupts
		localApicOut(lapic_dfr, 0xffffffffu32, virtualLocalApic) // Flat mode
		localApicOut(lapic_ldr, 0x01000000, virtualLocalApic) // All CPUs use logical id 1
		localApicOut(lapic_svr, 0x100u32 | 0xff, virtualLocalApic) // Configure Spurious Interrupt Vector Register

		// TODO FORMAT
		// let virtualIoApic = wholePhysicalStart + ((uint64_t) 33 *(uint64_t) 1024 *(uint64_t) 1024 *(uint64_t) 1024)
		let virtualIoApic = wholePhysicalStart + (33u64 * 1024u64 * 1024u64 * 1024u64)
		var physicalIoApic = 0u64

		let count = acpiTableEntriesApic(apic, 1)
		var data ArrayPointer<UInt8> = apic.controllerData.ref
		let end = data.offsetItems(count)

		while data.address < end.address {
			let type = data[0] as! ApicType
			let length = data[1]
			switch type {
				case APIC_TYPE_IO_APIC:
					let apicData = data as! ApicIoApic
					serialPrintf("[ACPI] Found I/O APIC: id=%d addr=%8 base=%d\n", apicData.ioApicId, apicData.ioApicAddress, apicData.globalSystemInterruptBase)
					let ioApicAddress = apicData.ioApicAddress

					if physicalIoApic != 0 and physicalIoApic != ioApicAddress {
						serialPrintf("[ACPI] multiple IO APICs found, overriding\n")
						// TODO NUMA/dual-socket only?
					}

					physicalIoApic = ioApicAddress
			}

			data = data.offsetItems(length)
		}

		drawLoadingVerbose("Enable IO APIC...", framebuffer)

		// Map memory, 1 page
		// TODO supposedly may be not enoungh for some HW?
		mapMemory(pml4entries, virtualIoApic, physicalIoApic, 1)

		// MMIO register select register that is used to access all the other I/O APIC registers
		let ioregsel = 0x00
		// MMIO register window
		let iowin = 0x10

		// TODO move elsewhere or turn into enum + give descriptions
		// IO APIC registers
		let ioapicid = 0x00
		let ioapicver = 0x01u8
		let ioapicarb = 0x02
		let ioredtbl = 0x10u8

		// TODO Hexa
		fun ioApicOut_TODO(base UInt64, reg UInt8, val UInt32) Void {
			writeToUInt32(base + ioregsel, reg)
			writeToUInt32(base + iowin, val)
		}

		// TODO use `enum` for `reg` instead of just number
		fun ioApicIn_TODO(base UInt64, reg UInt8) UInt32 {
			writeToUInt32(base + ioregsel, reg)
			return readFromUInt32(base + iowin)
		}

		fun ioApicSetEntry_TODO(base UInt64, index UInt8, data UInt64) Void {
			ioApicOut(base, ioredtbl + index * 2u8, data as! UInt32)
			ioApicOut(base, ioredtbl + index * 2 + 1u8, (data >> 32) as! UInt32)
		}

		fun ioApicInit(virtualIoApic UInt64) Void {
			// How many entries supports the I/O APIC
			let ver = ioApicIn(virtualIoApic, ioapicver)
			let count = ((ver >> 16u32) & 0xffu8) + 1u8

			serialPrintf("[ACPI] I/O APIC pin count = %d\n", count)

			for i in count { // Disable all entries TODO purpose
				ioApicSetEntry(virtualIoApic, i, 1u64 << 16)
			}
		}

		ioApicInit(virtualIoApic)

		fun acpiRemapIrq(irq UInt32, apic AcpiApic) UInt32 {
			let count = acpiTableEntriesApic(apic, 1)
			var data ArrayPointer<UInt8> = apic.controllerData.ref
			// TODO Hexa: produces UInt64 `let end = data + count`
			let end = data.offsetItems(count)

			while data.address < end.address {
				let type = data[0] as! ApicType
				let length = data[1]

				switch type {
					case APIC_TYPE_INTERRUPT_OVERRIDE:
						let interruptData = data as! ApicInterruptOverride
						if interruptData.source == irq {
							return interruptData.interrupt
						}
				}

				data = data.offsetItems(length)
			}

			return irq
		}

		// Set IO APIC entries
		// TODO
		let int_timer = 0x20u64
		let irq_timer = 0x00u32
		ioApicSetEntry(virtualIoApic, acpiRemapIrq(irq_timer, apic) as! UInt8, int_timer)

		let lapic_eoi = 0x00b0u64 // End of Interrupt
		localApicOut(lapic_eoi, 0, virtualLocalApic)
		serialPrintf("[ACPI] I/O APIC initialized\n")


		// SMP goes here //
		drawLoadingVerbose("Enable SMP...", framebuffer)

		// TODO extract to separate function
		// We will fill trapeze arguments dynamically by updating it's binary directly
		let trapezeIdenityAddress = 0x8000u64
		let trapeze = trapezeIdenityAddress + wholePhysicalStart
		// TODO trapeze is copied in tofita.hexa but this is better do here?
		let trapezePhysical = trapeze - wholePhysicalStart
		// TODO make it clear what is happening
		mapMemory(pml4entries, virtualAddr: trapeze, physicalAddr: trapezePhysical, pageCount: 1)
		// TODO make it clear why `- 4096u64`
		mapMemory(pml4entries, virtualAddr: trapezeIdenityAddress - 4096u64, physicalAddr: trapezeIdenityAddress - 4096u64, pageCount: 16)
		// TODO unmap later

		// TODO Unused `ready`
		let ready = trapeze + 8
		let cpu_id = ready + 8
		let page_table = cpu_id + 8

		let stack_start = page_table + 8
		let stack_end = stack_start + 8
		let code = stack_end + 8

		let pml4 = code + 8

		var data = apic.controllerData.ref
		let count = acpiTableEntriesApic(apic, 1)
		let end = data.offsetItems(count)
		let bsp = 0 // TODO Get from LAPIC MSR?

		// Iterate over "CPUs"
		while data.address < end.address {
			let type = data[0]
			let length = data[1]

			// Skip BSP
			let position = data as! UInt64
			let cpuid = readFromUInt8(position + 2)

			if bsp == cpuid {
				serialPrintf("[ACPI] BSP skip\n")
				// TODO turn into `@defer/defer` because it just loops forever lmao
				data = data.offsetItems(length)
				continue
			}

			let flags = readFromUInt8(position + 4)

			// TODO applicable to x2 or wrap into condition?
			// The core is disabled (absent, failed, or turned off in firmware)
			if (flags & 0x1) == 0 {
				// TODO break // TODO Hexa
				serialPrintf("[ACPI] Inactive AP skip\n")
				// TODO turn into `@defer/defer` because it just loops forever lmao
				data = data.offsetItems(length)
				continue
				// TODO there's known extra condition, that still allows to activate the core
				// ^ when flags bit 0 == 0 then check bit 1, if its 1 then activate
			}

			switch type {
				// TODO enum
				case 0:
					let lapicid = readFromUInt8(position + 3)

					if bsp == cpuid {
						// TODO break // TODO Hexa doc how to break early (to func) haxe break for?
						// TODO idea: break does break from `case` when in `switch`, not outer loops
						// ^ error when `break` is not within `if`
					}

					if (flags & 0x1) == 0 {
						// TODO break // TODO Hexa
					}

					// Allocate per-core stack
					// TODO decide on stack size (global var) + space for grow
					let _stack_start = PhysicalAllocator.allocatePages(64)
					let _stack_end = stack_start + 64 * 4096

					// TODO ensure PML4 & GDT within 4G or even 2G (Int32)
					let pml4 = (pml4entries as! UInt64) - wholePhysicalStart

					// Fill trapeze arguments via in-memory patch
					writeToUInt64(ready, pml4)
					writeToUInt64(cpu_id, cpuid)
					writeToUInt32(page_table, ((pml4entries as! UInt64) - wholePhysicalStart) as! UInt32)
					// TODO &globalGdtr
					let gtdAt = ((globalGdtr as! UInt64) - wholePhysicalStart) as! UInt32
					// TODO is UInt32 is really enough here?
					writeToUInt32(page_table + 4, gtdAt)
					writeToUInt64(stack_start, _stack_start)
					writeToUInt64(stack_end, _stack_end)
					// TODO `.meta.address`
					writeToUInt64(code, apStart as! UInt64)

					__sync_synchronize()
					// TODO disableAllInterrupts()?

					// Send INIT IPI
					drawLoadingVerbose("Send INIT SMP...", framebuffer)

					let icr = 0x4500
					if x2 {
						// TODO
					} else {
						let lapic_icrhi = 0x0310u64 // Interrupt Command [63:32]
						let icr_destination_shift = 24u32
						let lapic_icrlo = 0x0300u64 // Interrupt Command
						let icr_init = 0x00000500u32
						let icr_physical = 0x00000000u32
						let icr_assert = 0x00004000u32
						let icr_edge = 0x00000000u32
						let icr_no_shorthand = 0x00000000u32
						let icr_send_pending = 0x00001000u32

						let apic_id = lapicid
						localApicOut(lapic_icrhi, apic_id << icr_destination_shift, virtualLocalApic)
						localApicOut(lapic_icrlo, icr_init | icr_physical | icr_assert | icr_edge | icr_no_shorthand, virtualLocalApic)

						while (localApicIn(lapic_icrlo, virtualLocalApic) & icr_send_pending) != 0 {
							pause()
						}

						// Recommended 10ms delay TODO mega slow on QEMU
						delayMilliseconds(10)
					}

					let currentCoresAp = coresAp

					let trampoline = 0x8000u64
					let ap_segment = (trampoline >> 12u64) & 0xFFu64
					var icr = 0x4600u64 | ap_segment

					// Send START IPI (SIPI)
					drawLoadingVerbose("Send SIPI SMP...", framebuffer)

					if x2 {
						// TODO
					} else {
						// icr |= (cpuid << 56u64)
						// NOTE not cpu id
						icr |= ((lapicid as! UInt64) << 56u64)

						// TODO Hexa: precedence
						// while localApicIn(0x300u64, virtualLocalApic) & 1u32 << 12u32 == 1u32 << 12u32 {
						let done = 1u32 << 12u32
						while (localApicIn(0x300u64, virtualLocalApic) & done) == done {
							pause()
						}

						// Send first STARTUP IPI (SIPI)
						// ICR High: Destination
						localApicOut(0x310, (icr >> 32u64) as! UInt32, virtualLocalApic)
						// ICR Low: SIPI command
						localApicOut(0x300, icr as! UInt32, virtualLocalApic)

						// TODO Hexa: precedence
						// while localApicIn(0x300u64, virtualLocalApic) & 1u32 << 12u32 == 1u32 << 12u32 {
						while (localApicIn(0x300u64, virtualLocalApic) & done) == done {
							// Wait for send to complete
							pause()
						}

						// Recommended 200us delay TODO proper value if needed
						// + check if delay needed for this CPU model
						delayMicroseconds(200)

						// Send second STARTUP IPI (SIPI)
						let apic_id = lapicid
						let vector = icr
						let icr_startup = 0x00000600 // TODO

						// ICR High: Destination (same as before)
						localApicOut(0x310, (vector >> 32u64) as! UInt32, virtualLocalApic)
						// ICR Low: SIPI again
						localApicOut(0x300, vector as! UInt32, virtualLocalApic)

						while (localApicIn(0x300u64, virtualLocalApic) & done) == done {
							pause()
						}
					}

					drawLoadingVerbose("Waiting for SMP AP...", framebuffer)
					// TODO `[ERROR] SMP hardware failure [ERROR]`
					while currentCoresAp == coresAp {
						__sync_synchronize()
						pause()
					}
				case 2: // TODO Interrupt source override
				case 4: // TODO LAPIC NMI
				case _: // TODO
					serialPrintf("[ACPI] Unrecognized APIC type %d\n", type)
			}

			data = data.offsetItems(length)
		}

		serialPrintf("[ACPI] loadApic done\n")
	}

	static fun loadMcfg(mcfg AcpiMcfg, framebuffer FrameBuffer) {
		drawLoadingVerbose("Loading MCFG...", framebuffer)
		serialPrintf("[ACPI] loadMcfg\n")
		var count UInt64 = acpiTableEntriesAcpiMcfg(mcfg, sizeOf<AcpiMcfgEntry>()) // TODO sizeOf must error
		var mPci [PciGroup] = []

		for i in count {
			let mcfge = mcfg.entries[i].ref

			mPci[i].group = mcfge.group
			mPci[i].busStart = mcfge.busStart
			mPci[i].busEnd = mcfge.busEnd
			mPci[i].base = (mcfge.base) as! ArrayPointer<UInt32>

			var busses Int32 = mPci[i].busEnd - mPci[i].busStart + 1
		}

		probePci(mPci, count)
	}

	static fun multi(group PciGroup, bus UInt8, device UInt8, func UInt8) Bool {
		// TODO ^ proper name
		var mBase ArrayPointer<UInt32> = group.baseFor(bus, device, func)
		var mMulti = ((mBase[3] >> 16) & 0x80) == 0x80
		return mMulti
		// TODO ^ proper name
	}

	static fun probePci(mPci [PciGroup], count UInt64) {
		serialPrintf("[PCI] probePci\n")
		for i in count {
			var pci = mPci[i]
			for bus in pci.busStart ... pci.busEnd + 1 {
				for dev in 32 {
					// TODO
				}
			}
		}
	}
}

