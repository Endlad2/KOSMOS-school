// TODO Hexa: __cdecl on function types
declare PVFV = () => Void

@customHeader('
	typedef void (__cdecl *_PVFV)(void);
	void __cdecl callbackCaller_(void* callback) {
		((_PVFV)callback)();
	};
')
declare fun callbackCaller(callback PVFV) Void

#if bit32
	@convention('cdecl')
#end
@dllExport('_initterm')
fun _initterm(first ConstArrayPointer<PVFV>, last ConstArrayPointer<PVFV>) Void {
	// TODO
	kkernelDebugLog("_initterm(%8, %8)".utf16(), first as! UInt64, last as! UInt64)

	var current = first

	while current.address != last.address {
		let callback = current[0]
		kkernelDebugLog("_initterm checks (%8) at %8".utf16(), callback as! UInt64, current as! UInt64)
		current = current.offsetItems(1)

		if callback == null { continue }

		kkernelDebugLog("_initterm calls (%8)".utf16(), callback as! UInt64)
		#if bit64
			callback()
		#end

		#if bit32
			callbackCaller(callback)
		#end
		kkernelDebugLog("_initterm done call (%8)".utf16(), callback as! UInt64)
	}

	kkernelDebugLog("_initterm all done".utf16())
}

