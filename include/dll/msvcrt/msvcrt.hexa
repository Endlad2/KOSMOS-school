@struct @packed
class Malloc128 {
	var payload ArrayByValue<UInt8, 128> = [0]

	// TODO Hexa: allow to be constructible by default
	new () { }
}

@struct @packed
class Malloc4096 {
	var payload ArrayByValue<UInt8, 4096> = [0]

	// TODO Hexa: allow to be constructible by default
	new () { }
}

#if bit32
	@convention('cdecl')
#end
@rename('malloc')
@dllExport('malloc')
fun malloc(size SizeOfPointer) SizeOfPointer {
	// TODO 16 bytes min + HeapAlloc?
	// kkernelDebugLog("[msvcrt] malloc called with size %u".utf16(), size as! UInt32)

	// TODO Hexa: if size >= 128 {
	if (size as! UInt32) >= 128u32 {
		// kkernelDebugLog("[msvcrt] malloc >= 128".utf16())

		var stub = Malloc4096()
		// kkernelDebugLog("[msvcrt] malloc done allocation %8".utf16(), stub as! UInt64)
		return stub as! SizeOfPointer
	}

	// TODO use HeapAlloc
	var stub = Malloc128()
	// kkernelDebugLog("[msvcrt] malloc done allocation %8".utf16(), stub as! UInt64)
	return stub as! SizeOfPointer
}

@dllExport('memmove')
fun memmove(dest ConstArrayPointer<UInt8>, src ConstArrayPointer<UInt8>, count SizeOfPointer) SizeOfPointer {
	// TODO
	kkernelDebugLog("memmove()\n".utf16())
	return memcpy(dest, src, count)
}

@dllExport('memcpy')
fun memcpy(dest ConstArrayPointer<UInt8>, src ConstArrayPointer<UInt8>, count SizeOfPointer) SizeOfPointer {
	// TODO
	kkernelDebugLog("memcpy()\n".utf16())
	return dest as! SizeOfPointer
}

