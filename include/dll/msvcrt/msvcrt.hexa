// TODO use `meta.pointer` + rename to `wideCommandLine`
@rename('(wchar_t *)&_wcmdln_') declare let wcmdlnPointer ArrayPointer<ClangWideChar>
#if bit32
	@convention('cdecl')
#end
@dllExport('__wgetmainargs')
fun __wgetmainargs(
	/// Pointer to int for argument count
	argc ArrayPointer<Int32>,
	/// Pointer to `char**` for argument vector
	argv ArrayPointer<ArrayPointer<ClangWideChar>>,
	/// Pointer to `char**` for environment variables
	envp ArrayPointer<ArrayPointer<ClangWideChar>>,
	/// Flag for wildcard expansion
	doWildcards Int32,
	/// Pointer to startup info structure
	startupInfo SizeOfPointer
) Int32 {
	// TODO
	kkernelDebugLog("__wgetmainargs called with argc %8 argv %8".utf16(),
		argc as! UInt64, argv as! UInt64)
	argc[0] = 1
	argv[0] = wcmdlnPointer
	envp[0] = wcmdlnPointer
	return 0
}

