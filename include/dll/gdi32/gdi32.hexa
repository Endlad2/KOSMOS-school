@dllExport('GetStockObject')
fun getStockObject(index Int) Handle? {
	// TODO cache
	kkernelDebugLog("getStockObject called with index %d".utf16(), index as! UInt64)

	let white_brush = 0
	if index == white_brush {
		kkernelDebugLog("> Creating white brush".utf16())
		let brush = @heap new Brush()
		brush.pattern = null
		brush.color = 0x00FFFFFFu32
		return brush as! HBrush
	}

	let gray_brush = 2
	if index == gray_brush {
		kkernelDebugLog("> Creating gray brush".utf16())
		let brush = @heap new Brush()
		brush.pattern = null
		brush.color = 0x00D0D0D0u32 // TODO 192
		return brush as! HBrush
	}

	let black_pen = 7
	if index == black_pen {
		kkernelDebugLog("> Creating black pen".utf16())
		let pen = @heap new Pen()
		pen.style = 0
		pen.width = 0
		pen.color = 0
		return pen as! HPen
	}

	let ltgray_brush = 1
	if index == ltgray_brush {
		kkernelDebugLog("> Creating LTGRAY brush".utf16())
		let brush = @heap new Brush()
		brush.pattern = null
		brush.color = 0x00C0C0C0u32
		return brush as! HBrush
	}

	kkernelDebugLog("> Invalid index %d".utf16(), index as! UInt64)
	return null
}

