// Entry point of the project
@customHeader('
	#define HEXA_NEW(z) HeapAlloc(0,0,z)

	void *tmemcpy(void *dest, const void *src, size_t count) {
		// Handle edge cases
		if (count == 0 || dest == src) {
			return dest;
		}

		uint8_t *dst = (uint8_t *)dest;
		const uint8_t *src8 = (const uint8_t *)src;

	#ifdef bit64
		// Align destination to 16-byte boundary for SIMD
		while (((uintptr_t)dst & 15) && count) {
			*dst++ = *src8++;
			count--;
		}

		// Use 64-bit copies for unaligned or non-SIMD cases
		if (count >= 8 && !((uintptr_t)src8 & 7)) {
			uint64_t* dst64 = (uint64_t*)dst;
			const uint64_t* src64 = (const uint64_t*)src8;
			while (count >= 8) {
				*dst64++ = *src64++;
				count -= 8;
			}
			dst = (uint8_t*)dst64;
			src8 = (const uint8_t*)src64;
		}

		// Use SSE2 for large, aligned blocks
		/*if (count >= 16) {
			__m128i* dst128 = (__m128i*)dst;
			const __m128i* src128 = (const __m128i*)src8;
			while (count >= 16) {
				_mm_store_si128(dst128++, _mm_loadu_si128(src128++));
				count -= 16;
			}
			dst = (uint8_t*)dst128;
			src8 = (const uint8_t*)src128;
		}*/
	#endif

		// Copy remaining bytes
		while (count--) {
			*dst++ = *src8++;
		}

		return dest;
	}
	// TODO
	#define memcpy(z,u,x) tmemcpy(z,u,x)
	#define malloc(z) HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, z)

	// TODO move to Hexa .dll
	void __cdecl __chkstk(size_t probeBytes) asm("__chkstk");
	void __cdecl __chkstk(size_t probeBytes) {
		// kkernelDebugLog_(L"__chkstk called", 0, 0);
	}

	#define wprintf(z,...) {}
	#define HEAP_ZERO_MEMORY 0
	#define fflush(z) {}
	#define stdout ((void*)0)
	#define GetProcessHeap() 0

	int64_t _fltused = 0;

	#ifdef bit64
	// 64-bit
	void* __cdecl memset(void *dest, int val, size_t count) asm("_memset");
	__attribute__((no_builtin("memset"))) void* __cdecl memset(void *dest, int val, size_t count) {
		kkernelDebugLog_(L"userMain _memset called %8 %d", (uint64_t)((int32_t)dest), (uint64_t)((int32_t)count));
		for (size_t i = 0; i < count; i++) {
			((uint8_t *)dest)[i] = val;
		}
		return dest;
	} // TODO use crt/ntdll imports
	#else
	// 32-bit
	int64_t __stdcall __alldiv(int64_t dividend, int64_t divisor) asm("__alldiv");
	int64_t __stdcall __allrem(int64_t dividend, int64_t divisor) asm("__allrem");
	uint64_t __stdcall __aulldiv(uint64_t dividend, uint64_t divisor) asm("__aulldiv");
	uint64_t __stdcall __aullrem(uint64_t dividend, uint64_t divisor) asm("__aullrem");

	#define LLONG_MIN   -9223372036854775808LL
	#define LLONG_MAX    9223372036854775807LL

	int64_t __stdcall __alldiv(int64_t dividend, int64_t divisor) {
		kkernelDebugLog_(L"__alldiv called", 0, 0);
		bool result_is_negative = false; // Flag to determine the sign of the final result
		uint64_t u_dividend;             // Unsigned absolute value of dividend
		uint64_t u_divisor;              // Unsigned absolute value of divisor
		uint64_t u_quotient;             // Unsigned quotient from the core division

		// --- Edge Case Handling ---

		// 1. Handle division by zero. This is undefined behavior.
		//    We return LLONG_MAX or LLONG_MIN based on the dividends sign,
		//    mimicking typical CPU behavior (e.g., for integer overflow/exceptions).
		if (divisor == 0) {
			if (dividend >= 0) {
				return LLONG_MAX;
			} else {
				return LLONG_MIN;
			}
		}

		// --- Determine Result Sign ---

		// The result is negative if exactly one of the operands is negative.
		if ((dividend < 0 && divisor > 0) || (dividend > 0 && divisor < 0)) {
			result_is_negative = true;
		}

		// --- Convert to Absolute Unsigned Values ---

		// Convert dividend to its absolute unsigned value.
		// Special handling for LLONG_MIN (0x8000000000000000LL) is required
		// because its absolute value (0x8000000000000000ULL) cannot be represented
		// as a positive int64_t and negating it directly would overflow.
		if (dividend == LLONG_MIN) {
			u_dividend = 0x8000000000000000ULL; // Represents (uint64_t)(-LLONG_MIN)
		} else {
			u_dividend = (uint64_t)(dividend < 0 ? -dividend : dividend);
		}

		// Convert divisor to its absolute unsigned value, with similar LLONG_MIN handling.
		if (divisor == LLONG_MIN) {
			u_divisor = 0x8000000000000000ULL; // Represents (uint64_t)(-LLONG_MIN)
		} else {
			u_divisor = (uint64_t)(divisor < 0 ? -divisor : divisor);
		}

		// --- Perform Unsigned Division ---

		// Use the __aulldiv function for the core unsigned division.
		u_quotient = __aulldiv(u_dividend, u_divisor);

		// --- Apply Result Sign ---

		// Apply the determined sign to the unsigned quotient.
		if (result_is_negative) {
			// Special case: If the unsigned quotient is 0x8000000000000000ULL
			// (which is LLONG_MIN when interpreted as signed) and the result
			// should be negative, it means the true mathematical result (e.g.,
			// -LLONG_MIN) would overflow int64_t. This typically happens for
			// LLONG_MIN / 1. In such cases, MSVC intrinsics commonly return LLONG_MIN.
			if (u_quotient == 0x8000000000000000ULL) {
				return LLONG_MIN; // Return LLONG_MIN for overflow cases
			}
			return -(int64_t)u_quotient;
		} else {
			return (int64_t)u_quotient;
		}
	}

	int64_t __stdcall __allrem(int64_t dividend, int64_t divisor) {
		kkernelDebugLog_(L"__allrem called", 0, 0);
		uint64_t u_dividend;    // Unsigned absolute value of dividend
		uint64_t u_divisor;     // Unsigned absolute value of divisor
		uint64_t u_remainder;   // Unsigned remainder from the core operation

		// --- Edge Case Handling ---

		// 1. Handle division by zero. This is undefined behavior.
		//    Consistent with __aulldiv and __aullrem, we return the maximum
		//    unsigned value as an error sentinel.
		if (divisor == 0) {
			return 0xFFFFFFFFFFFFFFFFULL;
		}

		// --- Convert to Absolute Unsigned Values ---

		// Convert dividend to its absolute unsigned value, with LLONG_MIN handling.
		if (dividend == LLONG_MIN) {
			u_dividend = 0x8000000000000000ULL;
		} else {
			u_dividend = (uint64_t)(dividend < 0 ? -dividend : dividend);
		}

		// Convert divisor to its absolute unsigned value, with LLONG_MIN handling.
		if (divisor == LLONG_MIN) {
			u_divisor = 0x8000000000000000ULL;
		} else {
			u_divisor = (uint64_t)(divisor < 0 ? -divisor : divisor);
		}

		// --- Perform Unsigned Remainder ---

		// Use the __aullrem function for the core unsigned remainder calculation.
		u_remainder = __aullrem(u_dividend, u_divisor);

		// --- Apply Result Sign ---

		// The sign of the remainder is always the same as the sign of the dividend
		// according to the C standard.
		if (dividend < 0) {
			return -(int64_t)u_remainder;
		} else {
			return (int64_t)u_remainder;
		}
	}

	uint64_t __stdcall __aulldiv(uint64_t dividend, uint64_t divisor) {
		kkernelDebugLog_(L"__aulldiv called %d / %d", dividend, divisor);

		// --- Edge Case Handling ---

		// 1. Division by zero is undefined behavior. The processor would normally
		//    raise an exception. We return the maximum possible value, a common
		//    convention for indicating such an error from software.
		if (divisor == 0) {
			// TODO throw if needed
			return 0xFFFFFFFFFFFFFFFFULL;
		}

		// 2. If the divisor is larger than the dividend, the result is always 0.
		if (divisor > dividend) {
			return 0;
		}

		// 3. Division by 1 is a no-op; the result is the dividend.
		if (divisor == 1) {
			return dividend;
		}

		// --- Binary Long Division Algorithm ---

		uint64_t quotient = 0;
		uint64_t remainder = 0;
		int i;

		// Iterate through each bit of the dividend from most significant to least.
		for (i = 63; i >= 0; i--) {
			// Shift the current remainder left by 1 bit to make room for the next bit.
			remainder <<= 1;

			// "Bring down" the next bit from the dividend and set it as the
			// least significant bit of the remainder.
			if ((dividend >> i) & 1) {
				remainder |= 1;
			}

			// If the remainder is now greater than or equal to the divisor,
			// a subtraction is possible.
			if (remainder >= divisor) {
				// Subtract the divisor from the remainder.
				remainder -= divisor;

				// Set the corresponding bit in the quotient to 1, signifying a
				// successful subtraction for this bit position.
				quotient |= (1ULL << i);
			}
		}

		kkernelDebugLog_(L"__aulldiv result %d", quotient, 0);
		return quotient;
	}

	uint64_t __stdcall __aullrem(uint64_t dividend, uint64_t divisor) {
		kkernelDebugLog_(L"__aullrem called %d / %d", dividend, divisor);

		// --- Edge Case Handling ---

		// 1. Division by zero is undefined behavior. Consistent with __aulldiv,
		//    we return the maximum possible unsigned value as an error sentinel.
		if (divisor == 0) {
			return 0xFFFFFFFFFFFFFFFFULL;
		}

		// 2. If the divisor is larger than the dividend, the remainder is the dividend itself.
		if (divisor > dividend) {
			return dividend;
		}

		// 3. Division by 1 always leaves a remainder of 0.
		if (divisor == 1) {
			return 0;
		}

		// --- Binary Long Division Algorithm (focused on remainder) ---

		uint64_t remainder = 0;
		int i; // Loop counter for bits

		// Iterate through each bit of the dividend from most significant (63) to least (0).
		for (i = 63; i >= 0; i--) {
			// Shift the current remainder left by 1 bit to make room for the next bit
			// from the dividend.
			remainder <<= 1;

			// "Bring down" the next bit from the dividend.
			if ((dividend >> i) & 1) {
				remainder |= 1;
			}

			// If the remainder is now greater than or equal to the divisor,
			// a subtraction is possible.
			if (remainder >= divisor) {
				// Subtract the divisor from the remainder.
				remainder -= divisor;
				// For remainder calculation, we dont need to update a quotient.
			}
		}

		kkernelDebugLog_(L"__aullrem result %d", remainder, 0);
		return remainder;
	}

	void* __cdecl memset(void *dest, int val, size_t count) asm("_memset");
	__attribute__((no_builtin("memset"))) void* __cdecl memset(void *dest, int val, size_t count) {
		kkernelDebugLog_(L"userMain _memset called %8 %d", (uint64_t)((int32_t)dest), (uint64_t)((int32_t)count));
		for (size_t i = 0; i < count; i++) {
			((uint8_t *)dest)[i] = val;
		}
		return dest;
	} // TODO use crt/ntdll imports

	// TODO @attribute and @attributeAtDefinition
	// TODO try those at Tofita: i.e. use built-ins despite freestanding, so clang uses and optimizes them

	void* __cdecl _memcpy(void *dest, const void *src, size_t count) asm("_memcpy");
	__attribute__((no_builtin("memcpy"))) void* __cdecl _memcpy(void *dest, const void *src, size_t count) {
		kkernelDebugLog_(L"userMain _memcpy called %8 %8", (uint64_t)((int32_t)dest), (uint64_t)((int32_t)src));
		for (size_t i = 0; i < count; i++) {
			((uint8_t *)dest)[i] = ((uint8_t *)src)[i];
		}
		return dest;
	} // TODO
	#endif

	void startup() {
		HEXA_MAIN(0, nullptr);
	}

	#ifdef bit64 // TODO rename to x64 x32
	// TODO why separate fun? same arguments?
	__attribute__((fastcall)) void _DllMainCRTStartup() {
		startup();
	}
	#else
	__attribute__((stdcall)) void _DllMainCRTStartup(void *, void *, void *) {
		startup();
	}
	#endif
')
declare fun entry() Void

// TODO move those things
enum ButtonStyles : Int {
	// TODO Hexa: make it possible to use constants as tags like `BS_PUSHBUTTON = push_button`
	BS_PUSH_BUTTON = 0x00000000
	BS_DEF_PUSH_BUTTON = 0x00000001
	BS_CHECK_BOX = 0x00000002
	BS_AUTO_CHECK_BOX = 0x00000003
	BS_RADIO_BUTTON = 0x00000004
	BS_3STATE = 0x00000005
	BS_AUTO3STATE = 0x00000006
	BS_GROUP_BOX = 0x00000007
	BS_USER_BUTTON = 0x00000008
	BS_AUTO_RADIO_BUTTON = 0x00000009
	BS_PUSH_BOX = 0x0000000A
	BS_OWNER_DRAW = 0x0000000B
	BS_TYPE_MASK = 0x0000000F
	BS_LEFT_TEXT = 0x00000020

	BS_TEXT = BS_PUSH_BUTTON
	BS_ICON = 0x00000040
	BS_BITMAP = 0x00000080
	BS_LEFT = 0x00000100
	BS_RIGHT = 0x00000200
	BS_CENTER = 0x00000300
	BS_TOP = 0x00000400
	BS_BOTTOM = 0x00000800
	BS_VERTICAL_CENTER = 0x00000C00
	BS_PUSH_LIKE = 0x00001000
	BS_MULTILINE = 0x00002000
	BS_NOTIFY = 0x00004000
	BS_FLAT = 0x00008000
	BS_RIGHT_BUTTON = BS_LEFT_TEXT
}

enum ButtonStates : UInt16 {
	BST_UNCHECKED = 0x0000
	BST_CHECKED = 0x0001
	BST_INDETERMINATE = 0x0002
	BST_PUSHED = 0x0004
	BST_FOCUS = 0x0008
}

fun buttonWindowProcW(hWnd HWnd, uMsg Message, wParam WParam, lParam LParam) LResult? {
	// kkernelDebugLog("buttonWindowProcW called".utf16())

	switch uMsg {
		case WM_PAINT:
			kkernelDebugLog("buttonWindowProcW called - WM_PAINT".utf16())

			if isWindowVisible(hWnd) != Bool32.True {
				// TODO return what?
				// return null
			}

			let ps ByValue<PaintStruct> = ByValue<PaintStruct>()
			let hdc = beginPaint(hWnd, ps.ref)
			// let color_window = 5 // TODO
			// fillRect(hdc, ps.ref.rcPaint.ref, (color_window + 1) as! HBrush)
			let window = handleToWindow(hWnd)
			let style = getWindowLongW(hWnd, -16)
			let userdata = getWindowLongW(hWnd, -20)

			let title = window.title.utf16()

			switch (style & 0x000F) as! ButtonStyles {
				case BS_CHECK_BOX:
					// TODO

				case BS_GROUP_BOX:
					let r = ByValue<Rect>()
					getClientRect(hWnd, r.ref)
					drawTextW(hdc, title, -1, r.ref, DrawTextFormat.DT_SINGLE_LINE)

				case _:
					// Includes BS_PUSH_BUTTON and BS_DEF_PUSH_BUTTON

					// TODO
					// Draw push button
					// - black frame
					// - shadow etc.
					// - title string
					// - rectangle with dash line it means focus
					// (and strong black frame for default button)
					let r = ByValue<Rect>()
					getClientRect(hWnd, r.ref)
					let fmt DrawTextFormat = DrawTextFormat.DT_CENTER // TODO | DrawTextFormat.DT_V_CENTER

					let color_window = 5 // TODO
					// fillRect(hdc, ps.ref.rcPaint.ref, (color_window + 2) as! HBrush)
					// fillRect(hdc, r.ref, (color_window + 2) as! HBrush)
					fillRect(hdc, r.ref, getStockObject(2) as! HBrush)
					drawEdge(hdc, r.ref, EdgeFlags.BDR_RAISED_INNER, BorderFlags.BF_MIDDLE /* TODO | BF_RECT*/)
					r.ref.left += 2
					r.ref.top += 2
					r.ref.right += 2
					r.ref.bottom += 2
					drawTextW(hdc, title, -1, r.ref, fmt)

					/*if (userdata & (ButtonStates.BST_PUSHED as! UInt16) /*TODO*/) == 0 {
						drawEdge(hdc, r.ref, EdgeFlags.BDR_RAISED_INNER, BorderFlags.BF_MIDDLE /* TODO | BF_RECT*/)
						if (style & (ButtonStyles.BS_MULTILINE as! UInt16) /*TODO*/) == 0 {
							// TODO fmt |= DrawTextFormat.DT_SINGLE_LINE
							drawTextW(hdc, title, -1, r.ref, fmt)
						}
					}*/
					// TODO
					// if focus
					// - drawEdge(hdc, &r, BDR_RAISEDINNER, BF_MIDDLE | BF_RECT);
					// - drawFocusRect(hdc, &r);
			}

			// TODO restore font and bkg
			endPaint(hWnd, ps.ref)

			return null
	}

	kkernelDebugLog("buttonWindowProcW called - default".utf16())
	return defWindowProcW(hWnd, uMsg, wParam, lParam)
}

// TODO calling convention? for x32, same for other proc's + Hexa check for it on assign at `wc.proc = proc`
fun emptyWindowProcW(hWnd HWnd, uMsg Message, wParam WParam, lParam LParam) LResult? {
	// kkernelDebugLog("emptyWindowProcW called".utf16())

	// TODO `WM_ERASEBKGND` must be handled in the def window proc ig
	switch uMsg {
		case WM_PAINT:
			kkernelDebugLog("emptyWindowProcW called - WM_PAINT".utf16())
			let ps ByValue<PaintStruct> = ByValue<PaintStruct>()
			let hdc = beginPaint(hWnd, ps.ref)

			let color_window = 5 // TODO
			// fillRect(hdc, ps.ref.rcPaint.ref, (color_window + 1) as! HBrush)

			endPaint(hWnd, ps.ref)

			return null
	}

	kkernelDebugLog("emptyWindowProcW called - default".utf16())
	return defWindowProcW(hWnd, uMsg, wParam, lParam)
}

fun registerDefaultComponents() Bool32 {
	let wc = ByValue<WindowClass>()
	wc.ref.style = 0 // TODO

	// TODO register registerDefaultButtonComponent()

	// BUTTON
	wc.ref.lpfnWndProc = buttonWindowProcW
	wc.ref.utf16zClassName = "Button".utf16()
	registerClassW(wc.ref)

	// TODO make class registration code case-insensitive
	wc.ref.lpfnWndProc = buttonWindowProcW
	wc.ref.utf16zClassName = "BUTTON".utf16()
	registerClassW(wc.ref)

	// COMBO
	// TODO wc.ref.lpfnWndProc = comboWindowProcW
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "ComboBox".utf16()
	registerClassW(wc.ref)

	// COMBO L BOX
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "ComboLBox".utf16()
	registerClassW(wc.ref)

	// DIALOG
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = 32770 as! ConstArrayPointer<ClangWideChar>
	registerClassW(wc.ref)

	// EDIT
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "Edit".utf16()
	registerClassW(wc.ref)

	// ICON TITLE
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = 32772 as! ConstArrayPointer<ClangWideChar>
	registerClassW(wc.ref)

	// LISTBOX
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "ListBox".utf16()
	registerClassW(wc.ref)

	// MDI CLIENT
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "MDIClient".utf16()
	registerClassW(wc.ref)

	// MENU
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = 32768 as! ConstArrayPointer<ClangWideChar>
	registerClassW(wc.ref)

	// SCROLL
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "ScrollBar".utf16()
	registerClassW(wc.ref)

	// STATIC
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "Static".utf16()
	registerClassW(wc.ref)

	// IME
	wc.ref.lpfnWndProc = emptyWindowProcW // TODO
	wc.ref.utf16zClassName = "IME".utf16()
	registerClassW(wc.ref)

	return Bool32.True
}

