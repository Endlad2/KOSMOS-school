@dllExport('SetTimer')
fun setTimer(hWnd HWnd, nIDEvent SizeOfPointer, uElapse UInt32, lpTimerFunc TimerProcedure) UInt64 {
	kkernelDebugLog("setTimer called with hWnd %8, nIDEvent %u".utf16(),
		hWnd as! UInt64, nIDEvent as! UInt64)

	let uElapse = uElapse < 0x0000000A ? 0x0000000Au32 : uElapse // USER_TIMER_MINIMUM
	let uElapse = uElapse > 0x7FFFFFFF ? 0x7FFFFFFFu32 : uElapse // USER_TIMER_MAXIMUM

	let payload = new ByValue<SetTimerPayload>()
	let payload = payload.ref
	payload.hwnd = hWnd as! UInt64
	payload.nIDEvent = nIDEvent as! UInt64
	payload.uElapse = uElapse
	payload.timerProc = lpTimerFunc as! TimerProcedure

	let result = tofitaSetTimer(payload)
	kkernelDebugLog("setTimer done, result = %u".utf16(), result as! UInt64)
	return result
}

@dllExport('KillTimer')
fun killTimer(hWnd HWnd, uIDEvent SizeOfPointer) Bool32 {
	kkernelDebugLog("killTimer called with hWnd %8, uIDEvent %u".utf16(),
		hWnd as! UInt64, uIDEvent as! UInt64)

	let payload = new ByValue<KillTimerPayload>()
	let payload = payload.ref
	payload.hwnd = hWnd as! UInt64
	payload.nIDEvent = uIDEvent as! UInt64

	let result = tofitaKillTimer(payload)
	kkernelDebugLog("killTimer done, result = %u".utf16(), result as! UInt64)
	return result
}

