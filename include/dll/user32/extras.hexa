@dllExport('InflateRect')
fun inflateRect(lprc Rect?, dx Int32, dy Int32) Bool32 {
	kkernelDebugLog("inflateRect called with dx %d, dy %d".utf16(), dx as! UInt64, dy as! UInt64)

	if let lprc = lprc {
		lprc.left -= dx
		lprc.top -= dy
		lprc.right += dx
		lprc.bottom += dy
		return Bool32.True // Success
	}

	kkernelDebugLog("inflateRect: lprc is null".utf16())
	return Bool32.False
}

