@dllExport('IsWindowVisible')
fun isWindowVisible(hWnd HWnd) Bool32 {
	// TODO
	kkernelDebugLog("isWindowVisible called".utf16())
	let ws_visible = 0x10000000i32
	let gwl_style = -16
	// TODO test case if it returns `1` or some `non-zero` value
	// ^ in case of "non-zero" we would have to use `bool.isTrue()` instead of stricter `bool == Bool32.True`
	return Bool32.fromNonZero(
		// TODO Hexa `SOP & SOP`
		getWindowLongPtrW(hWnd, gwl_style) as! UInt32 & ws_visible
	)
}

