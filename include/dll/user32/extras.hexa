fun releaseCapture() Bool32 {
	// TODO
	kkernelDebugLog("releaseCapture called".utf16())
	return Bool32.True
}

@struct
class WindowClassEx {
	var cbSize Int32
	var style UInt32
	var lpfnWndProc WindowProcedure
	var cbClsExtra Int32
	var cbWndExtra Int32
	var hInstance HInstance
	var hIcon HIcon
	var hCursor HCursor
	var hbrBackground HBrush
	var lpszMenuName ConstArrayPointer<ClangWideChar>
	var utf16zClassName ConstArrayPointer<ClangWideChar>
	var hIconSm HIcon
	new () { }
}

@dllExport('RegisterClassExW')
fun registerClassExW(wc WindowClassEx) Atom {
	// TODO actually do opposite: `registerClassW` calls `registerClassExW`
	kkernelDebugLog("registerClassExW called".utf16())

	// TODO If you fail to initialize the structure correctly (e.g., if you forget to set wc.cbSize or wc.lpfnWndProc),
	// the function will typically fail gracefully and return 0.
	// You could then call GetLastError() to get the error code, usually ERROR_INVALID_PARAMETER (87).

	let wcw = ByValue<WindowClass>()
	let wcw WindowClass = wcw.ref
	// wcw.cbSize = sizeOf<WindowClass>()
	wcw.style = wc.style
	wcw.lpfnWndProc = wc.lpfnWndProc
	wcw.cbClsExtra = wc.cbClsExtra
	// TODO respect cbWndExtra
	wcw.cbWndExtra = wc.cbWndExtra
	wcw.hInstance = wc.hInstance
	wcw.hIcon = wc.hIcon
	wcw.hCursor = wc.hCursor
	wcw.hbrBackground = wc.hbrBackground
	wcw.lpszMenuName = wc.lpszMenuName
	wcw.utf16zClassName = wc.utf16zClassName
	// wcw.hIconSm = 0

	// TODO Hexa: `let wc = wc ?? return setLastErrorAndFalse(code)` -> returns `Bool32.False`
	// ^ `wc! ??` ? support `!` variant too just in case (simple check for `?? return/throw/continue/break`)

	return registerClassW(wcw)
}

@dllExport('RedrawWindow')
fun redrawWindow(hwnd HWnd, r Rect?, rgn HRgn?, flags UInt32) Bool32 {
	// TODO
	kkernelDebugLog("redrawWindow called".utf16())

	let rdw_invalidate = flags & 0x0001 != 0
	let rdw_internal_paint = flags & 0x0002 != 0
	let rdw_erase = flags & 0x0004 != 0
	let rdw_validate = flags & 0x0008 != 0
	let rdw_no_internal = flags & 0x0010 != 0
	let rdw_no_erase = flags & 0x0020 != 0
	let rdw_no_children = flags & 0x0040 != 0
	let rdw_all_children = flags & 0x0080 != 0
	let rdw_update_now = flags & 0x0100 != 0
	let rdw_erase_now = flags & 0x0200 != 0
	let rdw_frame = flags & 0x0400 != 0
	let rdw_no_frame = flags & 0x0800 != 0

	if rdw_invalidate {
		if rgn != null {
			// TODO return invalidateRgn(hwnd, rgn, Bool32.fromBool(rdw_erase))
		} else {
			return invalidateRect(hwnd, r, Bool32.fromBool(rdw_erase))
		}
	}

	// TODO Forcing it for now
	if rdw_update_now or true {
		sendMessageW(hwnd, Message.WM_PAINT, null, null)
	}

	return Bool32.True
}

// Purpose: Determines if a point is inside a rectangle
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-ptinrect
@dllExport('PtInRect')
// TODO Hexa: `lprc Readonly<Rect>` or something
fun ptInRect(lprc Rect, pt ByValue<Point>) Bool32 {
	kkernelDebugLog("ptInRect called with lprc %8".utf16(), lprc as! UInt64)
	kkernelDebugLog("> pt.x %d, pt.y %d".utf16(), pt.ref.x as! UInt64, pt.ref.y as! UInt64)

	if lprc == null {
		kkernelDebugLog("> Invalid rectangle pointer".utf16())
		return Bool32.False
	}

	// TODO Hexa: propose to use .ref.name Class `ByValue` has no field `.x`
	let result = pt.ref.x >= lprc.left and pt.ref.x < lprc.right and
	pt.ref.y >= lprc.top and pt.ref.y < lprc.bottom

	// TODO Hexa: cover `else {} as!` nad `if {} as!` with tests to ensure parsing to not break or change this logic
	// cause its confusing (move to the typer)
	// kkernelDebugLog("> Point %S in rect".utf16(), if result { "is".utf16() } else { "is not".utf16() } as! UInt64)
	return result as! Bool32 // TODO Bool32.fromBool(result)
}

// Purpose: Determines if two rectangles are equal
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-equalrect
@dllExport('EqualRect')
fun equalRect(lprc1 Rect, lprc2 Rect) Bool32 {
	kkernelDebugLog("equalRect called with lprc1 %8, lprc2 %8".utf16(),
		lprc1 as! UInt64, lprc2 as! UInt64)

	if lprc1 == null or lprc2 == null {
		kkernelDebugLog("> Invalid rectangle pointer".utf16())
		return Bool32.False
	}

	let equal = lprc1.left == lprc2.left and
	lprc1.top == lprc2.top and
	lprc1.right == lprc2.right and
	lprc1.bottom == lprc2.bottom

	// TODO oh yeah use `.address` instead lol
	kkernelDebugLog("> Rectangles %s".utf16(), if equal { "are equal".utf16() as! UInt64 } else { "are not equal".utf16() as! UInt64 })
	return Bool32.fromBool(equal)
}

