enum RasterOperation : UInt32 {
	SrcCopy = 0x00CC0020
	PatCopy = 0x00F00021
}

fun randomize(state UInt32) UInt32 {
	var state = state
	state ^= state << 13
	state ^= state >> 17
	state ^= state << 5
	return state
}

@dllExport('BitBlt')
fun bitBlt(
	hdc HDc, // Destination DC
	xDest Int32, // Destination X
	yDest Int32, // Destination Y
	cx Int32, // Width
	cy Int32, // Height
	hdcSrc HDc?, // Source DC (optional, depends on dwRop)
	xSrc Int32, // Source X
	ySrc Int32, // Source Y
	dwRop RasterOperation // Raster operation code (e.g., SRCCOPY, PATCOPY)
) Bool32 {
	// TODO Implement block transfer of pixel data. This is complex.
	// Needs to handle various ROP codes, source/destination DCs (memory or screen),
	// clipping, potential stretching (though StretchBlt is separate), brush patterns (for PATCOPY etc.).
	kkernelDebugLog("bitBlt called on DC %8 from DC %8".utf16(), hdc as! UInt64, hdcSrc as! UInt64)
	kkernelDebugLog("> ROP %u".utf16(), dwRop as! UInt64)
	kkernelDebugLog("> x %d y %d".utf16(), xDest as! UInt64, yDest as! UInt64)
	kkernelDebugLog("> cx %d cy %d".utf16(), cx as! UInt64, cy as! UInt64)
	kkernelDebugLog("> xSrc %d ySrc %d".utf16(), xSrc as! UInt64, ySrc as! UInt64)
	// Placeholder: Needs extensive implementation covering ROPs, clipping, surfaces.

	// let rect = Rect(x, y, x + cx, y + cy)

	/*
	let rect = Rect()
	rect.left = x
	rect.top = y
	rect.right = x + cx
	rect.bottom = y + cy
	// NOTE Hexa: `fillRect(hdc, rect, random(rand()) as! HBrush)` generates `called object type 'int32_t' (aka 'int') is not a function or function pointer`
	fillRect(hdc, rect, randomize(rand() as! UInt32) as! HBrush)
	*/
	let dcDest = hdc as! DC
	let dcSrc = hdcSrc as! DC
	if dcDest == null or dcSrc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	kkernelDebugLog("> dcDest: %8".utf16(), dcDest as! UInt64)
	kkernelDebugLog("> dcDest.handleType: %8".utf16(), dcDest.handleType as! UInt64)
	kkernelDebugLog("> dcSrc: %8".utf16(), dcSrc as! UInt64)
	kkernelDebugLog("> dcSrc.handleType: %8".utf16(), dcSrc.handleType as! UInt64)

	// let bmpDest = dcDest.hBitmap as! Bitmap
	// if bmpDest == null {
	// kkernelDebugLog("> Invalid destination bitmap, trying framebuffer".utf16())
	// let fb = dcDest.fb.ref
	// bytesPerRowDest = fb.width * 4i32
	// bitsDest = fb.pixels as! ArrayPointer<UInt8>
	// // TODO null-check here too of `fb.pixels` cause `fb` is by value`
	// } else {
	// bytesPerRowDest = bmpDest.bytesPerRow
	// bitsDest = bmpDest.bits
	// }

	var bytesPerRowDest = 0i32
	var bitsDest ArrayPointer<UInt8> = null
	var widthDest = 0i32
	var heightDest = 0i32
	var bppDest = 0i16
	if let bmpDest = dcDest.hBitmap as! Bitmap {
		kkernelDebugLog("> Using dcDest.hBitmap: %8".utf16(), dcDest.hBitmap as! UInt64)

		bytesPerRowDest = bmpDest.bytesPerRow
		bitsDest = bmpDest.bits
		widthDest = bmpDest.width
		heightDest = bmpDest.height
		bppDest = bmpDest.bitsPerPixel

		kkernelDebugLog("> bytesPerRowDest: %d".utf16(), bytesPerRowDest as! UInt64)
		kkernelDebugLog("> bitsDest: %8".utf16(), bitsDest as! UInt64)
		kkernelDebugLog("> widthDest: %d".utf16(), widthDest as! UInt64)
		kkernelDebugLog("> heightDest: %d".utf16(), heightDest as! UInt64)
		kkernelDebugLog("> bppDest: %d".utf16(), bppDest as! UInt64)
	} else {
		kkernelDebugLog("> Invalid destination bitmap, trying framebuffer".utf16())
		let fb = dcDest.fb.ref
		bytesPerRowDest = fb.width * 4i32
		bitsDest = fb.pixels as! ArrayPointer<UInt8>
		// TODO null-check here too of `fb.pixels` cause `fb` is by value`
		widthDest = fb.width as! Int32
		heightDest = fb.height as! Int32
		bppDest = 32i16

		kkernelDebugLog("> fb.pixels: %8".utf16(), fb.pixels as! UInt64)
		kkernelDebugLog("> fb.width: %d".utf16(), fb.width as! UInt64)
		kkernelDebugLog("> fb.height: %d".utf16(), fb.height as! UInt64)
		kkernelDebugLog("> calculated bytesPerRow: %d".utf16(), bytesPerRowDest as! UInt64)
	}

	// let bmpSrc = dcSrc.hBitmap as! Bitmap
	// var bytesPerRowSrc = 0i32
	// var bitsSrc ArrayPointer<UInt8> = null
	// if bmpSrc == null {
	// kkernelDebugLog("> Invalid source bitmap, trying framebuffer".utf16())
	// let fb = dcSrc.fb.ref
	// bytesPerRowSrc = fb.width * 4i32
	// bitsSrc = fb.pixels as! ArrayPointer<UInt8>
	// } else {
	// bytesPerRowSrc = bmpSrc.bytesPerRow
	// bitsSrc = bmpSrc.bits
	// }

	var bytesPerRowSrc = 0i32
	var bitsSrc ArrayPointer<UInt8> = null
	var widthSrc = 0i32
	var heightSrc = 0i32
	var bppSrc = 0i16
	var colorTable ArrayPointer<ByValue<RGBQUAD>> = null
	var colorTableSize = 0u32
	var isBottomUpSrc = false
	if let bmpSrc = dcSrc.hBitmap as! Bitmap {
		kkernelDebugLog("> Using dcSrc.hBitmap: %8".utf16(), dcSrc.hBitmap as! UInt64)

		bytesPerRowSrc = bmpSrc.bytesPerRow
		bitsSrc = bmpSrc.bits
		widthSrc = bmpSrc.width
		heightSrc = bmpSrc.height
		bppSrc = bmpSrc.bitsPerPixel
		colorTable = bmpSrc.colorTable
		colorTableSize = bmpSrc.colorTableSize
		isBottomUpSrc = not bmpSrc.isTopDown

		kkernelDebugLog("> bytesPerRowSrc: %d".utf16(), bytesPerRowSrc as! UInt64)
		kkernelDebugLog("> bitsSrc: %8".utf16(), bitsSrc as! UInt64)
		kkernelDebugLog("> widthSrc: %d".utf16(), widthSrc as! UInt64)
		kkernelDebugLog("> heightSrc: %d".utf16(), heightSrc as! UInt64)
		kkernelDebugLog("> bppSrc: %d".utf16(), bppSrc as! UInt64)
		kkernelDebugLog("> colorTable: %8".utf16(), colorTable as! UInt64)
		kkernelDebugLog("> colorTableSize: %d".utf16(), colorTableSize as! UInt64)
		kkernelDebugLog("> isBottomUpSrc: %d".utf16(), isBottomUpSrc as! UInt64)
	} else {
		kkernelDebugLog("> Invalid source bitmap, trying framebuffer".utf16())
		let fb = dcSrc.fb.ref
		bytesPerRowSrc = fb.width * 4i32
		bitsSrc = fb.pixels as! ArrayPointer<UInt8>
		// TODO null-check here too of `fb.pixels` cause `fb` is by value`
		widthSrc = fb.width as! Int32
		heightSrc = fb.height as! Int32
		bppSrc = 32i16

		kkernelDebugLog("> fb.pixels: %8".utf16(), fb.pixels as! UInt64)
		kkernelDebugLog("> fb.width: %d".utf16(), fb.width as! UInt64)
		kkernelDebugLog("> fb.height: %d".utf16(), fb.height as! UInt64)
		kkernelDebugLog("> calculated bytesPerRow: %d".utf16(), bytesPerRowSrc as! UInt64)
	}

	// Adjust coordinates and dimensions to clip within bounds
	var adjXDest = xDest
	var adjYDest = yDest
	var adjXSrc = xSrc
	var adjYSrc = ySrc
	var adjWidth = cx
	var adjHeight = cy

	// Clip destination
	if adjXDest < 0 {
		adjXSrc -= adjXDest // Adjust source accordingly
		adjWidth += adjXDest
		adjXDest = 0
	}
	if adjYDest < 0 {
		adjYSrc -= adjYDest
		adjHeight += adjYDest
		adjYDest = 0
	}
	if adjXDest + adjWidth > widthDest {
		adjWidth = widthDest - adjXDest
	}
	if adjYDest + adjHeight > heightDest {
		adjHeight = heightDest - adjYDest
	}

	// Clip source
	if adjXSrc < 0 {
		adjXDest -= adjXSrc
		adjWidth += adjXSrc
		adjXSrc = 0
	}
	if adjYSrc < 0 {
		adjYDest -= adjYSrc
		adjHeight += adjYSrc
		adjYSrc = 0
	}
	if adjXSrc + adjWidth > widthSrc {
		adjWidth = widthSrc - adjXSrc
	}
	if adjYSrc + adjHeight > heightSrc {
		adjHeight = heightSrc - adjYSrc
	}

	// Ensure non-negative dimensions
	if adjWidth <= 0 or adjHeight <= 0 {
		return Bool32.True // Nothing to draw, but not an error
	}

	// Validate bounds
	if xDest < 0 or yDest < 0 or xSrc < 0 or ySrc < 0 or cx <= 0 or cy <= 0 {
		kkernelDebugLog("> Invalid coordinates or dimensions".utf16())
		// return Bool32.False
	}
	if xDest + cx > widthDest or yDest + cy > heightDest or xSrc + cx > widthSrc or ySrc + cy > heightSrc {
		kkernelDebugLog("> Out of bounds".utf16())
		// return Bool32.False
	}

	// Apply clipped
	let xDest = adjXDest
	let yDest = adjYDest
	let xSrc = adjXSrc
	let ySrc = adjYSrc
	let cx = adjWidth
	let cy = adjHeight

	// Only support SRCCOPY
	if dwRop != RasterOperation.SrcCopy {
		kkernelDebugLog("> Unsupported ROP".utf16())
		return Bool32.False
	}

	// Only support SRCCOPY for the sample code

	/*if dwRop == RasterOperation.SrcCopy {
		for row in 0 ... cy - 1 {
			let srcOffset = ((ySrc + row) * bytesPerRowSrc + xSrc * 4) as! Int
			let destOffset = ((yDest + row) * bytesPerRowDest + xDest * 4) as! Int
			// TODO rename `offsetItemsBack` ot `offsetItems` and `offsetItemsForward` or `offsetItemsBidirectional`
			// ^ should not work for `ArrayPointer<Void>`
			memcpy(bitsDest.offsetItemsBack(destOffset), bitsSrc.offsetItemsBack(srcOffset), cx * 4)
		}
	}*/
	// Handle different bit depths
	if bppSrc == 8i16 and bppDest == 32i16 {
		kkernelDebugLog("> bppSrc == %di16 and bppDest == 32i16".utf16(), bppSrc as! UInt16)

		// N-bit source (indexed) to 32-bit destination (RGBA)
		if colorTable == null or colorTableSize == 0 {
			kkernelDebugLog("> Color table missing for N-bit source".utf16())
			return Bool32.False
		}

		// TODO Hexa: `let isBottomUp = if let bmpSrc = dcSrc.hBitmap as! Bitmap { bmpSrc.height > 0 } else { true }`
		for row in cy {
			// TODO Hexa: `let srcRow = if isBottomUp { cy - 1 - row } else { row }`
			let srcRow = isBottomUpSrc? (cy - 1 - row) : row
			let srcRowOffset = (ySrc + srcRow) * bytesPerRowSrc + xSrc
			// `let srcRowOffset = (ySrc + row) * bytesPerRowSrc + xSrc`
			let destRowOffset = ((yDest + row) * bytesPerRowDest + xDest * 4) as! Int
			let colorTable = colorTable as! ArrayPointer<UInt32>

			for col in cx {
				let srcPixel = bitsSrc[srcRowOffset + col]
				let destPixelOffset = destRowOffset + col * 4
				// if (srcPixel as! UInt32) < colorTableSize {

				if true {
					// let color = colorTable[srcPixel as! Int].ref
					// Alpha 255
					let color = ((srcPixel as! UInt32) < colorTableSize) ? (colorTable[srcPixel as! Int] | 0xFF000000u32) : 0xFF000000u32
					let bitsDest = (bitsDest.offsetItemsBack(destPixelOffset)) as! ArrayPointer<UInt32>
					bitsDest[0] = color

					// bitsDest[destPixelOffset] = color.rgbBlue
					// bitsDest[destPixelOffset + 1] = color.rgbGreen
					// bitsDest[destPixelOffset + 2] = color.rgbRed
					// bitsDest[destPixelOffset + 3] = 255u8 // Alpha
					// Log first pixel for debugging

					/*if row == 0 and col == 0 {
						kkernelDebugLog("> First pixel index: %u R %u".utf16(),
							srcPixel as! UInt64,
							color.rgbBlue as! UInt64
						)
						kkernelDebugLog("> GB: %u,%u".utf16(),
							color.rgbGreen as! UInt64,
							color.rgbRed as! UInt64
						)
					}*/
				} else {
					// kkernelDebugLog("> Invalid pixel index: %u".utf16(), srcPixel as! UInt64)
					// Invalid index: use black
					bitsDest[destPixelOffset] = 0u8
					bitsDest[destPixelOffset + 1] = 0u8
					bitsDest[destPixelOffset + 2] = 0u8
					bitsDest[destPixelOffset + 3] = 255u8
				}
			}
		}
	} else if bppSrc == 4i16 and bppDest == 32i16 {
		// The thing is that in 4bpp every byte is two pixels instead of one
		kkernelDebugLog("> bppSrc == %di16 and bppDest == 32i16 (two pixels per byte)".utf16(), bppSrc as! UInt16)

		// N-bit source (indexed) to 32-bit destination (RGBA)
		if colorTable == null or colorTableSize == 0 {
			kkernelDebugLog("> Color table missing for N-bit source".utf16())
			return Bool32.False
		}

		for row in cy {
			// logical row *inside* the whole bitmap (sub-rectangle)
			let logicalY = ySrc + row

			// physical row in the byte array
			let physicalRow = if isBottomUpSrc {
				heightSrc - 1 - logicalY // bottom-up storage
			} else {
				logicalY // top-down storage
			}

			let srcRowOffset = physicalRow * bytesPerRowSrc + xSrc / 2 // 4-bpp

			let destRowOffset = ((yDest + row) * bytesPerRowDest + xDest * 4) as! Int
			let colorTable = colorTable as! ArrayPointer<UInt32>

			for col in cx {
				let byteIndex = (xSrc + col) / 2 // which byte
				let nibbleSel = (xSrc + col) & 1 // 0 = high nibble, 1 = low nibble

				let rawPixel = bitsSrc[srcRowOffset + byteIndex]
				let srcPixel = if nibbleSel == 0 { rawPixel >> 4 } else { rawPixel & 0x0F }

				let destPixelOffset = destRowOffset + col * 4
				let color = ((srcPixel as! UInt32) < colorTableSize)
				? (colorTable[srcPixel as! Int] | 0xFF000000u32)
				: 0xFF000000u32
				let bitsDest = (bitsDest.offsetItemsBack(destPixelOffset)) as! ArrayPointer<UInt32>
				bitsDest[0] = color
			}
		}
	} else if bppSrc == 32i16 and bppDest == 32i16 {
		kkernelDebugLog("> bppSrc == 32i16 and bppDest == 32i16".utf16())

		// 32-bit to 32-bit copy
		for row in cy {
			let srcOffset = ((ySrc + row) * bytesPerRowSrc + xSrc * 4) as! Int
			let destOffset = ((yDest + row) * bytesPerRowDest + xDest * 4) as! Int
			memcpy(bitsDest.offsetItemsBack(destOffset), bitsSrc.offsetItemsBack(srcOffset), cx * 4)
		}
	} else {
		kkernelDebugLog("> Unsupported bit depth combination: src %d, dest %d".utf16(), bppSrc as! UInt64, bppDest as! UInt64)
		return Bool32.False
	}

	// TODO freaking Solitaire re-paints without timer, it uses sleep!
	// njraaSwapWindowFramebuffer(dcDest.fb.ref)
	kosmos32FastSystemCall(TofitaSyscalls.LazySwap as! TofitaSyscalls, 0)

	kkernelDebugLog("> BitBlt completed".utf16())
	return Bool32.True
}

@dllExport('DeleteDC')
fun deleteDC(hdc HDc) Bool32 {
	// TODO
	kkernelDebugLog("deleteDC called with hdc %8".utf16(), hdc as! UInt64)
	let dc = hdc as! DC
	if dc == null or dc == defaultDC {
		return Bool32.False
	}

	if dc.hBitmap != null {
		deleteObject(dc.hBitmap as! Handle)
	}

	if dc.hPen != null {
		deleteObject(dc.hPen as! Handle)
	}

	// free(dc as! RuntimeAllocated)
	return Bool32.True
}

@dllExport('CreateCompatibleDC')
fun createCompatibleDC(hdc HDc?) HDc {
	// TODO Create memory DC compatible with hdc's device
	kkernelDebugLog("createCompatibleDC called with hdc %8".utf16(), hdc as! UInt64)
	// TODO ensure heap
	let dc DC = @heap DC()
	kkernelDebugLog("> allocated DC at %8".utf16(), dc as! UInt64)
	// TODO move `=` into definition
	dc.penPosX = 0
	dc.penPosY = 0

	// Create default pen (black, solid, 1-pixel wide)
	let defaultPen = @heap new Pen()
	defaultPen.style = 0 // PS_SOLID
	defaultPen.width = 1
	defaultPen.color = 0x000000 as! COLORREF // Black
	dc.hPen = defaultPen as! HPen

	// Create a default 1x1 monochrome bitmap
	let bitmap = @heap new Bitmap()
	bitmap.width = 1
	bitmap.height = 1
	bitmap.bitsPerPixel = 1i16
	bitmap.bytesPerRow = 4 // Minimal aligned row size
	bitmap.bits = malloc(4) as! ArrayPointer<UInt8>
	bitmap.isTopDown = true
	if bitmap.bits != null {
		bitmap.bits[0] = 0xFFu8 // White pixel
	}
	dc.hBitmap = bitmap as! HBitmap

	return dc as! HDc
}

