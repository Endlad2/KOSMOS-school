@dllExport('SetBrushOrgEx')
fun setBrushOrgEx(hdc HDc, x Int32, y Int32, lppt Point?) Bool32 {
	kkernelDebugLog("setBrushOrgEx called with hdc %8".utf16(), hdc as! UInt64)
	kkernelDebugLog("> x %d y %d".utf16(), x as! UInt64, y as! UInt64)
	kkernelDebugLog("> lppt %8".utf16(), lppt as! UInt64)
	// TODO Set brush origin, store old in lppt
	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	if let lppt = lppt {
		lppt.x = dc.brushOrgX
		lppt.y = dc.brushOrgY
	}

	dc.brushOrgX = x
	dc.brushOrgY = y
	return Bool32.True
}

// Purpose: Sets the text color for a device context
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/wingdi/nf-wingdi-settextcolor
@dllExport('SetTextColor')
fun setTextColor(hdc HDc, color COLORREF) COLORREF {
	kkernelDebugLog("setTextColor called with hdc %8 color %u".utf16(), hdc as! UInt64, color as! UInt64)

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return 0
	}

	let prevColor = dc.textColor
	dc.textColor = color
	return prevColor
}

