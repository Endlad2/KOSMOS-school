	// TODO
	kkernelDebugLog("getThreadUILanguage called".utf16())
	let lang_english = 9u16
	let sublang_english_us = 1u16
	return make_lang_id(lang_english, sublang_english_us)
}

/// Find a resource in the specified module
@dllExport('FindResourceW')
fun findResourceW(hModule HModule, lpName ConstArrayPointer<ClangWideChar>, lpType ConstArrayPointer<ClangWideChar>) HRsrc {
	kkernelDebugLog("findResourceW called".utf16())

	// TODO Hexa: this creates a "inline" function (unsupported on the C target yet)
	// `return findResourceExW(hModule, lpType, lpName, getThreadUILanguage()) ?? findResourceExW(hModule, lpType, lpName, make_lang_id(lang_neutral, sub_lang_neutral))`

	if let resource = findResourceExW(hModule, lpType, lpName, getThreadUILanguage()) {
		return resource
	}

	return findResourceExW(hModule, lpType, lpName, make_lang_id(lang_neutral, sub_lang_neutral))
}

/// Load a resource from the specified module
@dllExport('LoadResource')
fun loadResource(hModule HModule, hResInfo HRsrc) HGlobal {
	kkernelDebugLog("loadResource called".utf16())
	return hResInfo as! HGlobal
}

// HGDIOBJ -> Handle
@dllExport('DeleteObject')
fun deleteObject(ho Handle) Bool32 // BOOL -> Bool (return type)
{
	kkernelDebugLog("deleteObject called with h %8".utf16(), ho as! UInt64)
	let handleTypeHolder = ho as! HandleTypeHolder
	if handleTypeHolder != null and handleTypeHolder.handleType == HandleType.HPen {
		// TODO free(ho as! RuntimeAllocated)
	}
	return Bool32.True
}

@dllExport('SelectObject')
fun selectObject(
	hdc Handle, // HDC -> Handle
	h Handle // HGDIOBJ -> Handle
) Handle // HGDIOBJ -> Handle (return type)
{
	kkernelDebugLog("selectObject called with hdc %8 h %8".utf16(), hdc as! UInt64, h as! UInt64)
	// TODO Select other GDI objects into DC, return previous

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return null
	}

	let handleTypeHolder = h as! HandleTypeHolder
	// TODO check for `INVALID_HANDLE` constants too
	if handleTypeHolder == null {
		kkernelDebugLog("> Invalid handle".utf16())
		return null
	}

	switch handleTypeHolder.handleType {
		case HBitmap:
			// Store the current bitmap and select the new one
			let prev = dc.hBitmap
			dc.hBitmap = h as! HBitmap
			kkernelDebugLog("> Selected bitmap %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case HPen:
			let prev = dc.hPen
			dc.hPen = h as! HPen
			kkernelDebugLog("> Selected pen %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case HBrush:
			let prev = dc.hBrush
			dc.hBrush = h as! HBrush
			kkernelDebugLog("> Selected brush %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case HFont:
			let prev = dc.hFont
			dc.hFont = h as! HFont
			kkernelDebugLog("> Selected font %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case HRgn:
			let prev = dc.hRgn
			dc.hRgn = h as! HRgn
			kkernelDebugLog("> Selected region %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case HPalette:
			let prev = dc.hPalette
			dc.hPalette = h as! HPalette
			kkernelDebugLog("> Selected palette %8, previous %8".utf16(), h as! UInt64, prev as! UInt64)
			return prev as! Handle

		case _:
			kkernelDebugLog("> Invalid handle type".utf16())
			return null
	}

	return null
}

