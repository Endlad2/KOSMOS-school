@dllExport('lstrcpyW')
fun lstrcpyW(lpString ArrayPointer<ClangWideChar>, sourceString ConstArrayPointer<ClangWideChar>) ArrayPointer<ClangWideChar> {
	// TODO SEH
	kkernelDebugLog("lstrcpyW called '%S'".utf16(), sourceString as! UInt64)
	var i = 0
	while sourceString[i] as! Int != 0 {
		lpString[i] = sourceString[i]
		i += 1
	}

	lpString[i] = 0
	return lpString
}

@dllExport('GetThreadUILanguage')
