/// Retrieve a message from the queue in a non-blocking way, exact behavior is tunable by the flags
@dllExport('PeekMessageW')
fun peekMessageW(msg Msg, hWnd HWnd?, wMsgFilterMin UInt32, wMsgFilterMax UInt32, wRemoveMsg UInt32) Bool32 {
	// kkernelDebugLog("peekMessageW called".utf16()) <- spammy

	let payload = ByValue<PeekMessagePayload>()
	let payload = payload.ref
	// TODO others by value too

	payload.hwnd = hWnd as! UInt64
	payload.wMsgFilterMin = wMsgFilterMin
	payload.wMsgFilterMax = wMsgFilterMax
	payload.remove = wRemoveMsg
	// TODO respect `wRemoveMsg PM_REMOVE`
	let result = tofitaPeekMessage(payload)

	msg.hwnd = payload.hwnd as! Handle
	msg.message = payload.message
	msg.wParam = payload.wParam as! WParam
	msg.lParam = payload.lParam as! LParam
	msg.time = payload.time
	msg.pt = payload.pt
	msg.lPrivate = payload.lPrivate

	// TODO This is copied from `dispatchMessageW` and then modified to handle `pt`
	if msg.message == Message.WM_MOUSE_MOVE or
		msg.message == Message.WM_LEFT_BUTTON_DOWN or
		msg.message == Message.WM_LEFT_BUTTON_UP or
		msg.message == Message.WM_RIGHT_BUTTON_DOWN or
		msg.message == Message.WM_RIGHT_BUTTON_UP or
		msg.message == Message.WM_MIDDLE_BUTTON_DOWN or
		msg.message == Message.WM_MIDDLE_BUTTON_UP or
		msg.message == Message.WM_LEFT_BUTTON_DOUBLE_CLICK or
		msg.message == Message.WM_RIGHT_BUTTON_DOUBLE_CLICK or
		msg.message == Message.WM_MIDDLE_BUTTON_DOUBLE_CLICK {

		// Extract mouse coordinates
		let lParam UInt32 = msg.lParam as! UInt32
		let frameWidth = 1
		let x Int32 = LParam.loWord(lParam) - frameWidth // Tofita sends non-client/non-screen mouse
		let frameHeight = 33
		let y Int32 = LParam.hiWord(lParam) - frameHeight // Tofita sends non-client/non-screen mouse

		let translatedX = x
		let translatedY = y
		msg.lParam = LParam.makeULong(translatedX as! UInt16, translatedY as! UInt16) as! LParam

		// TODO the `pt` field of the `Msg` structure is always in screen coordinates
		// TODO Hexa `msg.pt = Point(translatedX, translatedY)` i.e. `@struct` are allocated on the stack by default anyway so
		msg.pt.ref.x = translatedX
		msg.pt.ref.y = translatedY
	}

	return result
}

