// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-copyrect
@dllExport('CopyRect')
fun copyRect(lprcDst Rect, lprcSrc Rect) Bool32 {
	kkernelDebugLog("copyRect called with lprcDst %8 lprcSrc %8".utf16(), lprcDst as! UInt64, lprcSrc as! UInt64)

	if lprcDst == null or lprcSrc == null {
		kkernelDebugLog("> Invalid rectangle pointer".utf16())
		return Bool32.False
	}

	lprcDst.left = lprcSrc.left
	lprcDst.top = lprcSrc.top
	lprcDst.right = lprcSrc.right
	lprcDst.bottom = lprcSrc.bottom

	kkernelDebugLog("> Copied rect: left %d, top %d".utf16(),
		lprcDst.left as! UInt64, lprcDst.top as! UInt64)
	kkernelDebugLog("> right %d, bottom %d".utf16(),
		lprcDst.right as! UInt64, lprcDst.bottom as! UInt64)
	return Bool32.True
}

@dllExport('SetWindowLongPtrA')
fun setWindowLongPtrA(hWnd HWnd, nIndex Int32, dwNewLong SizeOfPointer) SizeOfPointer {
	// TODO
	// Here is a summary of the return behavior:
	// Success: Returns the previous value of the specified offset.
	// Failure: Returns zero, and you should check GetLastError for more details.
	// Previous Value is Zero: Returns zero, but you need to clear the last error information to confirm success.
	// TODO Hexa: `.windowLongPtrA` nullable check
	kkernelDebugLog("setWindowLongPtrA called %8 with index %u".utf16(), hWnd as! UInt64, nIndex as! UInt64)
	let previous = handleToWindow(hWnd).windowLongPtrA
	handleToWindow(hWnd).windowLongPtrA = dwNewLong
	kkernelDebugLog("setWindowLongPtrA previous %8".utf16(), previous as! UInt64)
	kkernelDebugLog("setWindowLongPtrA new %8".utf16(), dwNewLong as! UInt64)
	return previous
}

@struct
class WindowClassExA {
	var cbSize UInt32
	var style UInt32
	var lpfnWndProc WindowProcedure
	var cbClsExtra Int32
	var cbWndExtra Int32
	var hInstance HInstance
	var hIcon HIcon
	var hCursor HCursor
	var hbrBackground HBrush
	var lpszMenuName ConstArrayPointer<ClangChar>
	var lpszClassName ConstArrayPointer<ClangChar>
	var hIconSm HIcon
}

@dllExport('RegisterClassExA')
fun registerClassExA(wc WindowClassExA) Atom {
	// TODO
	kkernelDebugLog("registerClassExA called {%s}".utf16(), wc.lpszClassName as! UInt64)
	// TODO crash when 4096
	var lpszMenuName ArrayByValue<ClangWideChar, 256> = [0]
	var utf16zClassName ArrayByValue<ClangWideChar, 256> = [0]

	var i = 0
	while true {
		utf16zClassName[i] = wc.lpszClassName[i]
		if utf16zClassName[i] as! UInt16 == 0 {
			break
		}

		i++
	}

	kkernelDebugLog("registerClassExA utf8 {%S}".utf16(), utf16zClassName as! UInt64)
	let wcw WindowClass = WindowClass() // TODO on stack
	// wcw.cbSize = sizeOf<WindowClass>()
	wcw.style = wc.style
	wcw.lpfnWndProc = wc.lpfnWndProc
	wcw.cbClsExtra = wc.cbClsExtra
	// TODO respect cbWndExtra
	wcw.cbWndExtra = wc.cbWndExtra
	wcw.hInstance = wc.hInstance
	wcw.hIcon = wc.hIcon
	wcw.hCursor = wc.hCursor
	wcw.hbrBackground = wc.hbrBackground
	wcw.lpszMenuName = lpszMenuName.ref
	wcw.utf16zClassName = utf16zClassName.ref
	// wcw.hIconSm = 0

	return registerClassW(wcw)
}

@dllExport('GetWindowLongPtrA')
fun getWindowLongPtrA(hWnd HWnd, nIndex Int32) SizeOfPointer {
	// TODO
	kkernelDebugLog("getWindowLongPtrA called %8 with index %u".utf16(), hWnd as! UInt64, nIndex as! UInt64)

	// TODO Hexa `case -n` and format
	switch - nIndex {
		case 16: // GWL_STYLE
			return handleToWindow(hWnd).style
		case 20: // GWL_EXSTYLE TODO aka GWL_EX_STYLE
			return handleToWindow(hWnd).exStyle
		case 4: // GWL_WNDPROC
			return handleToWindow(hWnd).proc
	}

	let result = handleToWindow(hWnd).windowLongPtrA
	// TODO Hexa: `.windowLongPtrA` nullable check
	kkernelDebugLog("getWindowLongPtrA result %8".utf16(), result as! UInt64)
	return result
}

