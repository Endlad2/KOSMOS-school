// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winbase/nf-winbase-lstrlena
@dllExport('lstrlenA')
fun lstrlenA(lpString ConstArrayPointer<ClangChar>) Int32 {
	kkernelDebugLog("lstrlenA called with lpString %8".utf16(), lpString as! UInt64)

	if lpString == null {
		kkernelDebugLog("> Null string pointer".utf16())
		return 0
	}

	var length = 0
	while lpString[length] != 0 as! ClangChar {
		length += 1
	}

	kkernelDebugLog("> String length %d".utf16(), length as! UInt64)
	return length
}

