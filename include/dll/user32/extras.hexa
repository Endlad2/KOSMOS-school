// Purpose: Moves a rectangle by specified offsets
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-offsetrect
@dllExport('OffsetRect')
fun offsetRect(lprc Rect, dx Int32, dy Int32) Bool32 {
	kkernelDebugLog("offsetRect called with lprc %8".utf16(), lprc as! UInt64)
	kkernelDebugLog("> dx %d dy %d".utf16(), dx as! UInt64, dy as! UInt64)

	if lprc == null {
		kkernelDebugLog("> Invalid rectangle pointer".utf16())
		return Bool32.False
	}

	lprc.left += dx
	lprc.top += dy
	lprc.right += dx
	lprc.bottom += dy

	return Bool32.True
}

