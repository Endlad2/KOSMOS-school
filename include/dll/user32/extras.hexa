var random = 0

#if bit32
	@convention('cdecl')
#end
@dllExport('rand')
fun rand() Int32 {
	// TODO
	kkernelDebugLog("rand called".utf16())

	random ^= (random << 13)
	random ^= (random >> 17)
	random ^= (random << 5)

	kkernelDebugLog("rand result %d".utf16(), random as! UInt64)

	return random & 0x7FFF // Limit to 15 bits aka 32767
}

#if bit32
	@convention('cdecl')
#end
@dllExport('srand')
fun srand(seed UInt32) Void {
	// TODO well use unsigned
	kkernelDebugLog("srand called with seed %u".utf16(), seed)
	/* Prevent zero seed to avoid degenerate Xor-shift */
	if seed == 0 {
		random = 1
		// TODO actual expected value
		random = sizeOf<SizeOfPointer>() as! Int
	} else {
		random = seed as! Int
	}
}

