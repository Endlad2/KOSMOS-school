// Win32 Spec: https://learn.microsoft.com/en-us/windows/console/getconsolemode
@dllExport('GetConsoleMode')
// TODO Hexa: need a non-array pointer tpe here, like `SinglePointer` or `OutPointer` (check the spec `_Out_ LPDWORD lpMode`)
fun getConsoleMode(hConsoleHandle SizeOfPointer, lpMode ArrayPointer<UInt32>) Bool32 {
	kkernelDebugLog("getConsoleMode called with hConsoleHandle %8".utf16(), hConsoleHandle as! UInt64)

	// Validate parameters
	if lpMode == null {
		kkernelDebugLog("> Invalid lpMode pointer".utf16())
		return Bool32.False
	}

	// TODO In a real implementation, check if hConsoleHandle is valid (STD_INPUT_HANDLE, etc.)
	// For simplicity, assume it's a valid console handle and set a default mode
	// Common console modes: ENABLE_ECHO_INPUT | ENABLE_LINE_INPUT | ENABLE_PROCESSED_INPUT
	lpMode[0] = 0x0004 | 0x0002 | 0x0001 // ENABLE_ECHO_INPUT | ENABLE_LINE_INPUT | ENABLE_PROCESSED_INPUT

	kkernelDebugLog("> Set console mode to %u".utf16(), lpMode[0] as! UInt64)
	return Bool32.True
}

// Win32 Spec: https://learn.microsoft.com/en-us/windows/console/getconsoleoutputcp
@dllExport('GetConsoleOutputCP')
fun getConsoleOutputCP(stub SizeOfPointer) UInt32 {
	kkernelDebugLog("getConsoleOutputCP called".utf16())

	// Return default code page (e.g., CP_UTF8 = 65001 or OEM code page like 437)
	let codePage = 65001u32 // UTF-8
	kkernelDebugLog("> Returning code page %u".utf16(), codePage as! UInt64)
	return codePage
}

