// Purpose: Sets the background color for a device context
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/wingdi/nf-wingdi-setbkcolor
@dllExport('SetBkColor')
fun setBkColor(hdc HDc, color COLORREF) COLORREF {
	// TODO Set background color, return previous
	kkernelDebugLog("setBkColor called with hdc %8 color %u".utf16(), hdc as! UInt64, color as! UInt64)

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return 0
	}

	let prevColor = dc.bkColor
	dc.bkColor = color
	// TODO create on demand and cache + destroy old one + set some default
	// ^ Hmm technically we may create the brush once and just update its color field and that's it (brush may be `ByValue`)
	dc.bkBrush = createSolidBrush(color)
	return prevColor
}

