@dllExport('SetDIBitsToDevice')
fun setDIBitsToDevice(
	hdc HDc,
	xDest Int32,
	yDest Int32,
	w UInt32,
	h UInt32,
	xSrc Int32,
	ySrc Int32,
	startScan UInt32,
	scanLines UInt32,
	bits ConstArrayPointer<UInt8>, // raw pixel bytes
	bmi BITMAPINFO,
	usage UInt32 // must be DIB_RGB_COLORS (0)
) Int32 {
	kkernelDebugLog("setDIBitsToDevice called with hdc %8".utf16(), hdc as! UInt64)

	// quick rejections ---------------------------------------------------------
	if hdc == null or bits == null or bmi == null {
		kkernelDebugLog("> hdc or bits or bmi is null".utf16())
		kkernelDebugLog("> hdc: %8".utf16(), hdc as! UInt64)
		kkernelDebugLog("> bits: %8".utf16(), bits as! UInt64)
		kkernelDebugLog("> bmi: %8".utf16(), bmi as! UInt64)
		return 0
	}
	if usage != 0 /*DIB_RGB_COLORS*/ {
		kkernelDebugLog("> usage != 0".utf16())
		kkernelDebugLog("> usage: %u".utf16(), usage as! UInt64)
		return 0
	}

	let hdr = bmi.bmiHeader.ref
	if hdr.biCompression != 0 /*BI_RGB*/ {
		kkernelDebugLog("> hdr.biCompression != 0".utf16())
		kkernelDebugLog("> hdr.biCompression: %u".utf16(), hdr.biCompression as! UInt64)
		return 0
	}

	// TODO 8bpp
	if hdr.biBitCount != 24 and hdr.biBitCount != 32 and hdr.biBitCount != 4 {
		kkernelDebugLog("> hdr.biBitCount != 24/32/4".utf16())
		kkernelDebugLog("> hdr.biBitCount: %u".utf16(), hdr.biBitCount as! UInt64)
		kkernelDebugLog("> hdr.biWidth: %d".utf16(), hdr.biWidth as! UInt64)
		kkernelDebugLog("> hdr.biHeight: %d".utf16(), hdr.biHeight as! UInt64)
		return 0
	}

	let dc = hdc as! DC
	let bmp = dc.hBitmap as! Bitmap
	let fb = dc.fb.ref
	if bmp == null and fb == null {
		kkernelDebugLog("> bmp and fb are null".utf16())
		kkernelDebugLog("> bmp: %8".utf16(), bmp as! UInt64)
		kkernelDebugLog("> fb: %8".utf16(), fb as! UInt64)
		return 0
	}

	// destination surface ------------------------------------------------------
	var dstBits ArrayPointer<UInt8> = null
	var dstRow Int32 = 0
	var dstBpp Int32 = 0
	var dstWidth Int32 = 0
	var dstHeight Int32 = 0
	if bmp != null {
		dstBits = bmp.bits
		dstRow = bmp.bytesPerRow
		dstBpp = bmp.bitsPerPixel as! Int32
		dstWidth = bmp.width as! Int32
		dstHeight = bmp.height as! Int32
	} else {
		dstBits = fb.pixels as! ArrayPointer<UInt8>
		dstRow = fb.width * 4i32
		dstBpp = 32
		dstWidth = fb.width as! Int32
		dstHeight = fb.height as! Int32
	}

	// For simplicity, assume dstBpp is 32; reject otherwise
	if dstBpp != 32 {
		kkernelDebugLog("> Destination bit depth is not 32".utf16())
		return 0
	}

	// source layout   -----------------------------------------------------------
	let srcRow = ((hdr.biWidth * hdr.biBitCount + 31) / 32) * 4
	let absH = hdr.biHeight < 0 ? -hdr.biHeight : hdr.biHeight
	let isTopDn = hdr.biHeight < 0

	// Validate source bounds
	if xSrc < 0 or xSrc + w > hdr.biWidth or startScan + scanLines > absH {
		kkernelDebugLog("> Invalid source coordinates or dimensions".utf16())
		return 0
	}

	// Validate destination bounds
	if xDest < 0 or xDest + w > dstWidth or yDest < 0 or yDest + scanLines > dstHeight {
		kkernelDebugLog("> Destination out of bounds".utf16())
		return 0
	}

	// Handle different bit depths ----------------------------------------------
	if hdr.biBitCount == 24 or hdr.biBitCount == 32 {
		let srcBpp = hdr.biBitCount / 8
		// Copy each requested scanline
		for dy in 0u32 ... scanLines {
			let srcY = startScan + dy
			if srcY >= absH { break }

			// Flip: bottom-up DIB -> top-down bitmap
			let realSrcY = isTopDn ? srcY : (absH - 1 - srcY)
			let srcOff = (realSrcY * srcRow + xSrc * srcBpp) as! Int

			let dstY = yDest + dy as! Int32
			let dstOff = (dstY * dstRow + xDest * 4) as! Int // dstBpp = 32

			// Copy one scanline, converting 24bpp to 32bpp if needed
			if srcBpp == 4 {
				memcpy(
					dstBits.offsetItemsBack(dstOff),
					bits.offsetItemsBack(srcOff),
					(w * 4) as! Int
				)
			} else if srcBpp == 3 {
				for dx in 0u32 ... w {
					let srcPixelOffset = srcOff + (dx * 3) as! Int
					let dstPixelOffset = dstOff + (dx * 4) as! Int
					dstBits[dstPixelOffset] = bits[srcPixelOffset] // Blue
					dstBits[dstPixelOffset + 1] = bits[srcPixelOffset + 1] // Green
					dstBits[dstPixelOffset + 2] = bits[srcPixelOffset + 2] // Red
					dstBits[dstPixelOffset + 3] = 255u8 // Alpha
				}
			}
		}
	} else if hdr.biBitCount == 4 {
		// Handle 4bpp with color table
		let numColors = (hdr.biClrUsed != 0) ? hdr.biClrUsed : 16u32 // 2^4 = 16
		let colorTable = bmi.bmiColors as! ArrayPointer<ByValue<RGBQUAD>>
		if colorTable == null or numColors == 0 {
			kkernelDebugLog("> Color table missing for 4-bit source".utf16())
			return 0
		}

		// Copy each requested scanline
		for dy in 0u32 ... scanLines {
			let srcY = startScan + dy
			if srcY >= absH { break }
			let realSrcY = isTopDn ? srcY : (absH - 1 - srcY)
			/* Ensure realSrcY is within bounds to prevent buffer overrun */
			if realSrcY >= absH {
				kkernelDebugLog("> realSrcY %u exceeds absH %u".utf16(), realSrcY as! UInt64, absH as! UInt64)
				continue
			}
			// `let srcRowStart = bits.offsetItemsBack(realSrcY * srcRow)`
			let dstY = yDest + dy as! Int32
			let dstOffset = (dstY * dstRow + xDest * 4) as! Int

			var srcRowForCopy: ConstArrayPointer<UInt8> = null

			// Determine the source scanline, handling the vertical flip for bottom-up DIBs.
			// This new logic correctly calculates the offset relative to the 'bits' pointer,
			// which points to a buffer containing exactly 'scanLines' of data.
			if isTopDn {
				// Top-down DIB: process scanlines in forward order.
				srcRowForCopy = bits.offsetItemsBack((dy * srcRow) as! Int)
			} else {
				// Bottom-up DIB: process scanlines in reverse order to flip the image.
				let srcRowIndex = scanLines - 1 - dy
				srcRowForCopy = bits.offsetItemsBack((srcRowIndex * srcRow) as! Int)
			}

			for dx in 0u32 ... w {
				let srcX = xSrc + dx as! Int32
				let byteOffset = (srcX / 2) as! Int
				/* Check byteOffset to prevent reading beyond row */
				if byteOffset >= srcRow {
					kkernelDebugLog("> Byte offset exceeds srcRow %d at srcX %d".utf16(),
						srcRow as! UInt64, srcX as! UInt64)
					continue
				}
				let isHighNibble = (srcX % 2) == 0
				let byte = srcRowForCopy[byteOffset]
				let index = if isHighNibble {(byte >> 4) & 0xF } else { byte & 0xF }
				let destPixelOffset = dstOffset + (dx * 4) as! Int
				if (index as! UInt32) < numColors {
					let color = colorTable[index as! Int].ref
					dstBits[destPixelOffset] = color.rgbBlue
					dstBits[destPixelOffset + 1] = color.rgbGreen
					dstBits[destPixelOffset + 2] = color.rgbRed
					dstBits[destPixelOffset + 3] = 255u8 // Alpha
				} else {
					// Invalid index: use black
					kkernelDebugLog("> Invalid color index at srcX %d, srcY %u".utf16(),
						srcX as! UInt64, srcY as! UInt64)
					dstBits[destPixelOffset] = 0u8
					dstBits[destPixelOffset + 1] = 0u8
					dstBits[destPixelOffset + 2] = 0u8
					dstBits[destPixelOffset + 3] = 255u8
				}
			}
		}
	} else {
		kkernelDebugLog("> Unsupported biBitCount %u".utf16(), hdr.biBitCount as! UInt64)
		return 0
	}

	// Copy each requested scanline --------------------------------------------

	/*for dy in 0u32 ... scanLines {
		let srcY = startScan + dy
		if srcY >= absH { break }

		// flip: bottom-up DIB -> top-down bitmap
		let realSrcY = isTopDn ? srcY : (absH - 1 - srcY)
		let srcOff = realSrcY * srcRow + xSrc * srcBpp

		let dstY = yDest + dy as! Int32
		let dstOff = dstY * dstRow + xDest * (dstBpp / 8)

		// copy one scanline
		memcpy(
			dstBits.offsetItemsBack(dstOff),
			bits.offsetItemsBack(srcOff),
			(w * srcBpp) as! Int
		)
	}*/
	// trigger lazy swap so we see something on screen
	// TODO do not do it when target is bitmap
	kosmos32FastSystemCall(TofitaSyscalls.LazySwap as! TofitaSyscalls, 0)

	kkernelDebugLog("setDIBitsToDevice completed for hdc %8".utf16(), hdc as! UInt64)
	return scanLines as! Int32
}

@dllExport('GetPrivateProfileIntW')
fun getPrivateProfileIntW(
	lpAppName ConstArrayPointer<ClangWideChar>,
	lpKeyName ConstArrayPointer<ClangWideChar>,
	nDefault Int32,
	lpFileName ConstArrayPointer<ClangWideChar>
) UInt32 {
	kkernelDebugLog("getPrivateProfileIntW called with lpAppName %S lpKeyName %S".utf16(), lpAppName as! UInt64, lpKeyName as! UInt64)
	return nDefault as! UInt32
}

@dllExport('GetPrivateProfileStringW')
fun getPrivateProfileStringW(
	lpAppName ConstArrayPointer<ClangWideChar>,
	lpKeyName ConstArrayPointer<ClangWideChar>,
	lpDefault ConstArrayPointer<ClangWideChar>,
	lpReturnedString ArrayPointer<ClangWideChar>,
	nSize UInt32,
	lpFileName ConstArrayPointer<ClangWideChar>
) Int32 {
	kkernelDebugLog("getPrivateProfileStringW called with lpAppName %S lpKeyName %S".utf16(), lpAppName as! UInt64, lpKeyName as! UInt64)
	lpReturnedString[0] = 0
	return 0
}

