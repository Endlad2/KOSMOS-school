// Purpose: Retrieves the current position in a device context
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/wingdi/nf-wingdi-getcurrentpositionex
@dllExport('GetCurrentPositionEx')
fun getCurrentPositionEx(hdc HDc, lppt Point) Bool32 {
	kkernelDebugLog("getCurrentPositionEx called with hdc %8, lppt %8".utf16(),
		hdc as! UInt64, lppt as! UInt64)

	let dc = hdc as! DC
	if dc == null or lppt == null {
		kkernelDebugLog("> Invalid DC or point pointer".utf16())
		return Bool32.False
	}

	lppt.x = dc.penPosX
	lppt.y = dc.penPosY
	kkernelDebugLog("> Current position: x %d, y %d".utf16(),
		dc.penPosX as! UInt64, dc.penPosY as! UInt64)
	return Bool32.True
}

// Purpose: Updates the current position in a device context
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/wingdi/nf-wingdi-movetoex
@dllExport('MoveToEx')
fun moveToEx(hdc HDc, x Int32, y Int32, lpptPoint Point?) Bool32 {
	// TODO Implement updating the current pen position stored within the DC structure.
	// 1. Get the DC structure for hdc.
	// 2. If lpptPoint is not null, store the DC's current pen position (e.g., dc.penPosX, dc.penPosY) in it.
	// 3. Update the DC's current pen position fields with x and y.
	// 4. Return success.
	kkernelDebugLog("moveToEx called on DC %8 with point %8".utf16(), hdc as! UInt64, lpptPoint as! UInt64)
	kkernelDebugLog("> x %d y %d".utf16(), x as! UInt64, y as! UInt64)
	// Placeholder: Needs DC implementation

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	// Validate DC has a drawing surface
	if dc.hBitmap == null and dc.fb.ref == null {
		kkernelDebugLog("> No drawing surface selected".utf16())
		return Bool32.False
	}

	// Store previous position if requested
	if let lpptPoint = lpptPoint {
		lpptPoint.x = dc.penPosX
		lpptPoint.y = dc.penPosY
	}

	// Update pen position for subsequent LineTo calls
	dc.penPosX = x
	dc.penPosY = y

	kkernelDebugLog("> Moved to (%d, %d)".utf16(), x as! UInt64, y as! UInt64)
	return Bool32.True // Assume success
}

@dllExport('PatBltTODO')
fun patBltTODO(hdc HDc, x Int32, y Int32, cx Int32, cy Int32, dwRop RasterOperation) Bool32 {
	kkernelDebugLog("patBlt called on DC %8, ROP %u".utf16(), hdc as! UInt64, dwRop as! UInt64)
	//// NOTE Hexa: `fillRect(hdc, rect, random(rand()) as! HBrush)` generates `called object type 'int32_t' (aka 'int') is not a function or function pointer`
	// fillRect(hdc, rect, randomize(rand() as! UInt32) as! HBrush)

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	// Only support PATCOPY
	if dwRop != RasterOperation.PatCopy {
		kkernelDebugLog("> Only PATCOPY supported".utf16())
		return Bool32.False
	}

	let brush = dc.hBrush as! Brush
	if brush == null or brush.pattern == null {
		kkernelDebugLog("> No valid pattern brush selected".utf16())
		return Bool32.False
	}

	let pattern = brush.pattern as! Bitmap
	if pattern == null or pattern.bits == null {
		kkernelDebugLog("> Invalid pattern bitmap".utf16())
		return Bool32.False
	}

	// Validate pattern is 8x8 monochrome
	if pattern.width != 8 or pattern.height != 8 or pattern.bitsPerPixel != 1i16 {
		kkernelDebugLog("> Pattern must be 8x8 monochrome".utf16())
		return Bool32.False
	}

	// Get destination surface
	// TODO implement as `@struct DestinationSurface {} DC.getDestinationSurface(ds)`
	var destBits ArrayPointer<UInt8> = null
	var destWidth Int32 = 0
	var destHeight Int32 = 0
	var destBytesPerRow Int32 = 0
	var isDestTopDown = true

	if let bmp = dc.hBitmap as! Bitmap {
		destBits = bmp.bits
		destWidth = bmp.width
		destHeight = bmp.height
		destBytesPerRow = bmp.bytesPerRow
		isDestTopDown = bmp.isTopDown
	} else {
		let fb = dc.fb.ref
		if fb.pixels == 0 {
			kkernelDebugLog("> No valid destination surface".utf16())
			return Bool32.False
		}
		destBits = fb.pixels as! ArrayPointer<UInt8>
		destWidth = fb.width as! Int32
		destHeight = fb.height as! Int32
		destBytesPerRow = fb.width * 4i32
	}

	// Validate bounds
	if x < 0 or y < 0 or cx <= 0 or cy <= 0 or x + cx > destWidth or y + cy > destHeight {
		kkernelDebugLog("> Invalid coordinates or dimensions".utf16())
		return Bool32.False
	}

	// Pattern is 1-bit, 8x8 pixels
	let patternWidth = pattern.width
	let patternHeight = pattern.height
	let patternBits = pattern.bits
	let patternBytesPerRow = pattern.bytesPerRow // Should be 4 for 8-pixel monochrome (4-byte aligned)

	// Get colors from DC
	let fgColor = dc.textColor // Maps to bit 1
	let bgColor = dc.bkColor // Maps to bit 0
	let brushOrgX = dc.brushOrgX
	let brushOrgY = dc.brushOrgY

	kkernelDebugLog("> brushOrgX %d brushOrgY %d".utf16(), brushOrgX as! UInt64, brushOrgY as! UInt64)
	kkernelDebugLog("> fgColor %8 bgColor %8".utf16(), fgColor as! UInt64, bgColor as! UInt64)

	// Apply pattern with brush origin relative to DC origin
	let bppDest = 32i16 // TODO
	let bppSrc = pattern.bitsPerPixel
	if (bppSrc == 8i16 or bppSrc == 32i16) and bppDest == 32i16 {
		for row in 0 ... cy - 1 {
			let destY = y + row
			// Pattern Y relative to brush origin, modulo for tiling
			let patternY = ((destY - brushOrgY) % patternHeight + patternHeight) % patternHeight
			let destRowOffset = (isDestTopDown ? destY : (destHeight - 1 - destY)) * destBytesPerRow

			for col in 0 ... cx - 1 {
				let destX = x + col
				// Pattern X relative to brush origin, modulo for tiling
				let patternX = ((destX - brushOrgX) % patternWidth + patternWidth) % patternWidth
				// Monochrome bitmap: 8 pixels per byte, MSB is leftmost pixel
				let byteIndex = patternY * patternBytesPerRow + (patternX / 8)
				let bitPosition = 7 - (patternX % 8) // MSB to LSB
				let bitMask = 0x80u8 >> bitPosition
				let pixelValue = (patternBits[byteIndex] & bitMask) != 0
				let color = pixelValue ? fgColor : bgColor

				let destOffset = destRowOffset + destX * 4
				let pixel = (destBits as! ArrayPointer<ByValue<Pixel32>>).offsetItemsBack(destOffset)
				pixel[0].ref.color = color
			}
		}
	} else if bppSrc == 1i16 and bppDest == 32i16 { // Add monochrome case
		kkernelDebugLog("> bppSrc == 1i16 and bppDest == 32i16".utf16())

		for row in 0 ... cy - 1 {
			let destY = y + row
			let patternY = ((destY - brushOrgY) % patternHeight + patternHeight) % patternHeight
			let patternY = (destY - brushOrgY) % patternHeight
			let destRowOffset = ((destY + row) * destBytesPerRow) as! Int

			for col in 0 ... cx - 1 {
				let destX = x + col
				let patternX = ((destX - brushOrgX) % patternWidth + patternWidth) % patternWidth
				let patternX = (destX - brushOrgX) % patternWidth
				let byteIndex = patternY * patternBytesPerRow + (patternX / 8)

				// CORRECTED BITMASK CALCULATION
				let bitPosition = patternX % 8
				let bitMask = 0x80u8 >> bitPosition // MSB at leftmost pixel

				let srcByte = patternBits[byteIndex]
				let pixelValue = (srcByte & bitMask) != 0
				let color = pixelValue ? fgColor : bgColor

				let destOffset = destRowOffset + destX * 4
				let destRowOffset = ((destY + row) * destBytesPerRow) as! Int
				let destRowOffset = (destY * destBytesPerRow) as! Int
				// destBits[destOffset] = color.rgbBlue
				// destBits[destOffset + 1] = color.rgbGreen
				// destBits[destOffset + 2] = color.rgbRed
				// destBits[destOffset + 3] = 255u8 // Alpha
				let pixel = (destBits as! ArrayPointer<ByValue<Pixel32>>).offsetItemsBack(destOffset)
				pixel[0].ref.color = color
			}
		}
	} else {
		kkernelDebugLog("> Unsupported bit depth".utf16())
		return Bool32.False
	}

	kkernelDebugLog("> PatBlt completed".utf16())
	return Bool32.True
}

@dllExport('PatBltTODOTODO')
fun patBltTODOTODO(hdc HDc, x Int32, y Int32, cx Int32, cy Int32, dwRop RasterOperation) Bool32 {
	kkernelDebugLog("patBlt called on DC %8, ROP %u".utf16(), hdc as! UInt64, dwRop as! UInt64)

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	if dwRop != RasterOperation.PatCopy {
		kkernelDebugLog("> Only PATCOPY supported".utf16())
		return Bool32.False
	}

	let brush = dc.hBrush as! Brush
	if brush == null or brush.pattern == null {
		kkernelDebugLog("> No valid pattern brush selected".utf16())
		return Bool32.False
	}

	let pattern = brush.pattern as! Bitmap
	if pattern == null or pattern.bits == null {
		kkernelDebugLog("> Invalid pattern bitmap".utf16())
		return Bool32.False
	}

	if pattern.width != 8 or pattern.height != 8 or pattern.bitsPerPixel != 1i16 {
		kkernelDebugLog("> Pattern must be 8x8 monochrome".utf16())
		return Bool32.False
	}

	var destBits ArrayPointer<UInt8> = null
	var destWidth Int32 = 0
	var destHeight Int32 = 0
	var destBytesPerRow Int32 = 0
	var isDestTopDown = true

	if let bmp = dc.hBitmap as! Bitmap {
		destBits = bmp.bits
		destWidth = bmp.width
		destHeight = bmp.height
		destBytesPerRow = bmp.bytesPerRow
		isDestTopDown = bmp.isTopDown
	} else {
		let fb = dc.fb.ref
		if fb.pixels == 0 {
			kkernelDebugLog("> No valid destination surface".utf16())
			return Bool32.False
		}
		destBits = fb.pixels as! ArrayPointer<UInt8>
		destWidth = fb.width as! Int32
		destHeight = fb.height as! Int32
		destBytesPerRow = fb.width * 4i32
	}

	if x < 0 or y < 0 or cx <= 0 or cy <= 0 or x + cx > destWidth or y + cy > destHeight {
		kkernelDebugLog("> Invalid coordinates or dimensions".utf16())
		return Bool32.False
	}

	let patternWidth = pattern.width
	let patternHeight = pattern.height
	let patternBits = pattern.bits
	let patternBytesPerRow = (patternWidth + 7) / 8 // 1 byte per row for 8 pixels at 1 bpp

	let fgColor = dc.textColor
	let bgColor = dc.bkColor
	let brushOrgX = dc.brushOrgX
	let brushOrgY = dc.brushOrgY

	// Apply pattern
	kkernelDebugLog("> brushOrgX %d brushOrgY %d".utf16(), brushOrgX as! UInt64, brushOrgY as! UInt64)
	kkernelDebugLog("> fgColor %8 bgColor %8".utf16(), fgColor as! UInt64, bgColor as! UInt64)

	for row in 0 ... cy - 1 {
		let destY = y + row
		let patternY = ((destY - brushOrgY) % patternHeight + patternHeight) % patternHeight
		let destRowOffset = (isDestTopDown ? destY : (destHeight - 1 - destY)) * destBytesPerRow

		for col in 0 ... cx - 1 {
			let destX = x + col
			let patternX = ((destX - brushOrgX) % patternWidth + patternWidth) % patternWidth
			let byteIndex = patternY * patternBytesPerRow + (patternX / 8)
			let bitPosition = 7 - (patternX % 8)
			let bitMask = 0x80u8 >> bitPosition
			let pixelValue = (patternBits[byteIndex] & bitMask) != 0
			let color = pixelValue ? fgColor : bgColor

			let destOffset = destRowOffset + destX * 4
			let pixel = (destBits as! ArrayPointer<ByValue<Pixel32>>).offsetItemsBack(destOffset)
			pixel[0].ref.color = color
		}
	}

	kkernelDebugLog("> PatBlt completed".utf16())
	return Bool32.True
}

@dllExport('CreateBitmap')
fun createBitmap(nWidth Int32, nHeight Int32, nPlanes UInt32, nBitCount UInt32, lpBits ConstArrayPointer<UInt8>?) HBitmap {
	kkernelDebugLog("createBitmap called with nWidth %d nHeight %d".utf16(), nWidth as! UInt64, nHeight as! UInt64)
	kkernelDebugLog("> nPlanes %u nBitCount %u".utf16(), nPlanes as! UInt64, nBitCount as! UInt64)
	kkernelDebugLog("> lpBits %p".utf16(), lpBits as! UInt64)

	if nWidth <= 0 or nHeight <= 0 {
		kkernelDebugLog("createBitmap: invalid dimensions (width: %d, height: %d)".utf16(), nWidth as! UInt64, nHeight as! UInt64)
		return null
	}
	if nPlanes != 1 {
		kkernelDebugLog("createBitmap: nPlanes must be 1, got %u".utf16(), nPlanes as! UInt64)
		return null
	}
	if nBitCount != 1 and nBitCount != 4 and nBitCount != 8 and nBitCount != 16 and nBitCount != 24 and nBitCount != 32 {
		kkernelDebugLog("createBitmap: unsupported bit depth %u".utf16(), nBitCount as! UInt64)
		return null
	}

	let bitmap = @heap new Bitmap()
	bitmap.width = nWidth
	bitmap.height = nHeight
	bitmap.bitsPerPixel = nBitCount as! Int16
	bitmap.isTopDown = true

	// Calculate bytes per row (tightly packed for monochrome, DWORD-aligned for others)
	let bitsPerRow = nWidth * (nBitCount as! Int32)
	let bytesPerRow = if nBitCount == 1 {
		(bitsPerRow + 7) / 8 // For 1 bpp, pack tightly: 8 pixels per byte
	} else {
		((bitsPerRow + 31) / 32) * 4 // DWORD-aligned for other bit depths
	}
	bitmap.bytesPerRow = bytesPerRow
	let totalSize = bytesPerRow * nHeight

	bitmap.bits = malloc(totalSize as! UInt64) as! ArrayPointer<UInt8>
	if bitmap.bits == null {
		kkernelDebugLog("createBitmap: failed to allocate memory for bitmap.bits (%d bytes)".utf16(), totalSize as! UInt64)
		free(bitmap as! RuntimeAllocated)
		return null
	}

	kkernelDebugLog("> Allocated %d bytes for bitmap.bits at %p".utf16(), totalSize as! UInt64, bitmap.bits as! UInt64)

	if nBitCount <= 8 {
		let numColors = 1u32 << nBitCount
		bitmap.colorTableSize = numColors
		bitmap.colorTable = malloc(numColors * sizeOf<RGBQUAD>() as! UInt64) as! ArrayPointer<ByValue<RGBQUAD>>
		if bitmap.colorTable == null {
			kkernelDebugLog("createBitmap: failed to allocate memory for color table".utf16())
			free(bitmap.bits as! RuntimeAllocated)
			free(bitmap as! RuntimeAllocated)
			return null
		}

		if nBitCount == 1 {
			bitmap.colorTable[0].ref.rgbBlue = 0u8
			bitmap.colorTable[0].ref.rgbGreen = 0u8
			bitmap.colorTable[0].ref.rgbRed = 0u8
			bitmap.colorTable[0].ref.rgbReserved = 0u8
			bitmap.colorTable[1].ref.rgbBlue = 255u8
			bitmap.colorTable[1].ref.rgbGreen = 255u8
			bitmap.colorTable[1].ref.rgbRed = 255u8
			bitmap.colorTable[1].ref.rgbReserved = 0u8
		} else {
			for i in 0u32 ... numColors {
				let value = (i * 255 / (numColors)) as! UInt8
				bitmap.colorTable[i].ref.rgbRed = value
				bitmap.colorTable[i].ref.rgbGreen = value
				bitmap.colorTable[i].ref.rgbBlue = value
				bitmap.colorTable[i].ref.rgbReserved = 0u8
			}
		}
		kkernelDebugLog("> Initialized color table for %u-bit bitmap with %u entries.".utf16(), nBitCount as! UInt64, numColors as! UInt64)
	} else {
		bitmap.colorTable = null
		bitmap.colorTableSize = 0u32
	}

	if let lpBits = lpBits {
		kkernelDebugLog("> lpBits is provided (%p), copying data.".utf16(), lpBits as! UInt64)

		if nBitCount == 1 {
			// Special handling for 1-bit bitmaps - input data is WORD-aligned
			let srcWordsPerRow = (nWidth + 15) / 16 // Number of WORDs per row in source
			let srcBytesPerRow = srcWordsPerRow * 2 // Convert to bytes

			// Initialize to zero first
			memset(bitmap.bits, 0x00, totalSize as! SizeOfPointer)

			for y in nHeight {
				let destRowStart = bitmap.bits.offsetItemsBack(y * bytesPerRow)
				let srcRowStart = lpBits.offsetItemsBack(y * srcBytesPerRow)

				// Process each pixel in the row
				for x in nWidth {
					// Calculate which WORD contains this pixel
					let wordIdx = x / 16
					let bitInWord = x % 16

					// Read the WORD containing this pixel (little-endian)
					let srcWordOffset = wordIdx * 2
					let lowByte = srcRowStart[srcWordOffset]
					let highByte = srcRowStart[srcWordOffset + 1]
					let srcWord = (lowByte as! UInt16) << 8 | (highByte as! UInt16)

					// Extract the bit for this pixel (bit 0 is rightmost/LSB)
					let srcBit = (srcWord >> (15i32 - bitInWord)) & 1

					// Set the corresponding bit in destination
					// In destination: MSB is leftmost pixel in each byte
					let destByteIdx = x / 8
					let destBitIdx = 7 - (x % 8)

					if srcBit != 0 {
						destRowStart[destByteIdx] |= (1u8 << destBitIdx) as! UInt8
					}
				}
			}
		} else {
			// For non-1-bit formats, use existing logic
			let srcBytesPerScanlineActualData = (nWidth * (nBitCount as! Int32) + 7) / 8
			let srcScanlineStride = ((nWidth * (nBitCount as! Int32) + 15) / 16) * 2

			kkernelDebugLog("> srcBytesPerScanlineActualData: %d, srcScanlineStride (WORD-aligned): %d".utf16(), srcBytesPerScanlineActualData as! UInt64, srcScanlineStride as! UInt64)
			kkernelDebugLog("> dest bytesPerRow: %d".utf16(), bytesPerRow as! UInt64)

			// Initialize to zero to avoid garbage in unused bytes
			memset(bitmap.bits, 0x00, totalSize as! SizeOfPointer)

			for y in nHeight {
				let destRowStartPtr = bitmap.bits.offsetItemsBack(y * bytesPerRow)
				let srcRowStartPtr = lpBits.offsetItemsBack(y * srcScanlineStride)
				memcpy(destRowStartPtr, srcRowStartPtr, srcBytesPerScanlineActualData as! Int)
			}
		}

		kkernelDebugLog("> Copied data from lpBits to bitmap.bits row by row.".utf16())
	} else {
		kkernelDebugLog("> lpBits is null, initializing bitmap.bits to white.".utf16())
		memset(bitmap.bits, 0xFF, totalSize as! SizeOfPointer)
	}

	kkernelDebugLog("createBitmap: successfully created bitmap %p".utf16(), bitmap as! UInt64)
	return bitmap as! HBitmap
}

@dllExport('PatBlt')
fun patBlt(hdc HDc, x Int32, y Int32, cx Int32, cy Int32, dwRop RasterOperation) Bool32 {
	kkernelDebugLog("patBlt called on DC %8, ROP %u".utf16(), hdc as! UInt64, dwRop as! UInt64)

	let dc = hdc as! DC
	if dc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return Bool32.False
	}

	if dwRop != RasterOperation.PatCopy {
		kkernelDebugLog("> Only PATCOPY supported".utf16())
		return Bool32.False
	}

	let brush = dc.hBrush as! Brush
	if brush == null or brush.pattern == null {
		kkernelDebugLog("> No valid pattern brush selected".utf16())
		return Bool32.False
	}

	let pattern = brush.pattern as! Bitmap
	if pattern == null or pattern.bits == null {
		kkernelDebugLog("> Invalid pattern bitmap".utf16())
		return Bool32.False
	}

	if pattern.width != 8 or pattern.height != 8 or pattern.bitsPerPixel != 1i16 {
		kkernelDebugLog("> Pattern must be 8x8 monochrome".utf16())
		return Bool32.False
	}

	var destBits ArrayPointer<UInt8> = null
	var destWidth Int32 = 0
	var destHeight Int32 = 0
	var destBytesPerRow Int32 = 0
	var isDestTopDown = true

	if let bmp = dc.hBitmap as! Bitmap {
		destBits = bmp.bits
		destWidth = bmp.width
		destHeight = bmp.height
		destBytesPerRow = bmp.bytesPerRow
		isDestTopDown = bmp.isTopDown
	} else {
		let fb = dc.fb.ref
		if fb.pixels == 0 {
			kkernelDebugLog("> No valid destination surface".utf16())
			return Bool32.False
		}
		destBits = fb.pixels as! ArrayPointer<UInt8>
		destWidth = fb.width as! Int32
		destHeight = fb.height as! Int32
		destBytesPerRow = fb.width * 4i32
	}

	if x < 0 or y < 0 or cx <= 0 or cy <= 0 or x + cx > destWidth or y + cy > destHeight {
		kkernelDebugLog("> Invalid coordinates or dimensions".utf16())
		return Bool32.False
	}

	let patternWidth = pattern.width
	let patternHeight = pattern.height
	let patternBits = pattern.bits
	let patternBytesPerRow = (patternWidth + 7) / 8 // 1 byte per row for 8 pixels at 1 bpp

	let fgColor = dc.textColor
	let bgColor = dc.bkColor
	let brushOrgX = dc.brushOrgX
	let brushOrgY = dc.brushOrgY

	kkernelDebugLog("> brushOrgX %d brushOrgY %d".utf16(), brushOrgX as! UInt64, brushOrgY as! UInt64)
	kkernelDebugLog("> fgColor %8 bgColor %8".utf16(), fgColor as! UInt64, bgColor as! UInt64)

	/* TODO
		For a truly universal approach, you should:

		Process byte-by-byte instead of word-by-word
		Use standard bitmap alignment (DWORD-aligned scanlines)
		Handle arbitrary widths without assuming 16-bit word boundaries

		The universal bit indexing formula is:

		Within a byte: 7 - (x % 8) for MSB-first bit ordering
		Within a word: 15 - (x % 16) for MSB-first bit ordering
		Within a dword: 31 - (x % 32) for MSB-first bit ordering

		Recommendation: Replace your current word-based approach with the byte-based universal approach shown in the artifact. This will:

		Work with bitmaps of any width
		Follow standard Windows bitmap format conventions
		Be more maintainable and less error-prone
		Handle edge cases better (like 7-pixel wide patterns)
	*/
	for row in cy {
		let destY = y + row
		// Calculate pattern Y coordinate relative to brush origin
		let patternY = (destY - brushOrgY) % patternHeight
		let patternY = if patternY < 0 { patternY + patternHeight } else { patternY }

		let destRowOffset = (isDestTopDown ? destY : (destHeight - 1 - destY)) * destBytesPerRow

		for col in cx {
			let destX = x + col
			// Calculate pattern X coordinate relative to brush origin
			let patternX = (destX - brushOrgX) % patternWidth
			let patternX = if patternX < 0 { patternX + patternWidth } else { patternX }

			// Get the byte containing this pixel in the pattern
			let byteIndex = patternY * patternBytesPerRow + (patternX / 8)
			// Calculate bit position within the byte (MSB is leftmost pixel)
			let bitPosition = 7 - (patternX % 8)
			let bitMask = 0x01i32 << bitPosition
			let pixelValue = (patternBits[byteIndex] & bitMask) != 0
			let color = if pixelValue { fgColor } else { bgColor }

			let destOffset = destRowOffset + destX * 4
			// TODO renaming to `offsetByElements` may be less error prone
			// let pixel = (destBits as! ArrayPointer<ByValue<Pixel32>>).offsetItemsBack(destOffset)
			let pixel = (destBits as! ArrayPointer<UInt8>).offsetItemsBack(destOffset)
			let pixel = pixel as! ArrayPointer<ByValue<Pixel32>>
			pixel[0].ref.color = color
		}
	}

	kkernelDebugLog("> PatBlt completed".utf16())
	return Bool32.True
}

