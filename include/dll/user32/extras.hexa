let defaultDC DC = DC()

@dllExport('GetDC')
fun getDC(hWnd HWnd?) HDc {
	// TODO Retrieve device context
	kkernelDebugLog("getDC called with hWnd %8".utf16(), hWnd as! UInt64)
	var window = handleToWindow(hWnd)
	if window == null {
		kkernelDebugLog("getDC returned defaultDC %8".utf16(), defaultDC as! UInt64)
		return defaultDC as! HDc
	}

	// TODO Share `fb` by reference, not by value
	while window.parent != null {
		window = window.parent
	}

	let dc = window.dc
	let fb = dc.fb.ref
	njraaGetOrCreateWindowFramebuffer(fb)

	kkernelDebugLog("getDC returned window.dc.ref %8".utf16(), window.dc as! UInt64)
	return window.dc as! HDc
}

