@dllExport('CreatePenIndirect')
fun createPenIndirect(lplgpn LogPen) HPen {
	kkernelDebugLog("createPenIndirect called with lopnStyle %u=".utf16(), lplgpn.lopnStyle as! UInt64)
	kkernelDebugLog("> width %d, color %u".utf16(), lplgpn.lopnWidth.ref.x as! UInt64, lplgpn.lopnColor as! UInt64)

	let pen = @heap new Pen()
	pen.style = lplgpn.lopnStyle as! Int32
	pen.width = lplgpn.lopnWidth.ref.x
	pen.color = lplgpn.lopnColor

	kkernelDebugLog("> Created pen %8".utf16(), pen as! UInt64)
	return pen as! HPen
}

@dllExport('CreatePatternBrush')
fun createPatternBrush(hbmp HBitmap) HBrush {
	// TODO Create brush from bitmap pattern
	kkernelDebugLog("createPatternBrush called with hbmp %8".utf16(), hbmp as! UInt64)

	let bitmap = hbmp as! Bitmap
	if bitmap == null {
		kkernelDebugLog("> Invalid bitmap".utf16())
		return null
	}

	// Validate bitmap for pattern (8x8 monochrome typical for checkered)
	if bitmap.bitsPerPixel != 1i16 {
		kkernelDebugLog("> Only monochrome bitmaps supported".utf16())
		return null
	}

	let brush = @heap new Brush()
	brush.pattern = hbmp
	kkernelDebugLog("> Created brush %8".utf16(), brush as! UInt64)
	return brush as! HBrush
}

