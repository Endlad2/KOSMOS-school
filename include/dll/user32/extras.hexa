// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-mapwindowpoints
@dllExport('MapWindowPoints')
fun mapWindowPoints(hWndFrom HWnd, hWndTo HWnd, lpPoints ArrayPointer<ByValue<Point>>, cPoints UInt32) Int32 {
	// TODO currently we pass window-coordinates in Tofita, not screen ones
	return cPoints as! Int32

	// TODO make proper logging
	kkernelDebugLog("mapWindowPoints called with hWndFrom %8 hWndTo %8".utf16(),
		hWndFrom as! UInt64, hWndTo as! UInt64)

	if lpPoints == null or cPoints == 0 {
		kkernelDebugLog("> Invalid lpPoints or cPoints".utf16())
		return 0
	}

	/* Retrieve window structures, traversing to top-level parent as in GetDC/ReleaseDC */
	var fromWindow = handleToWindow(hWndFrom)
	while fromWindow != null and fromWindow.parent != null {
		fromWindow = fromWindow.parent
	}

	var toWindow = handleToWindow(hWndTo)
	while toWindow != null and toWindow.parent != null {
		toWindow = toWindow.parent
	}

	/* Determine coordinate offsets: screen coordinates if window is null */
	let fromX = if fromWindow == null { 0 } else { fromWindow.x }
	let fromY = if fromWindow == null { 0 } else { fromWindow.y }
	let toX = if toWindow == null { 0 } else { toWindow.x }
	let toY = if toWindow == null { 0 } else { toWindow.y }

	// TODO currently we pass window-coordinates in Tofita, not screen ones
	let fromX = 0
	let fromY = 0
	let toX = 0
	let toY = 0

	/* Calculate relative offset: from source window to target window */
	let offsetX = toX - fromX
	let offsetY = toY - fromY
	kkernelDebugLog("> Mapping offset: x %d, y %d".utf16(), offsetX as! UInt64, offsetY as! UInt64)

	/* If exactly two points are passed, treat them as a RECT and swap left/right if needed */
	if cPoints == 2 {
		let left = lpPoints[0].ref.x
		let top = lpPoints[0].ref.y
		let right = lpPoints[1].ref.x
		let bottom = lpPoints[1].ref.y

		lpPoints[0].ref.x = left + offsetX
		lpPoints[0].ref.y = top + offsetY
		lpPoints[1].ref.x = right + offsetX
		lpPoints[1].ref.y = bottom + offsetY

		/* Ensure left <= right after mapping */
		if lpPoints[0].ref.x > lpPoints[1].ref.x {
			let swap = lpPoints[0].ref.x
			lpPoints[0].ref.x = lpPoints[1].ref.x
			lpPoints[1].ref.x = swap
		}
	} else {
		/* Transform each point in the array */
		for i in cPoints {
			lpPoints[i].ref.x += offsetX
			lpPoints[i].ref.y += offsetY
		}
	}

	/* Return number of points processed, per Win32 spec */
	kkernelDebugLog("> Mapped %u points".utf16(), cPoints as! UInt64)
	return cPoints as! Int32
}

