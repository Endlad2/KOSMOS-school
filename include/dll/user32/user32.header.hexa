// TODO move out of header
// Purpose: Sets the coordinates of a rectangle
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-setrect
@dllExport('SetRect')
fun setRect(
	lprc Rect?, // LPRECT -> Pointer to ClangRect
	xLeft Int, // int -> Int // TODO remove -> comments
	yTop Int, // int -> Int
	xRight Int, // int -> Int
	yBottom Int // int -> Int
) Bool32 // BOOL -> Bool (return type)
{
	kkernelDebugLog("setRect called with lprc %8".utf16(), lprc as! UInt64)
	kkernelDebugLog("> left %d top %d".utf16(), xLeft as! UInt64, yTop as! UInt64)
	kkernelDebugLog("> right %d bottom %d".utf16(), xRight as! UInt64, yBottom as! UInt64)
	if let rc = lprc {
		rc.left = xLeft
		rc.top = yTop
		rc.right = xRight
		rc.bottom = yBottom
		return Bool32.True
	}

	return Bool32.False
}

fun monitorFromWindow(
	hwnd HWnd, // HWND -> Pointer to ClangWindow (window handle)
	dwFlags UInt32 // DWORD -> UInt32
