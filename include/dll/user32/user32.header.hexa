}

@dllExport('GetMonitorInfoW')
fun getMonitorInfoW(
	hMonitor HMonitor, // `HMONITOR` -> Pointer to ClangMonitor (monitor handle)
	lpmi MonitorInfo // `LPMONITORINFO` -> Pointer to ClangMonitorInfo (output structure)
) Bool32 // `BOOL` -> Bool (return type)
{
	kkernelDebugLog("getMonitorInfoW called".utf16())
	lpmi.rcWork.ref.left = 0
	lpmi.rcWork.ref.top = 0
	lpmi.rcWork.ref.right = 1920
	lpmi.rcWork.ref.bottom = 1040 // TODO Work area (excludes taskbar; taskbar is 40px tall at bottom)
	lpmi.rcMonitor.ref.left = 0
	lpmi.rcMonitor.ref.top = 0
	lpmi.rcMonitor.ref.right = 1920
	lpmi.rcMonitor.ref.bottom = 1080
	lpmi.dwFlags = 0x00000001 // `MONITORINFOF_PRIMARY`
	// TODO mi.szDevice = L"\\.\DISPLAY1" // Device name for the monitor (null-terminated string)
	// TODO Size of the structure (40 for `MONITORINFO`, 72 for `MONITORINFOEXW`)
	return Bool32.True
}

