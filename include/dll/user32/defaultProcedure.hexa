fun ntUserGetDialogInfo(hwnd HWnd) ArrayPointer<Void> {
	kkernelDebugLog("ntUserGetDialogInfo called".utf16())
	return null // TODO
}

fun ntUserSetDialogInfo(hwnd HWnd, dlgInfo ArrayPointer<Void>) Void {
	kkernelDebugLog("ntUserSetDialogInfo called".utf16())
	// TODO
}

fun dialog_get_info(hwnd HWnd, create Bool32) DIALOGINFO {
	kkernelDebugLog("dialog_get_info called".utf16())
	var dlgInfo DIALOGINFO = null
	dlgInfo = ntUserGetDialogInfo(hwnd) as! DIALOGINFO

	if dlgInfo == null and create == Bool32.True {
		// TODO Hexa: yeah assignment-as-expression is confusing, does Go allow it?
		// TODO Hexa: `sizeof(*dlgInfo)` converted into `sizeof(*dlgInfo)` instead of `sizeOf<DIALOGINFO>()`
		if (dlgInfo = heapAlloc(getProcessHeap(), 0, sizeOf<DIALOGINFO>() as! UInt32) as! DIALOGINFO) == null {
			kkernelDebugLog("dialog_get_info allocation failed".utf16())
			return null
		}

		dlgInfo.hwndFocus = null
		dlgInfo.hUserFont = null
		dlgInfo.hMenu = null
		dlgInfo.xBaseUnit = 4 // TODO should be `0`
		dlgInfo.yBaseUnit = 8 // TODO should be `0`
		dlgInfo.idResult = 1 // TODO `IDOK`
		dlgInfo.flags = 0
		ntUserSetDialogInfo(hwnd, dlgInfo as! ArrayPointer<Void>)
		kkernelDebugLog("dialog_get_info created".utf16())
	}

	return dlgInfo
}
