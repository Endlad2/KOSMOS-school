// Purpose: Returns the length of a null-terminated Unicode string
// Win32 Spec: https://learn.microsoft.com/en-us/windows/win32/api/winbase/nf-winbase-lstrlenw
@dllExport('lstrlenW')
@inline fun lstrlenW(str ConstArrayPointer<ClangWideChar>) Int {
	// const WCHAR *s = str;
	// while (*s) s++;
	// return s - str;
	var i = 0
	while str[i] != 0 as! ClangWideChar {
		i++
	}

	kkernelDebugLog("lstrlenW '%S' %d".utf16(), str as! UInt64, i as! UInt64)
	return i
}

