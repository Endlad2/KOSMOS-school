@dllExport('MoveWindow')
fun moveWindow(hwnd HWnd, x Int32, y Int32, width Int32, height Int32, repaint Bool32) Bool32 {
	// TODO change position too
	kkernelDebugLog("moveWindow called w %d h %d".utf16(), width as! UInt32, height as! UInt32)
	kkernelDebugLog("> x %d y %d".utf16(), x as! UInt32, y as! UInt32)

	if let window = handleToWindow(hwnd), window.width != width or window.height != height {
		window.x = x
		window.y = y
		window.width = width
		window.height = height
		kkernelDebugLog("> triggering WM_SIZE".utf16())

		// 1 x 0
		// TODO check `windowId != 0` i.e. overlapped and non-desktop?
		let payload = ShowWindowPayload()
		payload.windowId = window.windowId
		payload.nCmdShow = CmdShow.SW_UNCHANGED
		payload.x = -1 // TODO window.x
		payload.y = -1 // TODO window.y
		payload.width = window.width
		payload.height = window.height
		tofitaShowWindow(payload)

		let lParam = LParam.makeULong(window.width as! UInt16, window.height as! UInt16) as! LParam
		sendMessageW(hwnd, Message.WM_SIZE, null, lParam)
	}

	if repaint != Bool32.False {
		updateWindow(hwnd)
	}

	return Bool32.False
}

