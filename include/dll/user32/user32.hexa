		fb.width = bitmap.width as! UInt32
		fb.height = bitmap.height as! UInt32
	}

	if bitmap != null { return 1 }

	// Get brush properties
	let brushObj = brush as! Brush
	if brushObj == null {
		kkernelDebugLog("> Invalid brush".utf16())
		return 0
	}

	let color = ByValue<Pixel32>()
	// TODO by val
	color.ref.color = 0xFFE1E1E1u32 // TODO brush
	if brush as! Int != 7 {
		color.ref.color = 0xFFF0F0F0u32 // TODO brush
		color.ref.color = brush as! UInt32 // TODO brush
		if brush as! Int == 0 {
			color.ref.color = randomize(rand() as! UInt32)
		}

		color.ref.color = brushObj.color
	}

	for y in lprc.top ... lprc.bottom {
		for x in lprc.left ... lprc.right {
			// color.ref.color = (x * 256) + (y ^ x) + (y * 255 * 255) + 0u32
			// color.ref.color = color.ref.color ^(lprc as! UInt32) ^(dc as! UInt32)
			// TODO format
			// TODO respect brush color/style
			setFramebufferPixel(fb, x, y, color)
			// TODO ^ this can be unsafe write, cause within bounds

			// TODO this is for demo purposes and to check frame buffer size
			// if (x == 0 or y == 0 or y == lprc.bottom - 1 or x == lprc.right - 1) {
			// color.ref.color = 0x00AA0000
			// setFramebufferPixel(fb, x, y, color)
			// }
		}
	}

	kkernelDebugLog("> FillRect done".utf16())
	return 1
}

@dllExport('FillRect')
fun fillRect(hdc HDc, lprc Rect, brush HBrush) Int32 {
	// Validate device context
	if hdc == null {
		kkernelDebugLog("> Invalid DC".utf16())
		return 0
	}

	let dc = hdc as! DC
	let fb = dc.fb // Copy
	let fb = fb.ref

	let rect = ByValue<Rect>() // Copy cause we will modify it for clipping
	rect.ref.left = lprc.left
	rect.ref.top = lprc.top
	rect.ref.right = lprc.right
	rect.ref.bottom = lprc.bottom
	let lprc = rect.ref

	// Determine destination surface (framebuffer or bitmap)
	var destBits = null
	var destWidth = fb.width as! Int32
	var destHeight = fb.height as! Int32
	var destBytesPerRow = fb.width * 4u32 as! Int32

	let bitmap = dc.hBitmap as! Bitmap
	if bitmap != null {
		kkernelDebugLog("> Using bitmap".utf16())
		destBits = bitmap.bits as! ArrayPointer<UInt8>
		destWidth = bitmap.width
		destHeight = bitmap.height
		destBytesPerRow = bitmap.bytesPerRow

		if bitmap.bitsPerPixel != 32 {
			kkernelDebugLog("> Invalid bits per pixel".utf16())
			return 0
		}

		fb.pixels = destBits as! UInt64
		fb.width = destWidth as! UInt32
		fb.height = destHeight as! UInt32
	} else {
		destBits = fb.pixels as! ArrayPointer<UInt8>
	}

	// Validate rectangle bounds
	if lprc.left < 0 or lprc.top < 0 or lprc.right <= lprc.left or lprc.bottom <= lprc.top
		or lprc.right > destWidth or lprc.bottom > destHeight {
		kkernelDebugLog("> Invalid rectangle dimensions".utf16())
		lprc.left = max(lprc.left, 0)
		lprc.top = max(lprc.top, 0)

		// TODO weird stuff maybe assumed `width` in begin paint?
		if lprc.right <= lprc.left or lprc.bottom <= lprc.top {
			lprc.right += lprc.left
			lprc.bottom += lprc.top
		}

		// lprc.right = min(lprc.right, destWidth) // TODO need helper method to set `width` cause `right` != `width`
		// lprc.bottom = min(lprc.bottom, destHeight)
		kkernelDebugLog("> Clipped rectangle dimensions: left %d top %d".utf16(), lprc.left as! UInt64, lprc.top as! UInt64)
		kkernelDebugLog("> right %d bottom %d".utf16(), lprc.right as! UInt64, lprc.bottom as! UInt64)
		// TODO `return 0` just clip
	}

	// Get brush properties
	let brushObj = brush as! Brush
	if brushObj == null {
		kkernelDebugLog("> Invalid brush".utf16())
		return 0
	}

	let defaultBrush = (brushObj as! UInt64) < 4096

	let color = ByValue<Pixel32>()
	color.ref.color = 0xFFE1E1E1u32
	if not defaultBrush {
		color.ref.color = brushObj.color
	}

	let noPattern = defaultBrush or (brushObj.pattern == null)

	if noPattern {
		// Solid brush: use brush color
		kkernelDebugLog("> Solid brush color %8".utf16(), color.ref.color as! UInt32)
		for y in lprc.top ... lprc.bottom {
			for x in lprc.left ... lprc.right {
				setFramebufferPixel(fb, x, y, color)
			}
		}
	} else {
		// Pattern brush: use pattern bitmap with dc.textColor and dc.bkColor
		let pattern = brushObj.pattern as! Bitmap
		if pattern == null or pattern.width != 8 or pattern.height != 8 or pattern.bitsPerPixel != 1i16 {
			kkernelDebugLog("> Invalid pattern bitmap".utf16())
			return 0
		}
		let patternBits = pattern.bits as! ArrayPointer<UInt8>
		let patternBytesPerRow = pattern.bytesPerRow // Typically 4 for 8x8 monochrome
		let fgColor = ByValue<Pixel32>()
		fgColor.ref.color = dc.textColor // Foreground for bit 1
		let bgColor = ByValue<Pixel32>()
		bgColor.ref.color = dc.bkColor // Background for bit 0
		let brushOrgX = dc.brushOrgX
		let brushOrgY = dc.brushOrgY

		/*kkernelDebugLog("> Pattern brush: fgColor %08x bgColor %08x brushOrgX %d brushOrgY %d".utf16(),
			fgColor.ref.color as! UInt32, bgColor.ref.color as! UInt32,
			brushOrgX as! Int32, brushOrgY as! Int32)*/
		for y in lprc.top ... lprc.bottom {
			let destY = y as! Int32
			let patternY = ((destY - brushOrgY) % 8 + 8) % 8
			for x in lprc.left ... lprc.right {
				let destX = x as! Int32
				let patternX = ((destX - brushOrgX) % 8 + 8) % 8
				let byteIndex = patternY * patternBytesPerRow + (patternX / 8)
				let bitPosition = 7 - (patternX % 8) // MSB is leftmost
				let bitMask = 0x80u8 >> bitPosition
				let pixelValue = (patternBits[byteIndex] & bitMask) != 0
				let pixelColor = pixelValue ? fgColor : bgColor
				setFramebufferPixel(fb, x, y, pixelColor)
			}
		}
	}

	kkernelDebugLog("> FillRect done".utf16())
	return 1
}

@dllExport('EndPaint')
fun endPaint(hWnd HWnd, ps PaintStruct) Bool32 {
	// TODO respect ps
	kkernelDebugLog("endPaint called with hWnd %8 lpps %8".utf16(), hWnd as! UInt64, ps as! UInt64)
	// TODO `?? return 0` (hardcoded `return\throw` for now)
	var window = handleToWindow(hWnd)
	if window == null {
		return Bool32.False
	}

	// TODO unify this somehow, into function/method or logically
	while window.parent != null {
		window = window.parent
	}

	let dc = window.dc
	if dc == null {
		return Bool32.False
	}
	let fb = dc.fb.ref
	njraaSwapWindowFramebuffer(fb)
	// TODO ^ could be there multiple End Paint event? Probably swap after primary WM_PAINT
	kkernelDebugLog("> EndPaint done".utf16())
	// TODO ^ instead of explicit logging, create a trace-mode in normalizer with call tree
	return Bool32.True
}

// TODO move message handling, drawing etc to separate modules
@dllExport('DefWindowProcW')
fun defWindowProcW(hWnd HWnd, uMsg Message, wParam WParam, lParam LParam) LResult? {
	kkernelDebugLog("defWindowProcW called".utf16())
	let window = handleToWindow(hWnd)
	if window == null {
		return null
	}

	// TODO only for overlapped windows?
	if uMsg == Message.WM_CLOSE {
		// TODO DestroyWindow(hWnd)
		// TODO probably should be async post?
		// TODO call proc with an asm wrapper which sets red-zone and extra stack/reg safety
		window.proc(hWnd, Message.WM_DESTROY, null, null)
		window.proc(hWnd, Message.WM_NON_CLIENT_DESTROY, null, null)
		return null
	}

	if uMsg == Message.WM_ERASE_BACKGROUND {
		// TODO
		// First, the system asks the control to erase its background with the message WM_ERASEBKGND.
		// This may be as soon as the region is invalidated. The parameter wParam is set to the window's device context,
		// which can be used to paint something. However the painting, if used at all, should be very fast,
		// and usually consists of only filling the area with some background brush, hence effectively erasing its background.
		// If the control passes the message into DefWindowProc(), this is exactly what happens.
		// DefWindowProc() simply gets the brush which was specified during window class registration (WNDCLASS::hbrBackground)
		// and fills the control with it.

		// The return value is also important, the message should return non-zero if it performs the erase, or zero if it does not.
		// (DefWindowProc() follows it and returns non-zero if it filled the control with the background brush,
		// or zero if it did not because the WNDCLASS::hbrBackground was set to NULL.)
	}

	// If the update region also intersects the non-client area of the window, the system sends WM_NCPAINT.
	if uMsg == Message.WM_NON_CLIENT_PAINT {
		// TODO
		// If the control just passes the message into DefWindowProc(), it paints a border as specified by the window style WS_BORDER
		// and/or extended style WS_EX_CLIENTEDGE and the scrollbars as set by SetScrollInfo().
	}

	kkernelDebugLog("defWindowProcW done".utf16())
	return null
}

@dllExport('DestroyWindow')
fun destroyWindow(hWnd HWnd) Bool32 {
	kkernelDebugLog("destroyWindow called".utf16())
	return Bool32.False // TODO

	let window = handleToWindow(hWnd)
	if window == null {
		// TODO ^ guard (not just if let)
		return Bool32.False
	}

	// TODO probably should be async post?
	window.proc(hWnd, Message.WM_DESTROY, null, null)
	window.proc(hWnd, Message.WM_NON_CLIENT_DESTROY, null, null)
	kkernelDebugLog("destroyWindow done".utf16())
	return Bool32.False // TODO false?
}

