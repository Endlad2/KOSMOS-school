@dllExport('SendMessageW')
fun sendMessageW(
	hWnd Handle,
	msg Message,
	wParam WParam,
	lParam LParam
) LResult {
	// TODO
	kkernelDebugLog("sendMessageW called".utf16())
	var result LResult? = null
	let window = handleToWindow(hWnd)
	if window == null {
		kkernelDebugLog("> window == null".utf16())
		return null
	}
	result = window.proc(hWnd, msg, wParam, lParam)
	return result // TODO Hexa: `LResult?` is not allowed cause `LResult` is not nullable
}

@dllExport('GetClientRect')
fun getClientRect(
	hWnd HWnd,
	lpRect Rect
) Bool32 {
	kkernelDebugLog("getClientRect called with hWnd %8 lpRect %8".utf16(), hWnd as! UInt64, lpRect as! UInt64)
	// TODO verify that window.x and window.y are relative to the parent window’s client area (which they should be for child windows).
	if let window = handleToWindow(hWnd) {
		lpRect.left = window.x
		lpRect.top = window.y
		lpRect.right = window.width
		lpRect.bottom = window.height
		return Bool32.True
	}

	return Bool32.False
}

enum DrawTextFormat : Int {
	DT_LEFT = 0x00000000
	DT_RIGHT = 0x00000001
	DT_CENTER = 0x00000002
	DT_VERTICAL_CENTER = 0x00000004
	DT_SINGLE_LINE = 0x00000020
	DT_END_ELLIPSIS = 0x00008000
}

@dllExport('DrawTextW')
fun drawTextW(
	hdc HDc,
	lpchText ConstArrayPointer<ClangWideChar>,
	cchText Int32,
	lprc Rect,
	format DrawTextFormat
) Int32 {
	kkernelDebugLog("drawTextW called".utf16())
	let color = ByValue<Pixel32>()
	color.ref.color = 0xFF000000u32 // TODO
	drawTextBox(
		lpchText,
		lprc.left as! Int16,
		lprc.top as! Int16,
		color.ref,
		(lprc.right - lprc.left) as! UInt16,
		(lprc.bottom - lprc.top) as! UInt16,
		false,
		// TODO `HDc` is not actually pointer, so it may crash after `as!`, re-work into a handle
		(hdc as! DC).fb.ref,
		false
	)

	return 12 // TODO
}

enum EdgeFlags : UInt32 {
	BDR_RAISED_OUTER = 0x0001
	BDR_SUNKEN_OUTER = 0x0002
	BDR_RAISED_INNER = 0x0004
	BDR_SUNKEN_INNER = 0x0008
	BDR_OUTER = 0x0003
	BDR_INNER = 0x000c
	BDR_RAISED = 0x0005
	BDR_SUNKEN = 0x000a
	// TODO EDGE_RAISED = (BDR_RAISEDOUTER | BDR_RAISEDINNER)
	// TODO EDGE_SUNKEN = (BDR_SUNKENOUTER | BDR_SUNKENINNER)
	// TODO EDGE_ETCHED = (BDR_SUNKENOUTER | BDR_RAISEDINNER)
	// TODO EDGE_BUMP = (BDR_RAISEDOUTER | BDR_SUNKENINNER)
}

enum BorderFlags : UInt32 {
	BF_LEFT = 0x0001
	BF_TOP = 0x0002
	BF_RIGHT = 0x0004
	BF_BOTTOM = 0x0008
	BF_DIAGONAL = 0x0010
	/// Fill in the middle
	BF_MIDDLE = 0x0800
	/// For softer buttons
	BF_SOFT = 0x1000
	/// Calculate the space left over
	BF_ADJUST = 0x2000
	/// For flat rather than 3D borders
	BF_FLAT = 0x4000
	/// For monochrome borders
	BF_MONO = 0x8000
	// TODO BF_TOPLEFT = (BF_TOP | BF_LEFT)
	// TODO BF_TOPRIGHT = (BF_TOP | BF_RIGHT)
	// TODO BF_BOTTOMLEFT = (BF_BOTTOM | BF_LEFT)
	// TODO BF_BOTTOMRIGHT = (BF_BOTTOM | BF_RIGHT)
	// TODO BF_RECT = (BF_LEFT | BF_TOP | BF_RIGHT | BF_BOTTOM)
	// TODO BF_DIAGONAL_ENDTOPRIGHT = (BF_DIAGONAL | BF_TOP | BF_RIGHT)
	// TODO BF_DIAGONAL_ENDTOPLEFT = (BF_DIAGONAL | BF_TOP | BF_LEFT)
	// TODO BF_DIAGONAL_ENDBOTTOMLEFT = (BF_DIAGONAL | BF_BOTTOM | BF_LEFT)
	// TODO BF_DIAGONAL_ENDBOTTOMRIGHT = (BF_DIAGONAL | BF_BOTTOM | BF_RIGHT)
}

