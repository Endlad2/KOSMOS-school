// Constants

// TODO Test real limitation
let classNameLimit = 256u16

//
// Utils
//
// TODO regions and separate modules

// TODO `Window?`
fun handleToWindow(hWnd HWnd) Window {
	// TODO `HWnd?` and `if let hWnd, compare secret etc { return ok }`
	if hWnd == null {
		// TODO ^ assumes `HWnd?` so must error here or something
		return null // TODO return desktop
	}
	// TODO some bits of HANDLE should be ignored before reading
	// and comparison
	// Due to 16-byte aligned allocations
	// we may provide 4 bits for tagging
	// TODO how much actually in the original design?
	// `((v|0b1111) - 15) == v`
	// ^ Hexa: infer size_t for 0b here

	if hWnd == invalid_handle_value {
		return null
	}
	// TODO probe for read hWnd as pointer,
	// and only then compare HANDLE.tag (windowIsWindow)
	// HWnd should extend Handle/TaggedHandle probably
	// TODO SEH-reading
	// TODO the secret in fact can be just vTable address of Window class
	// `Window.type.virtualMethodTableAddress`
	// ^ makes sense cause this memory address would not be used elsewhere
	// TODO Hexa: .meta.fromPointer()/fromAddress()
	if (hWnd as! Window).windowIsWindowSecret != windowIsWindow {
		// TODO Hexa: cool idea `let w = hwnd as Window ?? return ...` so it does both `null` check and a cast
		// ^ (after null-check, to not produce RAII/ARC ref upfront)
		return null
	}
	// TODO static Window.fromHandle
	return hWnd as! Window
}

fun windowToHandle(window Window) HWnd {
	// TODO offset ptr 8-byte aligned + reserved space
	// os it fits into upper half of virtual space
	return window as! HWnd
}

//
// API
//

@dllExport('RegisterClassW')
fun registerClassW(wc WindowClass) Atom {
	// TODO just `kkernelDebugLog("registerClassW called")` no `.utf16()`
	kkernelDebugLog("registerClassW called".utf16())

	// TODO utf16zClassName takes atoms? then utf16zClassName PossiblyAtom .toString
	// TODO rename to just className, ci to require no \wlpsz[A-Z_][A-z_]+\w/etc prefixes
	// to avoid headers copy-pasta law (print all places at once)

	// TODO abort if class name is too long (test real limitation)
	// TODO Hexa: infer bug
	var tail ClassesLinkedList = rootClass
	// TODO `while let`
	while tail.next != null {
		tail = tail.next
		// TODO error if requested name already registered
	}

	// TODO sizeOf struct by value(!)
	// TODO `new ClassesLinkedList()` but on the heap
	// TODO just use Hexa Map here
	// TODO use SEH for string pointer validation? At least check it is not null ptr
	let className = isAtom(wc.utf16zClassName as! UInt64) ? '#' + (wc.utf16zClassName as! UInt64) : String.fromUTF16zUpTo(wc.utf16zClassName as! ConstArrayPointer<UInt16>, classNameLimit)
	kkernelDebugLog('registerClassW className "%S"'.utf16(), className.utf16() as! UInt64)
	let list = ClassesLinkedList(named: className)
	list.next = null

	// TODO on heap `list.wc = @heap WindowClass()` and `list.wc = @malloc/@calloc WindowClass()`
	// ^ `@heap` is more flexible cause offers RC for native libraries memory management
	list.wc = WindowClass()
	// TODO `new T() { ...wc }` to make a copy
	memcpy(list.wc as! ArrayPointer<UInt8>, wc as! ConstArrayPointer<UInt8>, sizeOf<WindowClass>() as! Int)

	// TODO still bad idea cause pointers to strings (aka wide chars)

	tail.next = list

	// TODO handle that proc can be null
	kkernelDebugLog("registerClassW done".utf16())
	return 1 as! Atom // TODO make proper atom
}

// TODO extract to createWindowEx taking Hexa Strings and be called from W and A
@dllExport('CreateWindowExW')
fun createWindowExW(
	dwExStyle UInt32,
	lpClassName ConstArrayPointer<ClangWideChar>,
	lpWindowName ConstArrayPointer<ClangWideChar>,
	dwStyle UInt32,
	x Int32,
	y Int32,
	nWidth Int32,
	nHeight Int32,
	hWndParent HWnd?,
	hMenu HMenu?,
	hInstance HInstance,
	lpParam LParam
) HWnd {
	kkernelDebugLog("createWindowExW called".utf16())

	// Find class
	// TODO Hexa: infer bug
	var list ClassesLinkedList = rootClass
	// TODO SEH
	let className = isAtom(lpClassName as! UInt64) ? '#' + (lpClassName as! UInt64) : String.fromUTF16zUpTo(lpClassName as! ConstArrayPointer<UInt16>, classNameLimit)
	kkernelDebugLog("> CreateWindowExW lpClassName \"%S\" lpWindowName \"%S\"".utf16(), className.utf16() as! UInt64, lpWindowName as! UInt64)
	// TODO ^ check string pointer for null/SEH
	var found = false
	var wc WindowClass = null

	while list.next != null {
		// Step upfront, to ignore empty root
		list = list.next

		if list.name == className {
			kkernelDebugLog("> CreateWindowExW found class \"%S\"".utf16(), className.utf16() as! UInt64)
			found = true
			wc = list.wc
			break
		}
	}

	// TODO `not`
	// TODO `if let`
	if not found {
		kkernelDebugLog("> CreateWindowExW class not found".utf16())
		return null
	}

	// Prepare for syscall
	// TODO proper `new CreateWindowExPayload {} ()`
	// TODO stack alloc\dealloc by @owned/borrowed @struct refs
	let payload CreateWindowExPayload = CreateWindowExPayload()

	payload.wc = wc as! UInt64
	// TODO `wc.type.address` same for others

	if isAtom(lpWindowName as! UInt64) {
		// TODO actually handle Atom
		payload.lpWindowName = 0 // Will use app name
	} else {
		payload.lpWindowName = lpWindowName as! UInt64 // TODO Hexa: .address
	}

	payload.dwStyle = dwStyle
	payload.x = x
	payload.y = y
	// TODO test zero-width
	// TODO Hexa: encode as `enum WindowSize { CW_USE_DEFAULT = 123 Custom = .../_ } case Custom(value):`
	// TODO respect CW_USE_DEFAULT etc for pos and size
	payload.nWidth = nWidth <= 0? 640 : nWidth
	payload.nHeight = nHeight <= 0? 400 : nHeight
	kkernelDebugLog("> CreateWindowExW requested size %d x %d".utf16(), nWidth as! UInt64, nHeight as! UInt64)
	// TODO pass params as tags? are all those params even needed in server?

	// if hWndParent != null and nWidth <= 0 {
	// // TODO If CW_USEDEFAULT is specified for a pop-up or child window, nWidth and nHeight are set to zero.
	// if let parent = handleToWindow(hWndParent) {
	// payload.nWidth = 0 // parent.width
	// payload.nHeight = 0 // parent.height
	// }
	// }

	// Create local window counterpart
	let window = Window()
	kkernelDebugLog("> window = {%8}".utf16(), window as! UInt64)

	let hWnd = window as! HWnd
	payload.hWnd = hWnd as! UInt64

	// Create native window counterpart
	let windowId UInt64 = hWndParent == null ? tofitaCreateWindowEx(payload) : 0
	// TODO ^ check the result if it succeeded

	if let parent = handleToWindow(hWndParent) {
		kkernelDebugLog("> window added as a child to {%8}".utf16(), parent as! UInt64)
		// TODO notify both of being added?
		parent.children.push(window)
		// TODO Hexa: clearer that it's a copy? With `@copy` or `@mayCopy` to keep it generic compared to explicit `.copy`
		window.dc.fb = parent.dc.fb
		window.parent = parent
	}

	window.windowId = windowId
	kkernelDebugLog("> window.windowId = {%8}".utf16(), window.windowId as! UInt64)
	window.windowIsWindowSecret = windowIsWindow
	kkernelDebugLog("> wc.lpfnWndProc = {%8}".utf16(), wc.lpfnWndProc as! UInt64)
	window.proc = wc.lpfnWndProc
	kkernelDebugLog("> window.proc = {%8}".utf16(), window.proc as! UInt64)

	// TODO `payload.x` must be updated in the syscall instead
	window.x = x
	window.y = y

	// `CW_USE_DEFAULT`
	if window.x < 0 {
		window.x = 0 // NOTE currently non-zero breaks `miceTarget`
	}

	if window.y < 0 {
		window.y = 0 // NOTE currently non-zero breaks `miceTarget`
	}

	window.width = payload.nWidth
	window.width = nWidth

	window.height = payload.nHeight
	window.height = nHeight

	if nWidth < 0 {
		if hWndParent != null {
			window.width = 0
		} else {
			window.width = payload.nWidth
		}
	}

	if nHeight < 0 {
		if hWndParent != null {
			window.height = 0
		} else {
			window.height = payload.nHeight
		}
	}

	// TODO null should produce `"null"`
	// TODO window name limit?
	window.title = isAtom(lpWindowName as! UInt64) ? '#' + (lpWindowName as! UInt64) : String.fromUTF16zUpTo(lpWindowName as! ConstArrayPointer<UInt16>, 4096)

	// Styles
	window.style = dwStyle
	window.exStyle = dwExStyle

	// TODO some template parsing is unclear
	// window.style = window.style | window.exStyle

	// TODO change to a helper `isDesktopWindow()` or `isDesktopOwnedWindow()`
	if windowId != 0 {
		// Whole framebuffer
		window.clipX = 0
		window.clipY = 0

		window.clipWidth = window.width
		window.clipHeight = window.height

		window.dc.fb.ref.ownerWindowId = windowId
	}

	// TODO Hexa: make @struct `new` allocate on stack instead of heap so no need for this
	// TODO ^ update c2hexa to not produce .ref accordingly
	// TODO Hexa: ByValue passes constructors and { fields }
	// ^ some fields have setter but still require initialization
	let createStruct ByValue<CREATESTRUCT> = ByValue<CREATESTRUCT>()
	kkernelDebugLog("> createStruct.ref.lpCreateParams = {%8}".utf16(), lpParam as! UInt64)
	createStruct.ref.lpCreateParams = lpParam
	createStruct.ref.hInstance = hInstance
	createStruct.ref.hMenu = hMenu
	createStruct.ref.hwndParent = hWndParent
	createStruct.ref.cy = payload.nHeight
	createStruct.ref.cx = payload.nWidth
	createStruct.ref.y = y
	createStruct.ref.x = x
	createStruct.ref.dwStyle = dwStyle
	createStruct.ref.dwExStyle = dwExStyle
	createStruct.ref.lpszName = payload.lpWindowName as! SizeOfPointer // TODO Hexa: .address
	createStruct.ref.lpszClass = lpClassName as! SizeOfPointer // TODO Hexa: .address

	// TODO should be called somewhere else, in syscall of windows creation?
	// TODO use sendMessage for WM_CREATE and WM_NON_CLIENT_CREATE
	// TODO Must return non-zero to proceed
	sendMessageW(hWnd, Message.WM_NON_CLIENT_CREATE, null, createStruct.ref as! LParam)

	// TODO WM_NCCALCSIZE

	/*
	WM_NCCALCSIZE is sent immediately after WM_NCCREATE during window creation, but only under certain conditions:
	The window has a non-client area that needs sizing (e.g., borders, title bar, scroll bars).
	It’s sent before WM_CREATE to allow the application to adjust the client area size based on the non-client features.

	It’s sent when the window’s style or extended style implies a non-client area (e.g., WS_CAPTION, WS_BORDER, WS_THICKFRAME, WS_EX_CLIENTEDGE). If the window is purely client-area (e.g., a popup with no border), it might not be sent during creation.
	It’s also sent later (post-creation) whenever the non-client area needs recalculation, like during resizing or style changes, but that’s not relevant to initial creation.

	// If dwStyle or dwExStyle implies a non-client area:
	let ncParams = NCCALCSIZE_PARAMS() // Fill with appropriate rects
	sendMessage(hWnd, Message.WM_NCCALCSIZE, false, ncParams as! LParam)

	// Optional: WM_NCCALCSIZE if non-client area exists
	if (dwStyle & (WS_CAPTION | WS_BORDER | WS_THICKFRAME)) { // Example condition
		let ncParams = NCCALCSIZE_PARAMS()
		// Fill ncParams.rgrc[0] with proposed window rect (x, y, x+nWidth, y+nHeight)
		ncParams.rgrc[0].left = x
		ncParams.rgrc[0].top = y
		ncParams.rgrc[0].right = x + payload.nWidth
		ncParams.rgrc[0].bottom = y + payload.nHeight
		sendMessage(hWnd, Message.WM_NCCALCSIZE, false, ncParams as! LParam)
	}

	When sent during creation:
	wParam is FALSE.
	lParam points to an NCCALCSIZE_PARAMS structure containing proposed window rectangles.
	Post-creation (e.g., resizing):
	wParam is TRUE.
	lParam points to NCCALCSIZE_PARAMS.

	However, for completeness in mimicking CreateWindowEx, you could send it if your window uses styles like WS_OVERLAPPEDWINDOW or WS_EX_WINDOWEDGE. Most apps ignore it during creation and let DefWindowProc handle the default sizing.
	*/
	// TODO Must return non-zero to proceed?
	sendMessageW(hWnd, Message.WM_CREATE, null, createStruct.ref as! LParam)

	// Initial paint - post WM_PAINT asynchronously
	postMessage(hWnd, Message.WM_PAINT, null, null)

	kkernelDebugLog("> CreateWindowExW done".utf16())
	return hWnd
}

@dllExport('CreateWindowExA')
fun createWindowExA(
	dwExStyle UInt32,
	lpClassName ConstArrayPointer<ClangChar>, // TODO must be MayBeAtomA MayBeAtomW
	lpWindowName ConstArrayPointer<ClangChar>,
	dwStyle UInt32,
	x Int32,
	y Int32,
	nWidth Int32,
	nHeight Int32,
	hWndParent HWnd,
	hMenu HMenu,
	hInstance HInstance,
	lpParam LParam
) HWnd {
	kkernelDebugLog("createWindowExA called {%s} of {%s}".utf16(), lpWindowName as! UInt64, lpClassName as! UInt64)
	// TODO crash when 4096 (supposedly wrong stack checker signature)
	var utf16zClassName ArrayByValue<ClangWideChar, 256> = [0]
	var i = 0
	while lpClassName != null { // TODO avoid infinite loop
		utf16zClassName[i] = lpClassName[i]
		if utf16zClassName[i] as! UInt16 == 0 {
			break
		}

		i++
	}

	var utf16zWindowName ArrayByValue<ClangWideChar, 256> = [0]
	var i = 0
	while lpWindowName != null { // TODO avoid infinite loop
		utf16zWindowName[i] = lpWindowName[i]
		if utf16zWindowName[i] as! UInt16 == 0 {
			break
		}

		i++
	}

	kkernelDebugLog("createWindowExA calls createWindowExW {%S} of {%S}".utf16(), utf16zClassName as! UInt64, utf16zWindowName as! UInt64)
	return createWindowExW(dwExStyle, utf16zClassName.ref, utf16zWindowName.ref, dwStyle, x, y, nWidth, nHeight, hWndParent, hMenu, hInstance, lpParam)
	return null // TODO
}

@dllExport('ShowWindow')
fun showWindow(hWnd HWnd, nCmdShow CmdShow) Bool32 {
	kkernelDebugLog("showWindow called with nCmdShow %d for Hwnd %8".utf16(), nCmdShow as! UInt64, hWnd as! UInt64)
	// TODO ^ remove all debug logs, make them traceable with external tool
	var window = handleToWindow(hWnd)
	var result = Bool32.False
	if window != null {
		// TODO Cannot switch over `Int32` type
		switch nCmdShow {
			case SW_HIDE: {
					let payload = ShowWindowPayload()
					payload.windowId = window.windowId
					payload.nCmdShow = nCmdShow
					payload.x = -1
					payload.y = -1
					payload.width = -1
					payload.height = -1
					tofitaShowWindow(payload)
					result = Bool32.True
				}
				// NOTE rename them to SW_SHOW_NORMAL
				// TODO Hexa: this one is probably `case SW_SHOW or SW_SHOWNORMAL or SW_SHOWDEFAUL:` cause mimic bit flags i.e. `A | B` implies `A and also B`
			case SW_SHOW | SW_SHOWNORMAL | SW_SHOWDEFAULT: {
					let payload = ShowWindowPayload()
					payload.windowId = window.windowId
					payload.nCmdShow = nCmdShow
					payload.x = -1
					payload.y = -1
					payload.width = -1
					payload.height = -1
					tofitaShowWindow(payload)
					result = Bool32.True
				}
			case _: {
					// TODO
				}
		}
	} else {
		kkernelDebugLog("showWindow window is null for Hwnd %8".utf16(), hWnd as! UInt64)
	}
	kkernelDebugLog("showWindow done".utf16())
	return result
}

// TODO take 2 or more messages at a time for better perf (this is pretty common)
@dllExport('GetMessageW')
fun getMessageW(msg Msg, hWnd HWnd, wMsgFilterMin UInt32, wMsgFilterMax UInt32) Bool32 {
	kkernelDebugLog("getMessageW called".utf16())
	var result = Bool32.True // TODO `true`

	let payload = ByValue<GetMessagePayload>()
	let payload = payload.ref
	// TODO others by value too

	payload.hWnd = hWnd as! UInt64
	payload.wMsgFilterMin = wMsgFilterMin
	payload.wMsgFilterMax = wMsgFilterMax
	tofitaGetMessage(payload) // TODO use its returned value

	msg.hwnd = payload.hwnd as! Handle
	msg.message = payload.message
	msg.wParam = payload.wParam as! WParam
	msg.lParam = payload.lParam as! LParam
	msg.time = payload.time
	msg.pt = payload.pt
	// #if bit64
	msg.lPrivate = payload.lPrivate
	// #end
	// TODO ^ lPrivate is present only on 32-bit

	// Stop iteration
	if msg.message == Message.WM_QUIT {
		kkernelDebugLog("getMessageW got WM_QUIT".utf16())
		result = Bool32.False
	}

	kkernelDebugLog("getMessageW done".utf16())
	return result
}

@dllExport('TranslateMessage')
fun translateMessage(msg Msg) Bool32 {
	kkernelDebugLog("translateMessage called".utf16())
	// TODO
	kkernelDebugLog("translateMessage done".utf16())
	return Bool32.False
}

fun render(window Window, msg Msg) LResult? {
	// TODO BK ERASE
	kkernelDebugLog("render proc {%8} hwnd {%8}".utf16(), window.proc as! UInt64, msg.hwnd as! UInt64)
	var result = window.proc(msg.hwnd, msg.message, msg.wParam, msg.lParam)

	for child in window.children {
		// TODO Hexa: `kkernelDebugLog("child WM_PAINT {%S}", child.title.utf16() as! UInt64)` note lack of `.utf16()`
		kkernelDebugLog("child WM_PAINT {%S}".utf16(), child.title.utf16() as! UInt64)
		// TODO pass msg or not? what is even passed
		// child.proc(child as! HWnd, msg.message, msg.wParam, msg.lParam)
		child.clipX = window.clipX + child.x
		child.clipY = window.clipY + child.y
		// TODO child.clipWidth = window.clipWidth - child.x
		// TODO child.clipHeight = window.clipHeight - child.y
		child.clipWidth = child.width
		child.clipHeight = child.height

		// TODO Hexa: `render(child, {...msg, hwnd: child as! HWnd})` + ensure its on stack
		// let childMsg = Msg() // TODO ensure allocated on stack
		let childMsg = ByValue<Msg>()
		let childMsg = childMsg.ref
		childMsg.hwnd = child as! HWnd
		childMsg.message = msg.message
		childMsg.message = Message.WM_PAINT
		childMsg.wParam = msg.wParam // TODO
		childMsg.lParam = msg.lParam // TODO

		child.clipX = 0
		child.clipY = 0
		child.clipWidth = child.width
		child.clipHeight = child.height

		childMsg.wParam = 0 as! WParam
		childMsg.lParam = 0 as! LParam
		// render(child, childMsg)
		postMessageW(childMsg.hwnd, childMsg.message, childMsg.wParam, childMsg.lParam)

		/*
		TODO Probably adding local message queue for speed makes sense (for messages produced within the app like this one)

		Correct Behavior (Win32 Standard):
		Children don’t inherit the parent’s WM_PAINT message. Instead, when a child’s region is invalidated (e.g., via InvalidateRect(child_hwnd, ...)), the system posts a separate WM_PAINT message to the child’s HWND, which DispatchMessage routes to the child’s proc.
		You’d see separate log entries like:
			dispatchMessageW called (parent WM_PAINT, hwnd=parent_hwnd)
			dispatchMessageW called (child WM_PAINT, hwnd=child_hwnd)
		*/
	}

	return result
}

fun miceTarget(window Window, x Int32, y Int32) Window? {
	kkernelDebugLog(">> miceTarget: checking at x=%d, y=%d".utf16(), x as! UInt64, y as! UInt64)
	kkernelDebugLog(">> miceTarget: window %8".utf16(), window as! UInt64)

	// Check if the coordinates are within the current window's bounds
	if x >= window.x and x < (window.x + window.width) and y >= window.y and y < (window.y + window.height) {
		kkernelDebugLog(">>> miceTarget: window %8 recursively checking the children".utf16(), window as! UInt64)
		kkernelDebugLog(">>> miceTarget: window children count %8".utf16(), window.children.length as! UInt64)

		// Recursively check children
		for child in window.children {
			let target = miceTarget(child, x, y)
			if target != null {
				kkernelDebugLog(">>> miceTarget: found child window %8".utf16(), target as! UInt64)
				return target
			}
		}

		// No child window found, return the current window
		kkernelDebugLog(">> miceTarget: no child hit, returning window %8".utf16(), window as! UInt64)
		return window
	}

	// Coordinates not within this window
	kkernelDebugLog(">> miceTarget: window bounds x=%d, y=%d".utf16(), window.x as! UInt64, window.y as! UInt64)
	kkernelDebugLog(">> width=%d, height=%d".utf16(), window.width as! UInt64, window.height as! UInt64)
	kkernelDebugLog(">> miceTarget: window children count %d".utf16(), window.children.length as! UInt64)

	kkernelDebugLog(">> miceTarget: coordinates outside window %8".utf16(), window as! UInt64)
	return null
}

@dllExport('DispatchMessageW')
fun dispatchMessageW(msg Msg) LResult? {
	// TODO msg is optional
	// `let msg = msg ?? return { log LResult.zero }`
	kkernelDebugLog("dispatchMessageW called".utf16())
	var result LResult? = null
	// TODO ^ clearer result type? LResult.zero
	if msg.hwnd != null {
		kkernelDebugLog("> msg.hwnd != null".utf16())
		let window = handleToWindow(msg.hwnd)
		kkernelDebugLog("handleToWindow".utf16())
		if window == null {
			kkernelDebugLog("> window == null".utf16())
			return null
		}
		// ERROR_INVALID_HANDLE
		if msg.message == Message.WM_PAINT {
			kkernelDebugLog("> WM_PAINT".utf16())
			result = render(window, msg)
		} else {
			kkernelDebugLog("> not_WM_PAINT".utf16())
			kkernelDebugLog(">> msg.message = %8".utf16(), msg.message as! UInt64)

			// TODO Do this in the `getMessageW`
			if msg.message == Message.WM_MOUSE_MOVE or
				msg.message == Message.WM_LEFT_BUTTON_DOWN or
				msg.message == Message.WM_LEFT_BUTTON_UP or
				msg.message == Message.WM_RIGHT_BUTTON_DOWN or
				msg.message == Message.WM_RIGHT_BUTTON_UP or
				msg.message == Message.WM_MIDDLE_BUTTON_DOWN or
				msg.message == Message.WM_MIDDLE_BUTTON_UP or
				msg.message == Message.WM_LEFT_BUTTON_DOUBLE_CLICK or
				msg.message == Message.WM_RIGHT_BUTTON_DOUBLE_CLICK or
				msg.message == Message.WM_MIDDLE_BUTTON_DOUBLE_CLICK {
				kkernelDebugLog(">> Mouse event".utf16())
				kkernelDebugLog(">> msg.lParam = %d".utf16(), msg.lParam as! UInt64)
				// Extract mouse coordinates
				let lParam UInt32 = msg.lParam as! UInt32
				let frameWidth = 1
				let x Int32 = LParam.loWord(lParam) - frameWidth // Tofita sends non-client mouse
				let frameHeight = 33
				let y Int32 = LParam.hiWord(lParam) - frameHeight // Tofita sends non-client mouse
				kkernelDebugLog(">> x = %d, y = %d".utf16(), x as! UInt64, y as! UInt64)

				// TODO screen coordinates should come from the DWM
				msg.pt.ref.x = x
				msg.pt.ref.y = y

				// Find the target window (parent or child) under the cursor
				let targetWindow = miceTarget(window, x, y)
				if let targetWindow = targetWindow {
					// Translate coordinates to target window's client space
					let translatedX = x - targetWindow.x
					let translatedY = y - targetWindow.y
					let translatedLParam = LParam.makeULong(translatedX as! UInt16, translatedY as! UInt16) as! LParam
					kkernelDebugLog(">> Forwarding to window %8".utf16(), targetWindow as! UInt64)
					kkernelDebugLog(">> translated x = %d, y = %d".utf16(), translatedX as! UInt64, translatedY as! UInt64)
					result = targetWindow.proc(targetWindow as! HWnd, msg.message, msg.wParam, translatedLParam)
				} else {
					kkernelDebugLog("> No window found under cursor".utf16())
					let translatedX = x
					let translatedY = y
					let translatedLParam = LParam.makeULong(translatedX as! UInt16, translatedY as! UInt16) as! LParam
					result = window.proc(msg.hwnd, msg.message, msg.wParam, translatedLParam)
				}
			} else if msg.message == Message.WM_TIMER, msg.lParam != null {
				// TODO capture exceptions and flag for non-capturing
				let timerProc = msg.lParam as! TimerProcedure
				timerProc(msg.hwnd, Message.WM_TIMER, msg.wParam as! UInt64, msg.time)
			} else {
				// TODO logic should be "GetWindowLongPtrW GWLP_WNDPROC ?? DefWindowProcW"
				result = window.proc(msg.hwnd, msg.message, msg.wParam, msg.lParam)
			}
		}
		// TODO result = ERROR_SUCCESS
	} else {
		// TODO
	}
	kkernelDebugLog("> DispatchMessageW done".utf16())
	return result
}

@dllExport('PostMessage')
fun postMessage(hWnd HWnd, msg Message, wParam WParam, lParam LParam) Bool32 {
	kkernelDebugLog("postMessage called HWnd = %8".utf16(), hWnd as! UInt64)
	var payload PostMessagePayload = PostMessagePayload()
	// TODO ^ by value
	payload.hWnd = hWnd as! UInt64
	payload.msg = msg
	payload.wParam = wParam as! UInt64
	payload.lParam = lParam as! UInt64
	kkernelDebugLog("> PostMessage done HWnd = %8".utf16(), hWnd as! UInt64)
	return tofitaPostMessage(payload)
}

@dllExport('PostQuitMessage')
fun postQuitMessage(nExitCode Int32) Void {
	kkernelDebugLog("postQuitMessage called".utf16())
	postMessage(null, Message.WM_QUIT, nExitCode as! WParam, null)
	kkernelDebugLog("> PostQuitMessage done".utf16())
	// TODO ERROR_SUCCESS
}

@dllExport('BeginPaint')
fun beginPaint(hWnd HWnd, ps PaintStruct) HDc {
	kkernelDebugLog("beginPaint called HWnd = %8".utf16(), hWnd as! UInt64)
	var window = handleToWindow(hWnd)
	// TODO guard `let window = window ?? return null`
	if window == null {
		kkernelDebugLog("> window == null, cancelling".utf16())
		return null
	}

	while window.parent != null {
		window = window.parent
	}

	let dc = window.dc
	let fb = dc.fb.ref
	if fb == null {
		kkernelDebugLog("> window == null, cancelling".utf16())
		return null
	}

	// We do this every time, cause window may be resized
	njraaGetOrCreateWindowFramebuffer(fb)
	// TODO ^ only for overlapped + cache it
	let rcPaint = ps.rcPaint.ref
	rcPaint.left = 0
	rcPaint.left = window.clipX
	rcPaint.top = 0
	rcPaint.top = window.clipY

	rcPaint.right = fb.width as! Int32
	rcPaint.right = window.clipX + window.clipWidth // TODO MIN(fb.width)
	rcPaint.bottom = fb.height as! Int32
	rcPaint.bottom = window.clipY + window.clipHeight // TODO MIN(fb.height)

	// Default to entire *client* area
	rcPaint.left = 0
	rcPaint.top = 0
	rcPaint.right = fb.width as! Int32
	rcPaint.bottom = fb.height as! Int32

	// Set fErase (assume true if no WM_ERASEBKGND handler)
	ps.fErase = Bool32.True // TODO Check if background was erased

	// Validate update region
	// window.invalidRect = null // Clear invalid region
	// TODO Implement ValidateRect to update system-wide invalid region

	kkernelDebugLog("> BeginPaint done HDc = %8".utf16(), fb as! UInt64)
	return dc as! HDc
	// TODO ^ proper HDc implementation (at least as a handle with secret)
}

// TODO reimplement into SEH writer instead of `if`? is it any safer for overflows? faster? x/y bounds?
// TODO @inline ?
// TODO Clang may NOT pass Pixel32 as a single uint32_t in argument and cause perf loss
@fastcall fun setFramebufferPixel(fb WindowFramebuffer, x Int32, y Int32, pixel ByValue<Pixel32>) Void {
	// TODO merge to single comparison
	if (x < 0) or (y < 0) {
		return
	}
	if (x > fb.width - 1) or (y > fb.height - 1) {
		return
	}

	// TODO this is not copy by value!!!
	let pixels = fb.pixels as! ArrayPointer<ByValue<Pixel32>>
	// TODO `#if (bit64 == true)` or `#if bit64 == true`
	// #if bit64
	// TODO `if sizeOf<ArrayPointer<Int> >() == 8 {` generates into `sizeof(int32_t)`
	pixels[y * fb.width + x] = pixel
	// #else
	// TODO compiler crashes without `#else`
	// ^ or it's just vs hexa related
	// #end
}

fun outerRect(dc HDc, lprc Rect, brush HBrush) {
	kkernelDebugLog("[internal] outerRect called".utf16())
	let fb = (dc as! DC).fb.ref
	let color = ByValue<Pixel32>()
	color.ref.color = 0xFFADADADu32 // TODO brush

	// TODO Hexa: make it possible to assign `let rect ByValue<Rect>() = lprc` to make a stack copy
	let rect = ByValue<Rect>() // Copy cause we will modify it for clipping
	rect.ref.left = lprc.left
	rect.ref.top = lprc.top
	rect.ref.right = lprc.right
	rect.ref.bottom = lprc.bottom
	let lprc = rect.ref
	if lprc.right <= lprc.left or lprc.bottom <= lprc.top {
		lprc.right += lprc.left
		lprc.bottom += lprc.top
	}

	for y in lprc.top ... lprc.bottom {
		for x in lprc.left ... lprc.right {
			if (x == lprc.left or y == lprc.top or y == lprc.bottom - 1 or x == lprc.right - 1) {
				setFramebufferPixel(fb, x, y, color)
			}
		}
	}
	kkernelDebugLog("[internal] outerRect done".utf16())
}

