@struct
class ClassesLinkedList {
	// TODO let name String (late init)
	var name String // TODO = null or in constructor `new (named String? = null)`
	var wc WindowClass
	var next ClassesLinkedList = null // TODO Pointer useless for struct?
	new (named String) {
		name = named
	}
}

// TODO alloc by value, and use .ref (same for String.root)
// TODO use Map instead of linked list
var rootClass = ClassesLinkedList(null)
rootClass.next = null as! ClassesLinkedList // TODO why I do this?

// TODO some HandleWrapper with handle type field?
// TODO to enums
let windowIsWindow UInt16 = 0xA1CE

/// Window == HWnd
@struct
class Window {
	// @rename('windowIsWindow_') // TODO renames due to global
	var windowIsWindowSecret UInt16
	var windowId UInt64
	// TODO Bool isNativeWindow
	var proc WindowProcedure
	// var fb ByValue<WindowFramebuffer>
	var dc DC = DC() // ByValue<DC>
	var instanceId UInt64 // Random unique ID
	let children [Window] = []
	var x Int32
	var y Int32
	var width Int32
	var height Int32
	var title String
	var parent Window? = null
	var style UInt32 = 0 // TODO use bit masks
	var exStyle UInt32 = 0 // TODO use bit masks

	// Clipping for painting
	var clipX Int32 = 0
	var clipY Int32 = 0
	var clipWidth Int32 = 0
	var clipHeight Int32 = 0

	// TODO others + unset state (i.e. `SizeOfPointer?` + support this in code gen + maybe this is `Array<SizeOfPointer?>`)
	var windowLongPtrA SizeOfPointer = 0

	new () {
		windowIsWindowSecret = windowIsWindow
	}
}

// TODO just allocate global and take its address as a secret
let windowIsRemoteWindow UInt16 = 0xA1CB

// Window of other process
@struct
class RemoteWindow {
	var windowIsRemoteWindow UInt16
	var pid UInt64
	var hWnd HWnd
	var instanceId UInt64 // Random unique ID
}
