@dllExport('RegEnumKeyExW')
fun regEnumKeyExW(
	hKey HKey,
	dwIndex UInt32,
	lpName ArrayPointer<ClangWideChar>,
	lpcchName ArrayPointer<UInt32>,
	lpReserved ArrayPointer<UInt32>,
	lpClass ArrayPointer<ClangWideChar>,
	lpcchClass ArrayPointer<UInt32>,
	lpftLastWriteTime ArrayPointer<FILETIME>
) LSTATUS {
	kkernelDebugLog("regEnumKeyExW called with hKey %8 dwIndex %u".utf16(), hKey as! UInt64, dwIndex as! UInt64)
	return 259 // ERROR_NO_MORE_ITEMS
}

@dllExport('RegEnumKeyExA')
fun regEnumKeyExA(
	hKey HKey,
	dwIndex UInt32,
	lpName ArrayPointer<ClangChar>,
	lpcchName ArrayPointer<UInt32>,
	lpReserved ArrayPointer<UInt32>,
	lpClass ArrayPointer<ClangChar>,
	lpcchClass ArrayPointer<UInt32>,
	lpftLastWriteTime ArrayPointer<FILETIME>
) LSTATUS {
	kkernelDebugLog("regEnumKeyExA called with hKey %8 dwIndex %u".utf16(), hKey as! UInt64, dwIndex as! UInt64)
	var utf16zName ArrayByValue<ClangWideChar, 256> = [0]
	var utf16zClass ArrayByValue<ClangWideChar, 256> = [0]
	let result = regEnumKeyExW(hKey, dwIndex, utf16zName.ref, lpcchName, lpReserved, utf16zClass.ref, lpcchClass, lpftLastWriteTime)
	// TODO Convert utf16zName and utf16zClass to ANSI and copy to lpName, lpClass
	return result
}

