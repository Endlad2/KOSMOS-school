@dllExport('RegGetValueA')
fun regGetValueA(
	hKey HKey,
	lpSubKey ConstArrayPointer<ClangChar>,
	lpValueName ConstArrayPointer<ClangChar>,
	dwFlags UInt32,
	lpdwType ArrayPointer<UInt32>,
	pvData ArrayPointer<UInt8>,
	lpcbData ArrayPointer<UInt32>
) LSTATUS {
	kkernelDebugLog("regGetValueA called with lpSubKey %s lpValueName %s".utf16(), lpSubKey as! UInt64, lpValueName as! UInt64)
