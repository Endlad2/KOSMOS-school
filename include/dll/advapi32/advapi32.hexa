// TODO into enum
declare LSTATUS = Int32

// TODO use proper one
fun simpleAtoW(ascii8z ConstArrayPointer<ClangChar>, utf16z ArrayPointer<ClangWideChar>) Void {
	var i = 0
	while ascii8z != null { // Check for a null basically
		utf16z[i] = ascii8z[i] as! ClangWideChar
		if ascii8z[i] as! UInt8 == 0 {
			break
		}

		i++
	}
}

@dllExport('RegCloseKey')
fun regCloseKey(hKey HKey) LSTATUS {
	// TODO seems like functions with 1/0 arguments get corrupted stack, because kkernelDebugLog receives 64 bit integers
	// kkernelDebugLog("regCloseKey called with hKey %8".utf16(), hKey as! UInt64)
	return 0 // ERROR_SUCCESS
}

@dllExport('RegCreateKeyExW')
fun regCreateKeyExW(
	hKey HKey,
	lpSubKey ConstArrayPointer<ClangWideChar>,
	reserved UInt32,
	lpClass ConstArrayPointer<ClangWideChar>,
	dwOptions UInt32,
	samDesired UInt32,
	lpSecurityAttributes SizeOfPointer,
	phkResult ArrayPointer<HKey>,
	lpdwDisposition ArrayPointer<UInt32> // TODO optional
) LSTATUS {
	kkernelDebugLog("regCreateKeyExW called with hKey %8 lpSubKey %S".utf16(), hKey as! UInt64, lpSubKey as! UInt64)
	phkResult[0] = 0x777 as! HKey
	return 0 // ERROR_SUCCESS
}

@dllExport('RegCreateKeyExA')
fun regCreateKeyExA(
	hKey HKey,
	lpSubKey ConstArrayPointer<ClangChar>,
	reserved UInt32,
	lpClass ConstArrayPointer<ClangChar>,
	dwOptions UInt32,
	samDesired UInt32,
	lpSecurityAttributes SizeOfPointer,
	phkResult ArrayPointer<HKey>,
	lpdwDisposition ArrayPointer<UInt32>
) LSTATUS {
	kkernelDebugLog("regCreateKeyExA called with hKey %8 lpSubKey %s".utf16(), hKey as! UInt64, lpSubKey as! UInt64)
	var utf16zSubKey ArrayByValue<ClangWideChar, 256> = [0]
	simpleAtoW(lpSubKey, utf16zSubKey.ref)
	var utf16zClass ArrayByValue<ClangWideChar, 256> = [0]
	simpleAtoW(lpClass, utf16zClass.ref)
	return regCreateKeyExW(hKey, utf16zSubKey.ref, reserved, utf16zClass.ref, dwOptions, samDesired, lpSecurityAttributes, phkResult, lpdwDisposition)
}

