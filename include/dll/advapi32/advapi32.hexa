@dllExport('RegQueryValueExW')
fun regQueryValueExW(
	hKey HKey,
	lpValueName ConstArrayPointer<ClangWideChar>,
	lpReserved ArrayPointer<UInt32>,
	lpType ArrayPointer<UInt32>,
	lpData ArrayPointer<UInt8>,
	lpcbData ArrayPointer<UInt32>
) LSTATUS {
	kkernelDebugLog("regQueryValueExW called with hKey %8 lpValueName %S".utf16(), hKey as! UInt64, lpValueName as! UInt64)
	if lpData != null and lpcbData != null {
		lpData[0] = 1
		lpData[1] = 0
		lpData[2] = 0
		lpData[3] = 0
		// memset(lpData, 1, lpcbData[0]) // Stub
		// memset(lpData, 0, lpcbData[0]) // Zero-fill buffer
	}
	return 0 // stub
	return 2 // ERROR_FILE_NOT_FOUND
}

