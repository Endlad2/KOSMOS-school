// TODO move all headers into Dance + make there a project for type check
@linkName('LocalAlloc')
declare
fun localAlloc(flags UInt32, bytes SizeOfPointer) HLocal

@linkName('HeapAlloc')
@dllImport
@rename('HeapAlloc')
declare
fun heapAlloc(heap Handle, flags UInt32, bytes SizeOfPointer) ArrayPointer<Void>
// TODO
// let kernel32 = "kernel32.dll" (uppercase?)
// @dllImport(kernel32) (fpc)
// Generate .dllImport.txt where each line is libgen argument list line-per-dll

declare VoidPointer = ConstArrayPointer<Void>

// TODO only header here, impl in other files
@linkName('HeapFree')
@dllImport
declare
fun heapFree(
	hHeap Handle,
	dwFlags UInt32,
	lpMem VoidPointer
) Bool32

@linkName('MulDiv')
@dllImport
declare
fun mulDiv(
	nNumber Int,
	nNumerator Int,
	nDenominator Int
) Int

@linkName('WideCharToMultiByte')
@dllImport
declare
fun wideCharToMultiByte(
	codePage UInt32,
	dwFlags UInt32,
	lpWideCharStr ConstArrayPointer<ClangWideChar>,
	cchWideChar Int,
	lpMultiByteStr ArrayPointer<ClangChar>,
	cbMultiByte Int,
	lpDefaultChar ConstArrayPointer<ClangChar>,
	lpUsedDefaultChar ArrayPointer<Bool>
) Int

@linkName('GetProcessHeap')
@dllImport
declare
fun getProcessHeap() Handle

@linkName('SetLastError')
@dllImport
declare
fun setLastError(
	dwErrCode UInt32
) Void

// TODO Hexa: well just `@dllImport('GetLastError')` also error if @linkName present too
@linkName('GetLastError')
@dllImport
declare
fun getLastError() UInt32

@linkName('GetModuleHandleA')
@dllImport
declare
fun getModuleHandleA(lpLibFileName ConstArrayPointer<ClangChar>) HModule

@linkName('GetModuleHandleW')
@dllImport
declare
fun getModuleHandleW(lpLibFileName ConstArrayPointer<ClangWideChar>) HModule
