// TODO @linkName('KiFastSystemCall')
fun kiFastSystemCall(rcx TofitaSyscalls, rdx SyscallPayload) SyscallResult {
	return kosmos32FastSystemCall(rcx, rdx)
}

@linkName('NtCurrentTeb')
@dllExport
fun ntCurrentTeb() SizeOfPointer {
	// return
	#if bit64 // TODO format
		// TODO `0x60u32`?
		return readgsqword(0x30u32)
	#end
	#if bit32
		// #else TODO Hexa: bug
		return readfsdword(0x18u32)
	#end
}

// TODO calling convention
// TODO no capture `@closure(false)`
declare ConsoleEntry = (hInstance ConstArrayPointer<Void>, hPrev ConstArrayPointer<Void>, pCmdLine ConstArrayPointer<Void>, nCmdShow Int) => UInt32
declare Entry = (hInstance ConstArrayPointer<Void>, hPrev ConstArrayPointer<Void>, pCmdLine ConstArrayPointer<Void>, nCmdShow Int) => UInt32
declare ExeEntry = () => Int32
// TODO The function must be defined to use the __stdcall calling convention
declare DllEntry = (hInstanceDLL ConstArrayPointer<Void>, fdwReason DllEntryReason, lpvReserved ConstArrayPointer<Void>) => Bool32
// TODO Hexa: must error `hinstDLL` twice `declare DllEntry = (hinstDLL ConstArrayPointer<Void>, fdwReason DllEntryReason, hinstDLL ConstArrayPointer<Void>) => Bool32`

// @rename('hexa_entry') declare let hexa_entry Entry // TODO size_t
// @rename('hexa_pid') declare let hexa_pid UInt64 // TODO size_t
// @rename('hexa_dllEntries') declare let hexa_dllEntries UInt64 // TODO size_t
@rename('hexa_startup') declare let hexa_startup UInt64 // TODO size_t aka PointerSizedUInt (size_t is guaranteed to be an unsigned type)

@dllExport('memset')
fun memset(dest ConstArrayPointer<UInt8>, value Int, count SizeOfPointer) SizeOfPointer {
	// TODO !! inline(?) version here, full at msvcrt
	kkernelDebugLog("[ntdll] memset() WARN: STUB\n".utf16())
	return dest as! SizeOfPointer
}

enum DllEntryReason: UInt32 {
	DLL_PROCESS_ATTACH = 1
}

// TODO set as entry @linkName('greenteaosIsTheBest')
fun greenteaosIsTheBest(startup ProcessStartupInformation) {
	kkernelDebugLog("CRT prepare for startup info at %8".utf16(), startup as! UInt32)
	// TODO get this info from PEB, after all
	let entry ExeEntry? = startup.entry as! ExeEntry
	let pid UInt64 = startup.pid
	let dllEntries UInt64 = startup.dllEntries
	// TODO entry arguments (argv, argc)
	// TODO probably should call own DLL startup code (hexa main)
	// TODO init DLLs
	// TODO PEB/TEB
	// TODO TLS callbacks [before EXE entry]

	/* - look for IMAGE_TLS_DIRECTORY (IMAGE_DIRECTORY_ENTRY_TLS) and AddressOfCallBacks must be not 0. So this is real entry point(s) of this EXE - no other option, otherwise EXE will crashes.
	So solution is to look for IMAGE_DIRECTORY_ENTRY_TLS.AddressOfCallBacks or set breakpoint to LdrpCallTlsInitializers*/

	/*
	really this was CLR (.NET) image - in this images type entry point is formal and not used after xp. system ignore it and call _CorExeMain in mscoree.dll as entry point.
	https://msdn.microsoft.com/en-us/library/xh0859k0(v=vs.110).aspx
	*/
	// TODO delay-loaded DLLs
	// TODO load DLLs in user mode
	kkernelDebugLog("CRT ready for PID %u".utf16(), pid)
	// TODO as stricture `{ count UInt32, dllEntries ArrayByValue<...> }`
	let count = startup.dllCount
	let dllMains = dllEntries as! ConstArrayPointer<DllEntry?>

	if dllEntries == 0 {
		kkernelDebugLog("dllEntries == 0 for PID %u".utf16(), pid)
	}

	for i in count {
		// TODO DLL name
		// DLL may have no entry
		if let entryPoint = dllMains[i] {
			kkernelDebugLog("entry != null OK for DLL %u at %8".utf16(), i, entryPoint)
			// TODO hInstance
			let hInstance = null as! ConstArrayPointer<Void>
			// TODO handle returned value
			entryPoint(hInstance, DllEntryReason.DLL_PROCESS_ATTACH, null)
		}
		// TODO add DLL to PEB list
	}

	// TODO unmap entries/ProcessStartupInformation if required
	// ^ probably map it right after where NTDLL is mapped
	kkernelDebugLog("done %u DLLs".utf16(), count)

	if entry != null {
		// Note: some apps require entry to be called even if its zero to invoke TLS callbacks
		kkernelDebugLog("entry != null OK for PID %u at %8".utf16(), pid, entry)
	}

	if entry == null {
		kkernelDebugLog("entry == null ERROR for PID %u".utf16(), pid)
	}

	// TODO non-null stubs here, like HInstance etc
	// let hInstance = null as! ConstArrayPointer<Void>
	// TODO detect SUBSYSTEM:CONSOLE
	// TODO actual command line
	// let cmd ArrayByValue<UInt16, 5> = "demo"
	// TODO is it really LPSTR or LPWSTR?
	// let pCmdLine = cmd.ref as! ConstArrayPointer<Void>
	// kosmos32ExitProcess(entry(hInstance, null, pCmdLine, 0))
	if let entry = entry, false {
		{ return }
		// No arguments taken, they are produced by the CRT within .exe itself
		// Guessing by CRT0 examples, it's likely to return error code than void
		let entryPoint ConsoleEntry = entry as! ConsoleEntry
		kosmos32ExitProcess(entryPoint(null, null, null, 0) as! Int32)
		// TODO calling without args breaks demo64.exe but that one has no CRT so this should be used later
		// kosmos32ExitProcess(entry())
		return
	}

	// Well, weird .exe or does stuff via TLS callbacks, thus we *must* cause page fault when entry is null
	// TODO Hexa: `= entry!`
	let entry ExeEntry = entry as! ExeEntry
	let result = entry()

	// Whatever
	kosmos32ExitProcess(result)
}

// TODO get this structure from FS/GS
greenteaosIsTheBest(hexa_startup as! ProcessStartupInformation)
